{
  "name": "seniorpath",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "build": "pnpm --filter @seniorpath/web build",
    "build:all": "pnpm build && pnpm build:site",
    "build:site": "pnpm --filter @seniorpath/site build",
    "dev:all": "node scripts/dev-all.mjs",
    "dev": "pnpm --filter @seniorpath/web dev",
    "dev:site": "pnpm --filter @seniorpath/site dev",
    "lint": "pnpm --filter @seniorpath/web lint",
    "preview": "pnpm --filter @seniorpath/web preview",
    "preview:site": "pnpm --filter @seniorpath/site preview",
    "test": "pnpm --filter @seniorpath/web test",
    "typecheck:site": "pnpm --filter @seniorpath/site check",
    "typecheck": "pnpm --filter @seniorpath/web exec tsc -b",
    "verify": "pnpm lint && pnpm test && pnpm typecheck && pnpm typecheck:site && pnpm build && pnpm build:site"
  }
}
