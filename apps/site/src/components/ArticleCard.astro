---
import type { CollectionEntry } from 'astro:content'
import { getGuideHrefFromEntry } from '../lib/guide-links'
import { getSiteCopy } from '../lib/site-copy'

type Props = {
  categoryLabel?: string
  className?: string
  eyebrow?: string
  post: CollectionEntry<'guides'>
}

const {
  categoryLabel,
  className,
  eyebrow,
  post,
} = Astro.props
const href = getGuideHrefFromEntry(post)
const copy = getSiteCopy(post.data.locale)
---

<article
  class:list={['panel', 'article-card', className]}
  data-guide-card-category={categoryLabel}
  data-guide-post={post.data.guideId}
>
  <a class="article-card__link" href={href}>
    <div class="article-card__body">
      {eyebrow ? <p class="article-card__eyebrow">{eyebrow}</p> : null}
      <h3 class="article-card__title">{post.data.title}</h3>
      <p class="article-card__summary">{post.data.description}</p>
    </div>
    <div class="article-card__footer">
      <span class="article-card__cta">
        <span>{copy.learn}</span>
        <span aria-hidden="true">→</span>
      </span>
    </div>
  </a>
</article>
