---
import type { CollectionEntry } from 'astro:content'
import { getGuideHrefFromEntryId } from '../lib/guide-links'
import { getSiteCopy } from '../lib/site-copy'

type Props = {
  categoryLabel?: string
  className?: string
  eyebrow?: string
  post: CollectionEntry<'guides'>
}

const {
  categoryLabel,
  className,
  eyebrow,
  post,
} = Astro.props
const href = getGuideHrefFromEntryId(post.id)
const copy = getSiteCopy(post.data.locale)
---

<article
  class:list={['panel', 'article-card', className]}
  data-guide-card-category={categoryLabel}
  data-guide-post={post.data.guideId}
>
  <div class="article-card__body">
    {eyebrow ? <p class="article-card__eyebrow">{eyebrow}</p> : null}
    <h3>
      <a class="article-card__title-link" href={href}>{post.data.title}</a>
    </h3>
    <p class="article-card__summary">{post.data.summary}</p>
  </div>
  <div class="article-card__footer">
    <a class="button-link button-link--primary" href={href}>{copy.learn}</a>
  </div>
</article>
