---
import { articleCompletionSummaryDomHooks, getDataHookAttributes } from '@/lib/dom-hooks'
import type { ArticleRecommendationCandidate, ArticleRecommendationLink } from '@/lib/article-recommendations'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'
import { ui } from '@/lib/ui'

type TrackSummary = {
  href: string
  stepIndex: number
  title: string
  totalSteps: number
}

type Props = {
  locale: SiteLocale
  nextStep?: ArticleRecommendationLink | null
  recommendationCandidates?: ArticleRecommendationCandidate[]
  relatedItems?: ArticleRecommendationLink[]
  track?: TrackSummary | null
  variant?: 'compact' | 'default'
}

const {
  locale,
  nextStep = null,
  recommendationCandidates = [],
  track = null,
  variant = 'default',
} = Astro.props

const copy = getSiteCopy(locale)
const isCompact = variant === 'compact'
const completionHeadingClass = isCompact
  ? 'm-0 flex items-center gap-2 text-[0.88rem] font-semibold leading-6 text-site-ink lg:text-[0.96rem]'
  : 'm-0 flex items-center gap-2 text-[0.92rem] font-semibold leading-6 text-site-ink lg:text-[1rem]'
const trackMetaClass = isCompact
  ? 'm-0 text-[0.78rem] leading-6 text-site-ink-soft lg:text-[0.86rem]'
  : 'm-0 text-[0.8rem] leading-6 text-site-ink-soft lg:text-[0.88rem]'
const nextStepTitleClass = isCompact
  ? 'text-[0.88rem] font-semibold leading-6 text-site-ink transition-colors duration-150 group-hover:text-site-link-hover group-focus-visible:text-site-link-hover lg:text-[0.96rem]'
  : 'text-[0.9rem] font-semibold leading-6 text-site-ink transition-colors duration-150 group-hover:text-site-link-hover group-focus-visible:text-site-link-hover lg:text-[0.98rem]'
const nextStepMetaClass = isCompact
  ? 'text-[0.76rem] font-medium text-site-ink-soft lg:text-[0.84rem]'
  : 'text-[0.78rem] font-medium text-site-ink-soft lg:text-[0.86rem]'
const quietActionClass = isCompact
  ? 'w-fit text-[0.76rem] font-medium text-site-ink-muted transition-colors duration-150 hover:text-site-link-hover focus-visible:text-site-link-hover focus-visible:outline-none lg:text-[0.84rem]'
  : ui.quietAction
---

<div
  class="grid gap-4"
  {...getDataHookAttributes(articleCompletionSummaryDomHooks.root)}
  {...getDataHookAttributes(articleCompletionSummaryDomHooks.recommendationCandidates, JSON.stringify(recommendationCandidates))}
>
  <div class="grid gap-2">
    <p class={completionHeadingClass}>
      <span aria-hidden="true" class="text-site-success">✓</span>
      <span>{copy.article.finishedArticle}</span>
    </p>
    {track ? (
      <p class={trackMetaClass}>
        {copy.article.partOfTrack}:{' '}
        <a class="font-medium text-site-ink transition-colors duration-150 hover:text-site-link-hover focus-visible:text-site-link-hover focus-visible:outline-none" href={track.href}>
          {track.title}
        </a>{' '}
        ({track.stepIndex}/{track.totalSteps})
      </p>
    ) : null}
  </div>

  <div
    class="grid gap-2"
    hidden={!nextStep}
    {...getDataHookAttributes(articleCompletionSummaryDomHooks.nextStepSection)}
  >
    <p class={ui.eyebrow}>{copy.article.nextStep}</p>
    <a
      class={ui.subtlePanelLink}
      href={nextStep?.href ?? '#'}
      {...getDataHookAttributes(articleCompletionSummaryDomHooks.nextStepLink)}
    >
      <span class={nextStepTitleClass} {...getDataHookAttributes(articleCompletionSummaryDomHooks.nextStepTitle)}>
        {nextStep?.title ?? ''}
      </span>
      <span class={nextStepMetaClass}>{copy.article.nextStep} →</span>
    </a>
  </div>

  <button class={quietActionClass} {...getDataHookAttributes(articleCompletionSummaryDomHooks.markUnread)} type="button">
    {copy.article.markUnread}
  </button>
</div>
