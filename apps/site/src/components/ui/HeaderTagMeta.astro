---
import { cn } from '@/lib/cn'
import { ui } from '@/lib/ui'

type HeaderTagMetaItem = {
  href?: string | null
  label: string
}

type Props = {
  className?: string
  items: HeaderTagMetaItem[]
}

const { className = '', items } = Astro.props
const visibleItems = items.filter((item) => item.label.trim().length > 0)
---

{visibleItems.length > 0 ? (
  <div class={cn(ui.articleHeaderTagTone, 'mt-3 flex flex-wrap gap-x-3 gap-y-1.5', className)}>
    {visibleItems.map((item) => (
      item.href ? (
        <a
          class="transition-colors duration-200 ease-out hover:text-site-link-hover focus-visible:text-site-link-hover focus-visible:outline-none"
          href={item.href}
        >
          {item.label}
        </a>
      ) : (
        <span>{item.label}</span>
      )
    ))}
  </div>
) : null}
