---
import { cn } from '@/lib/cn'
import { ui } from '@/lib/ui'

type Props = {
  bodyClass?: string
  className?: string
  description?: string
  descriptionClass?: string
  href?: string
  title: string
  titleClass?: string
}

const {
  bodyClass = '',
  className = '',
  description,
  descriptionClass = ui.bodyCopy,
  href,
  title,
  titleClass = ui.eyebrow,
} = Astro.props
---

<section class={cn(ui.panel, 'grid gap-4 p-5', className)}>
  <div class={ui.sectionHeader}>
    <div class="grid gap-1">
      <p class={titleClass}>
        {href ? (
          <a class="transition-colors duration-150 hover:text-site-link-hover" href={href}>{title}</a>
        ) : (
          title
        )}
      </p>
      {description ? <p class={descriptionClass}>{description}</p> : null}
      <slot name="header" />
    </div>
  </div>

  {bodyClass ? (
    <div class={bodyClass}>
      <slot />
    </div>
  ) : (
    <slot />
  )}
</section>
