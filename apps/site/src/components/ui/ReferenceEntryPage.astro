---
import ArticleStickyMeta from '@/components/ArticleStickyMeta.astro'
import ArticleCompletionPanel from '@/components/ArticleCompletionPanel.astro'
import ArticleCompletionRail from '@/components/ArticleCompletionRail.astro'
import ArticleSharePanel from '@/components/ArticleSharePanel.astro'
import AuthorByline from '@/components/ui/AuthorByline.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import ContentArticleHeader from '@/components/ui/ContentArticleHeader.astro'
import { articleReadingDomHooks, getDataHookAttributes } from '@/lib/dom-hooks'
import type { ArticleRecommendationLink } from '@/lib/article-recommendations'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'
import { ui } from '@/lib/ui'

type TocHeading = {
  depth: number
  slug: string
  text: string
}

type Props = {
  alternateLocaleHrefs?: Record<string, string | null>
  completionId?: string | null
  createdMeta: string | null
  description: string
  headings?: TocHeading[]
  locale: SiteLocale
  localeHrefs?: Record<string, string | null>
  nextStep?: ArticleRecommendationLink | null
  socialImage?: string
  structuredData?: Record<string, unknown> | Record<string, unknown>[]
  title: string
  updatedMeta?: string | null
  url: string
}

const {
  alternateLocaleHrefs = {},
  completionId = null,
  createdMeta,
  description,
  headings = [],
  locale,
  localeHrefs = {},
  nextStep = null,
  socialImage,
  structuredData = [],
  title,
  updatedMeta = null,
  url,
} = Astro.props
const copy = getSiteCopy(locale)

---

<BaseLayout
  alternateLocaleHrefs={alternateLocaleHrefs}
  contentWidth="wide"
  description={description}
  localeHrefs={localeHrefs}
  socialImage={socialImage}
  structuredData={structuredData}
  title={title}
>
  <article class="w-full pb-11">
    <ContentArticleHeader
      className="article-header-wide-shell"
      createdMeta={createdMeta}
      createdMetaClassName={ui.articleHeaderTagTone}
      description={description}
      title={title}
    >
      <div data-pagefind-ignore>
        <AuthorByline />
        {updatedMeta ? (
          <p class={`mt-3 ${ui.articleHeaderTagTone}`}>
            {copy.article.updatedPrefix} {updatedMeta}
          </p>
        ) : null}
        <slot name="headerMeta" />
      </div>
    </ContentArticleHeader>

    <div data-pagefind-ignore>
      <ArticleStickyMeta
        className="article-reading-shell mx-auto my-5 w-full xl:hidden"
        completionId={completionId}
        headings={headings}
        locale={locale}
        nextStep={nextStep}
        showCompletionInPlace={false}
      />
    </div>

    <div class={ui.articleRailLayout}>
      <div class={ui.articleRailLayoutMain}>
        <div class="article-prose" {...getDataHookAttributes(articleReadingDomHooks.content)}>
          <slot />
        </div>
        <div aria-hidden="true" class="h-px" {...getDataHookAttributes(articleReadingDomHooks.end)}></div>
      </div>

      <div class={ui.articleRailLayoutGuide} data-pagefind-ignore>
        <ArticleStickyMeta
          completionId={completionId}
          headings={headings}
          locale={locale}
          nextStep={nextStep}
          showCompletionInPlace={false}
        />

        {completionId ? (
          <ArticleCompletionRail
            className={ui.articleRailLayoutCompletion}
            completionId={completionId}
            locale={locale}
            nextStep={nextStep}
          />
        ) : null}
      </div>
    </div>

    <div data-pagefind-ignore>
      {completionId ? (
        <ArticleCompletionPanel
          className="mt-6"
          completionId={completionId}
          locale={locale}
          nextStep={nextStep}
        />
      ) : null}

      <ArticleSharePanel
        description={description}
        locale={locale}
        title={title}
        useDetailShell={true}
        url={url}
      />

      <slot name="afterContent" />
    </div>
  </article>
</BaseLayout>
