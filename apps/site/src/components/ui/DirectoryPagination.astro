---
import { getPaginationSlots } from '@/lib/directory'
import { directoryPaginationDomHooks, getDataHookAttributes } from '@/lib/dom-hooks'
import { cn } from '@/lib/cn'
import { ui } from '@/lib/ui'

type Props = {
  currentPage: number
  getHref: (page: number) => string
  nextLabel: string
  pageCount: number
  pageLabel: string
  previousLabel: string
}

const { currentPage, getHref, nextLabel, pageCount, pageLabel, previousLabel } = Astro.props
const slots = getPaginationSlots(currentPage, pageCount)
---

{pageCount > 1 ? (
  <nav
    aria-label={`${pageLabel} navigation`}
    class="mt-6 flex flex-wrap items-center justify-center gap-2"
    {...getDataHookAttributes(directoryPaginationDomHooks.root)}
  >
    {currentPage > 1 ? (
      <a
        class={cn(ui.controlButton, 'min-h-10 px-4 text-sm font-semibold')}
        href={getHref(currentPage - 1)}
        {...getDataHookAttributes(directoryPaginationDomHooks.previousLink)}
      >
        {previousLabel}
      </a>
    ) : null}
    {slots.map((slot) =>
      slot.type === 'ellipsis' ? (
        <span
          aria-hidden="true"
          class="inline-flex min-h-10 min-w-8 items-center justify-center px-1 text-sm font-semibold text-site-ink-muted"
        >
          ...
        </span>
      ) : (
        <a
          aria-current={slot.value === currentPage ? 'page' : undefined}
          class={cn(
            ui.controlButton,
            'min-h-10 min-w-10 px-3 text-sm font-semibold',
            slot.value === currentPage && 'border-site-line-strong bg-site-hover text-site-link-hover',
          )}
          href={getHref(slot.value)}
          {...getDataHookAttributes(directoryPaginationDomHooks.pageLink, String(slot.value))}
        >
          <span class="sr-only">{pageLabel} </span>
          {slot.value}
        </a>
      ),
    )}
    {currentPage < pageCount ? (
      <a
        class={cn(ui.controlButton, 'min-h-10 px-4 text-sm font-semibold')}
        href={getHref(currentPage + 1)}
        {...getDataHookAttributes(directoryPaginationDomHooks.nextLink)}
      >
        {nextLabel}
      </a>
    ) : null}
  </nav>
) : null}
