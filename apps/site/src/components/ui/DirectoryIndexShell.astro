---
import BaseLayout from '@/layouts/BaseLayout.astro'
import CompactSection from '@/components/ui/CompactSection.astro'
import PageHeader from '@/components/ui/PageHeader.astro'
import RecentlyUpdatedSection from '@/components/RecentlyUpdatedSection.astro'
import type { RecentUpdateItem } from '@/lib/recent-updates'
import type { SiteLocale } from '@/lib/site-copy'

type BreadcrumbItem = {
  href: string | null
  label: string
}

type Props = {
  alternateLocaleHrefs?: Record<string, string | null>
  breadcrumbs?: BreadcrumbItem[]
  description: string
  icon?: any
  iconLabel?: string
  localeHrefs?: Record<string, string | null>
  noindex?: boolean
  pagefind?: boolean
  pageHeaderClassName?: string
  recentUpdates?: RecentUpdateItem[]
  recentUpdatesLocale?: SiteLocale
  title: string
}

const {
  alternateLocaleHrefs = {},
  breadcrumbs = [],
  description,
  icon: Icon = null,
  iconLabel = '',
  localeHrefs = {},
  noindex = false,
  pagefind = true,
  pageHeaderClassName = '',
  recentUpdates = [],
  recentUpdatesLocale,
  title,
} = Astro.props
---

<BaseLayout
  alternateLocaleHrefs={alternateLocaleHrefs}
  description={description}
  localeHrefs={localeHrefs}
  noindex={noindex}
  pagefind={pagefind}
  title={title}
>
  <PageHeader
    breadcrumbs={breadcrumbs}
    className={pageHeaderClassName}
    description={description}
    icon={Icon}
    iconLabel={iconLabel}
    title={title}
  />

  <div data-pagefind-ignore>
    <CompactSection>
      <slot />
    </CompactSection>
  </div>

  {recentUpdatesLocale ? (
    <div data-pagefind-ignore>
      <RecentlyUpdatedSection items={recentUpdates} locale={recentUpdatesLocale} />
    </div>
  ) : null}
</BaseLayout>
