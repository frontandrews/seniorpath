---
import BaseLayout from '@/layouts/BaseLayout.astro'
import CompactSection from '@/components/ui/CompactSection.astro'
import PageHeader from '@/components/ui/PageHeader.astro'

type BreadcrumbItem = {
  href: string | null
  label: string
}

type Props = {
  breadcrumbs?: BreadcrumbItem[]
  description: string
  englishHref?: string | null
  icon?: any
  iconLabel?: string
  pageHeaderClassName?: string
  portugueseHref?: string | null
  title: string
}

const {
  breadcrumbs = [],
  description,
  englishHref = null,
  icon: Icon = null,
  iconLabel = '',
  pageHeaderClassName = '',
  portugueseHref = null,
  title,
} = Astro.props
---

<BaseLayout
  description={description}
  englishHref={englishHref}
  portugueseHref={portugueseHref}
  title={title}
>
  <PageHeader
    breadcrumbs={breadcrumbs}
    className={pageHeaderClassName}
    description={description}
    icon={Icon}
    iconLabel={iconLabel}
    title={title}
  />

  <CompactSection>
    <slot />
  </CompactSection>
</BaseLayout>
