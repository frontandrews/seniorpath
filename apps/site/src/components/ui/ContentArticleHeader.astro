---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import { cn } from '@/lib/cn'
import { ui } from '@/lib/ui'

type BreadcrumbItem = {
  href: string | null
  label: string
}

type Props = {
  breadcrumbs?: BreadcrumbItem[]
  className?: string
  createdMeta?: string | null
  createdMetaClassName?: string
  description: string
  meta?: string
  title: string
}

const {
  breadcrumbs = [],
  className = '',
  createdMeta = null,
  createdMetaClassName = '',
  description,
  meta,
  title,
} = Astro.props
---

<header class={cn(ui.articleHeader, className)}>
  {breadcrumbs.length > 0 ? <Breadcrumbs items={breadcrumbs} /> : null}
  {createdMeta ? <p class={cn(ui.articleKicker, createdMetaClassName)}>{createdMeta}</p> : null}
  <h1 class={ui.articleTitle}>{title}</h1>
  <p class={ui.articleExcerpt}>{description}</p>
  <slot />
  {meta ? <p class={ui.articleMeta}>{meta}</p> : null}
</header>
