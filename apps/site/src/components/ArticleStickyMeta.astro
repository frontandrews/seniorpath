---
import { randomUUID } from 'node:crypto'
import ArticleCompletionSummary from '@/components/ArticleCompletionSummary.astro'
import ArticleStickyMetaClient from '@/components/ArticleStickyMetaClient.svelte'
import { cn } from '@/lib/cn'
import {
  articleCompletionPanelDomHooks,
  articleStickyMetaDomHooks,
  getDataHookAttributes,
  sharedDomHooks,
} from '@/lib/dom-hooks'
import type { ArticleRecommendationCandidate, ArticleRecommendationLink } from '@/lib/article-recommendations'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'
import { ui } from '@/lib/ui'

type TrackSummary = {
  href: string
  stepIndex: number
  title: string
  totalSteps: number
}

type TocHeading = {
  depth: number
  slug: string
  text: string
}

type Props = {
  className?: string
  completionId?: string | null
  headings: TocHeading[]
  categoryLabel?: string
  levelLabel?: string
  locale: SiteLocale
  nextStep?: ArticleRecommendationLink | null
  readingTimeMinutes?: number | null
  recommendationCandidates?: ArticleRecommendationCandidate[]
  relatedItems?: ArticleRecommendationLink[]
  showCompletionInPlace?: boolean
  track?: TrackSummary | null
  updatedMeta?: string | null
}

const {
  className = '',
  completionId = null,
  headings,
  categoryLabel = '',
  levelLabel = '',
  locale,
  nextStep = null,
  readingTimeMinutes = null,
  recommendationCandidates = [],
  relatedItems = [],
  showCompletionInPlace = true,
  track = null,
  updatedMeta = null,
} = Astro.props

const copy = getSiteCopy(locale)
const controllerId = randomUUID()
---

<aside class={cn('grid gap-4', className)}>
  <section
    class={cn(
      ui.panel,
      ui.spotlightPanel,
      'gap-3 px-4 py-3.5 lg:px-4 lg:py-4 xl:border-0 xl:bg-transparent xl:max-h-[calc(100vh-8.5rem)] xl:overflow-y-auto',
    )}
    {...getDataHookAttributes(sharedDomHooks.controllerId, controllerId)}
    {...getDataHookAttributes(articleCompletionPanelDomHooks.completionId, completionId ?? '')}
    {...getDataHookAttributes(articleStickyMetaDomHooks.showCompletionInPlace, showCompletionInPlace ? 'true' : 'false')}
    {...getDataHookAttributes(articleStickyMetaDomHooks.root)}
  >
    {updatedMeta || (readingTimeMinutes && levelLabel && categoryLabel) || headings.length > 0 ? (
      <div class="grid gap-2" {...getDataHookAttributes(articleStickyMetaDomHooks.tocSection)}>
        {updatedMeta ? (
          <div class={cn(ui.metaQuiet, 'grid gap-1')}>
            {updatedMeta ? <p class="m-0">{copy.article.updatedPrefix} {updatedMeta}</p> : null}
          </div>
        ) : null}

        {readingTimeMinutes && levelLabel && categoryLabel ? (
          <div class={cn(ui.metaQuiet, 'flex flex-wrap items-center gap-x-2 gap-y-1')}>
            <span>{readingTimeMinutes} min</span>
            <span aria-hidden="true" class="text-site-ink-muted">•</span>
            <span>{levelLabel}</span>
            <span aria-hidden="true" class="text-site-ink-muted">•</span>
            <span>{categoryLabel}</span>
          </div>
        ) : null}

        {headings.length > 0 ? (
          <>
            <p class={cn(ui.eyebrow, 'text-site-line-strong')}>{copy.article.tableOfContents}</p>
            <nav aria-label={copy.article.tableOfContents} class="grid gap-0.5">
              {headings.map((heading) => (
                <a
                  class={cn(
                    'article-toc-link',
                    'px-0 py-0.5 text-[0.9rem] leading-[1.45] text-site-line-strong transition-colors duration-150 hover:text-site-link-hover focus-visible:text-site-link-hover focus-visible:outline-none lg:text-[0.94rem]',
                    heading.depth > 2 && 'ml-2 text-[0.82rem] lg:text-[0.88rem]',
                  )}
                  {...getDataHookAttributes(articleStickyMetaDomHooks.tocLink)}
                  {...getDataHookAttributes(articleStickyMetaDomHooks.tocSlug, heading.slug)}
                  data-astro-reload
                  href={`#${heading.slug}`}
                >
                  {heading.text}
                </a>
              ))}
            </nav>
          </>
        ) : null}
      </div>
    ) : null}

    <div class="article-reading-progress grid gap-2 border-t border-site-line pt-4" data-js-only="true" {...getDataHookAttributes(articleStickyMetaDomHooks.readingProgress)}>
      <div class="flex items-center gap-3">
        <div class={cn('min-w-0 flex-1', ui.progressTrack)}>
          <div
            class={cn('article-reading-progress-bar', ui.progressBarSolid)}
            {...getDataHookAttributes(articleStickyMetaDomHooks.readingProgressBar)}
          />
        </div>
        <p class={cn('article-reading-progress-value', ui.progressMeta, 'shrink-0 text-site-line-strong lg:text-[0.88rem]')} {...getDataHookAttributes(articleStickyMetaDomHooks.readingProgressValue)}>
          0%
        </p>
      </div>
    </div>

    {showCompletionInPlace ? (
      <div
        class="grid gap-3 overflow-hidden border-t border-site-line"
        {...getDataHookAttributes(articleStickyMetaDomHooks.stickyDirection)}
        style="max-height: 0; opacity: 0; transform: translateY(0.5rem); padding-top: 0; border-top-color: transparent; pointer-events: none; transition: max-height 300ms ease, opacity 220ms ease, transform 300ms ease, padding-top 300ms ease, border-top-color 220ms ease;"
      >
        <ArticleCompletionSummary
          locale={locale}
          nextStep={nextStep}
          recommendationCandidates={recommendationCandidates}
          relatedItems={relatedItems}
          track={track}
          variant="compact"
        />
      </div>
    ) : null}

    <ArticleStickyMetaClient client:idle controllerId={controllerId} />
  </section>
</aside>
