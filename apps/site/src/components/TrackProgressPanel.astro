---
import { randomUUID } from 'node:crypto'
import ArrowRightIcon from '@/components/ui/icons/ArrowRightIcon.astro'
import TrackProgressPanelClient from '@/components/TrackProgressPanelClient.svelte'
import { cn } from '@/lib/cn'
import { getDataHookAttributes, sharedDomHooks, trackProgressDomHooks } from '@/lib/dom-hooks'
import { getSiteCopy, getSiteLowerCaseLocale, type SiteLocale } from '@/lib/site-copy'
import { ui } from '@/lib/ui'

type TrackItem = {
  articleId: string
  href: string
  title: string
}

type Props = {
  className?: string
  items: TrackItem[]
  locale: SiteLocale
  totalReadingMinutes: number
}

const {
  className = '',
  items,
  locale,
  totalReadingMinutes,
} = Astro.props

const copy = getSiteCopy(locale)
const metaLine = `${items.length} ${copy.startHere.stepsLabel.toLocaleLowerCase(getSiteLowerCaseLocale(locale))} • ~${totalReadingMinutes} min`
const ofLabel = copy.trackProgress.ofLabel
const initialHref = items[0]?.href ?? '#'
const controllerId = randomUUID()
---

<section
  class={cn('track-progress-root', ui.compactSection, className)}
  {...getDataHookAttributes(sharedDomHooks.controllerId, controllerId)}
  {...getDataHookAttributes(trackProgressDomHooks.root)}
  {...getDataHookAttributes(trackProgressDomHooks.ofLabel, ofLabel)}
  {...getDataHookAttributes(trackProgressDomHooks.progressLabel, copy.startHere.progressLabel)}
  {...getDataHookAttributes(trackProgressDomHooks.stepLabel, copy.startHere.stepLabel)}
  {...getDataHookAttributes(trackProgressDomHooks.completedLabel, copy.startHere.trackCompleted)}
  {...getDataHookAttributes(trackProgressDomHooks.continueLabel, copy.trackProgress.continueTrack)}
>
  <div class="grid gap-5 border-y border-site-line bg-transparent px-[0.45rem] py-5 lg:gap-6 lg:px-[0.55rem] lg:py-6">
    <div class="grid gap-2.5">
      <p class={ui.progressMeta}>
        {metaLine}
      </p>
      <p class={cn(ui.metaQuiet, 'text-sm leading-6')} data-no-js-only="true" {...getDataHookAttributes(trackProgressDomHooks.noJsNote)}>
        {copy.trackProgress.noJsDescription}
      </p>
      <div class="grid gap-2" data-js-only="true">
        <div class="flex items-center justify-between gap-4">
          <p class="track-progress-status m-0 text-[0.9rem] font-medium text-site-ink lg:text-[0.98rem]" {...getDataHookAttributes(trackProgressDomHooks.progressStatus)}>
            {copy.startHere.progressLabel}: {copy.startHere.stepLabel} 1 {ofLabel} {items.length}
          </p>
          <p class="track-progress-value m-0 text-[0.82rem] font-semibold text-site-ink-soft lg:text-[0.9rem]" {...getDataHookAttributes(trackProgressDomHooks.progressValue)}>
            0%
          </p>
        </div>
        <div class={ui.progressTrackStrong}>
          <div
            class={cn('track-progress-bar', ui.progressBar)}
            {...getDataHookAttributes(trackProgressDomHooks.progressBar)}
          />
        </div>
      </div>
    </div>

    <a
      class={ui.cardButton}
      {...getDataHookAttributes(trackProgressDomHooks.cta)}
      href={initialHref}
    >
      <span {...getDataHookAttributes(trackProgressDomHooks.ctaLabel)}>{copy.startHere.continueWhereLeftOff}</span>
      <ArrowRightIcon className="size-[0.92rem]" />
    </a>

    <div class="grid gap-3 border-t border-site-line pt-4" hidden>
      <p class={cn(ui.progressStatus, 'track-progress-overall m-0 flex items-center justify-center gap-2 text-center text-[0.98rem] font-semibold lg:text-[1.08rem]')}>
        <span aria-hidden="true" class="text-site-ink-muted" {...getDataHookAttributes(trackProgressDomHooks.overallIcon)}>→</span>
        <span {...getDataHookAttributes(trackProgressDomHooks.overallText)}>{copy.trackProgress.continueTrack}</span>
      </p>
    </div>

    <div class="hidden" aria-hidden="true">
      {items.map((item) => (
        <a
          {...getDataHookAttributes(trackProgressDomHooks.item)}
          {...getDataHookAttributes(trackProgressDomHooks.itemHref, item.href)}
          {...getDataHookAttributes(trackProgressDomHooks.itemId, item.articleId)}
          href={item.href}
        >
          {item.title}
        </a>
      ))}
    </div>

    <TrackProgressPanelClient client:idle controllerId={controllerId} />
  </div>
</section>
