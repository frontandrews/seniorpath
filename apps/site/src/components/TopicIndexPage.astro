---
import type { TopicDefinition } from '@seniorpath/content'

import BaseLayout from '@/layouts/BaseLayout.astro'
import PageHeader from '@/components/ui/PageHeader.astro'
import SectionBlock from '@/components/ui/SectionBlock.astro'
import LinkCard from '@/components/ui/LinkCard.astro'
import { getTopicHref, getTopicIndexHref } from '@/lib/topic-links'
import { getLocalizedTopicLabel } from '@/lib/topic-taxonomy'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'
import { ui } from '@/lib/ui'

type TopicWithCount = {
  count: number
  topic: TopicDefinition
}

type Props = {
  locale: SiteLocale
  topics: TopicWithCount[]
}

const { locale, topics } = Astro.props
const copy = getSiteCopy(locale)
const selectionLabel = locale === 'pt-br' ? 'Escolha um topico' : 'Select a topic'
---

<BaseLayout
  description={copy.topicIndex.copy}
  englishHref={getTopicIndexHref('en')}
  portugueseHref={getTopicIndexHref('pt-br')}
  title={copy.topicIndex.title}
>
  <PageHeader description={copy.topicIndex.copy} title={copy.topicIndex.title} />

  <SectionBlock bodyClass={ui.cardsGrid} eyebrow={selectionLabel}>
      {topics.map(({ topic }) => (
        <article class="group h-full">
          <LinkCard
            href={getTopicHref(topic.id, locale)}
            showArrow={false}
            title={getLocalizedTopicLabel(topic.id, locale)}
            titleClass="m-0 text-base font-semibold leading-[1.32]"
            titleTag="h3"
            variant="ghost"
          />
        </article>
      ))}
  </SectionBlock>
</BaseLayout>
