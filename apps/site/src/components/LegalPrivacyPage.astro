---
import StaticArticlePage from '@/components/ui/StaticArticlePage.astro'
import LegalOperationalReview from '@/components/LegalOperationalReview.astro'
import { getDataHookAttributes, legalPageDomHooks } from '@/lib/dom-hooks'
import { getLegalContactLinks } from '@/lib/legal-contact'
import { getLegalPageCopy } from '@/lib/legal-page-copy'
import {
  getLegalGoverningLaw,
  getLegalOperatorLocation,
  getLegalOperatorName,
  getLegalTemplateNotice,
  siteConfig,
} from '@/lib/site-config'
import { resolveLocaleHrefMap } from '@/lib/locale-config'
import { getPrivacyHref } from '@/lib/privacy-links'
import { getSiteLocale, type SiteLocale } from '@/lib/site-copy'

type Props = {
  locale?: SiteLocale
}

const { locale: requestedLocale = 'en' } = Astro.props
const locale = getSiteLocale(requestedLocale)
const { legalEmail, supportEmail } = getLegalContactLinks()
const privacyContactEmail = legalEmail ?? supportEmail
const operatorName = getLegalOperatorName(locale)
const operatorLocation = getLegalOperatorLocation(locale)
const governingLaw = getLegalGoverningLaw(locale)
const templateNotice = getLegalTemplateNotice(locale)
const localeHrefs = resolveLocaleHrefMap((supportedLocale) => getPrivacyHref(supportedLocale))
const copy = getLegalPageCopy(locale).privacy
const copyContext = {
  governingLaw,
  operatorLocation,
  operatorName,
  siteName: siteConfig.site.name,
}
---

<StaticArticlePage
  description={copy.description(siteConfig.site.name)}
  kicker="Legal"
  localeHrefs={localeHrefs}
  title={copy.title}
>
  <blockquote>
    <p>
      <strong>{copy.templateNoteLabel}</strong> {templateNotice}
    </p>
  </blockquote>

  <p>{copy.intro(siteConfig.site.name)}</p>

  <section {...getDataHookAttributes(legalPageDomHooks.publicationChecklist)}>
    <h2>{copy.publishChecklist.title}</h2>
    <ul>
      {copy.publishChecklist.items.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <h2>{copy.whoControls.title}</h2>
  <p>
    {copy.whoControls.body(copyContext)}
    {privacyContactEmail ? (
      <>
        {' '}
        {copy.whoControls.contactPrefix}{' '}
        <a href={privacyContactEmail.href}>{privacyContactEmail.value}</a>.
      </>
    ) : null}
  </p>

  <h2>{copy.collectedData.title}</h2>
  <ul>
    {copy.collectedData.items?.map((item) => <li>{item}</li>)}
  </ul>

  <h2>{copy.howDataIsUsed.title}</h2>
  <ul>
    {copy.howDataIsUsed.items?.map((item) => <li>{item}</li>)}
  </ul>

  <h2>{copy.cookies.title}</h2>
  <p>{copy.cookies.body(copyContext)}</p>

  <h2>{copy.thirdPartyServices.title}</h2>
  <p>{copy.thirdPartyServices.body(copyContext)}</p>

  <LegalOperationalReview locale={locale} />

  <h2>{copy.retention.title}</h2>
  <p>{copy.retention.body(copyContext)}</p>

  <h2>{copy.yourRights.title}</h2>
  <p>{copy.yourRights.body(copyContext)}</p>

  <h2>{copy.changes.title}</h2>
  <p>{copy.changes.body(copyContext)}</p>

  <h2>{copy.applicableLaw.title}</h2>
  <p>{copy.applicableLaw.body(copyContext)}</p>

  {privacyContactEmail && copy.contact ? (
    <>
      <h2>{copy.contact.title}</h2>
      <p>
        {copy.contact.bodyPrefix} <a href={privacyContactEmail.href}>{privacyContactEmail.value}</a>.
      </p>
    </>
  ) : null}
</StaticArticlePage>
