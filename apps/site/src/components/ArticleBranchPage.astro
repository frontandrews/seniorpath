---
import type { CollectionEntry } from 'astro:content'
import type { LearningPathBranch, LearningPathPillar } from '@/lib/learning-paths'

import BaseLayout from '@/layouts/BaseLayout.astro'
import FilterableDirectory from '@/components/FilterableDirectory.svelte'
import CompactSection from '@/components/ui/CompactSection.astro'
import { getArticleBranchHref, getArticleHrefFromEntry, getArticlePillarHref, getArticlesIndexHref } from '@/lib/article-links'
import { formatEditorialDate } from '@/lib/format-date'
import { getBranchBreadcrumb, getLocalizedBranchLabel, getLocalizedPillarLabel } from '@/lib/article-taxonomy'
import { resolveLocaleHrefMap } from '@/lib/locale-config'
import { getSiteCopy, getSiteDateLocale, type SiteLocale } from '@/lib/site-copy'
import { siteStorageKeys } from '@/lib/storage-keys'
import PageHeader from '@/components/ui/PageHeader.astro'

type Props = {
  branch: LearningPathBranch
  locale: SiteLocale
  pillar: LearningPathPillar
  posts: CollectionEntry<'articles'>[]
}

const BRANCH_PAGE_DESCRIPTION: Record<string, (title: string, pillarLabel: string) => string> = {
  en: (title, pillarLabel) => `Articles about ${title} inside ${pillarLabel}.`,
  'pt-br': (title, pillarLabel) => `Artigos de ${title} dentro de ${pillarLabel}.`,
}

const { branch, locale, pillar, posts } = Astro.props
const copy = getSiteCopy(locale)
const title = getLocalizedBranchLabel(branch, locale)
const pillarLabel = getLocalizedPillarLabel(pillar, locale)
const localeHrefs = resolveLocaleHrefMap((supportedLocale) =>
  getArticleBranchHref(pillar.id, branch.id, supportedLocale)
  ?? getArticlePillarHref(pillar.id, supportedLocale)
  ?? getArticlesIndexHref(supportedLocale),
)
const description =
  posts[0]?.data.description ??
  (BRANCH_PAGE_DESCRIPTION[locale] ?? BRANCH_PAGE_DESCRIPTION.en)(title, pillarLabel)
const breadcrumbItems = getBranchBreadcrumb(pillar, branch, locale)
const dateLocale = getSiteDateLocale(locale)
const items = posts.map((post) => ({
  badgeLabel: post.data.kind === 'note' ? copy.directory.noteBadge : undefined,
  completedCtaLabel: copy.directory.readAgain,
  completionId: post.data.articleId,
  contentKind: post.data.kind,
  ctaLabel: copy.directory.readMore,
  description: post.data.description,
  eyebrow: formatEditorialDate(post.data.pubDate, dateLocale),
  href: getArticleHrefFromEntry(post),
  tags: [],
  title: post.data.title,
}))
---

<BaseLayout
  description={description}
  localeHrefs={localeHrefs}
  title={title}
>
  <PageHeader breadcrumbs={breadcrumbItems} description={description} title={title} />

  <CompactSection>
    <FilterableDirectory
      allItemsLabel={copy.directory.allItems}
      articleItemsLabel={copy.directory.articleItems}
      completionStorageKey={siteStorageKeys.completedArticles}
      fewerFiltersLabel={copy.directory.showLess}
      items={items}
      layout="rows"
      moreFiltersLabel={copy.directory.more}
      noJsMessage={copy.directory.filtersRequireJavaScript}
      noteItemsLabel={copy.directory.noteItems}
      client:idle
    />
  </CompactSection>
</BaseLayout>
