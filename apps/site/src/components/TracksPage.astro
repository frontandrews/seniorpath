---
import RouteIcon from '@lucide/astro/icons/route'

import BaseLayout from '@/layouts/BaseLayout.astro'
import type { ResolvedEditorialRoadmap } from '@/lib/editorial-roadmaps'
import type { SiteLocale } from '@/lib/site-copy'
import { getTracksHref } from '@/lib/tracks-links'
import FilterableDirectory from '@/components/FilterableDirectory.svelte'
import CompactSection from '@/components/ui/CompactSection.astro'
import PageHeader from '@/components/ui/PageHeader.astro'

type Props = {
  locale: SiteLocale
  roadmaps: ResolvedEditorialRoadmap[]
}

const { locale, roadmaps } = Astro.props
const englishHref = getTracksHref('en')
const portugueseHref = getTracksHref('pt-br')
const copy =
  locale === 'pt-br'
    ? {
        filterLabel: 'Filtrar por tag',
        intro: 'Trilhas editoriais para seguir uma sequencia de artigos e conceitos com um tema claro.',
        title: 'Trilhas',
      }
    : {
        filterLabel: 'Filter by tag',
        intro: 'Editorial tracks to follow a sequence of articles and concepts around a clear theme.',
        title: 'Tracks',
      }
const items = roadmaps.map((roadmap) => ({
  href: roadmap.href,
  tags: roadmap.tags,
  title: roadmap.title,
}))
---

<BaseLayout
  description={copy.intro}
  englishHref={englishHref}
  portugueseHref={portugueseHref}
  title={copy.title}
>
  <PageHeader description={copy.intro} icon={RouteIcon} iconLabel={copy.title} title={copy.title} />

  <CompactSection>
    <FilterableDirectory
      filterLabel={copy.filterLabel}
      fewerFiltersLabel={locale === 'pt-br' ? 'Mostrar menos' : 'Show less'}
      items={items}
      client:load
      kind="title-cards"
      moreFiltersLabel={locale === 'pt-br' ? 'mais' : 'more'}
    />
  </CompactSection>
</BaseLayout>
