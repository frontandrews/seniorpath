---
import BrandIcon from '@/brand/BrandIcon.astro'
import { cn } from '@/lib/cn'
import { type getSiteCopy } from '@/lib/site-copy'
import { ui } from '@/lib/ui'

type SiteCopy = ReturnType<typeof getSiteCopy>

type ExploreLink = {
  href: string
  label: string
  pageType: string
}

type Props = {
  copy: SiteCopy
  currentYear: number
  exploreLinks?: ExploreLink[]
  homeHref: string
  privacyHref: string
  rssHref?: string | null
  termsHref: string
}

const {
  copy,
  currentYear,
  exploreLinks = [],
  homeHref,
  privacyHref,
  rssHref,
  termsHref,
} = Astro.props

const brandLinkClass =
  'inline-flex min-h-8 items-center gap-2.5 text-site-ink nav:min-h-10 nav:gap-3 lg:min-h-11 lg:gap-3.5'
const brandIconWrapClass = 'inline-flex size-7 shrink-0 items-center justify-center nav:size-8 lg:size-[2.1rem]'
const brandIconClass = 'size-[1.1rem] nav:size-[1.2rem] lg:size-[1.35rem]'
const brandLabelClass =
  'block font-sans text-[1.05rem] font-semibold leading-[1] tracking-[-0.02em] nav:text-[clamp(1.18rem,2.2vw,1.48rem)] lg:text-[clamp(1.28rem,1.7vw,1.72rem)]'
---

<footer class="border-t-2 border-site-line-strong bg-site-surface">
  <div class={cn(ui.frame, 'grid gap-6 py-10')}>
    <div class="grid gap-8 md:grid-cols-[minmax(0,1.5fr)_minmax(12rem,1fr)_minmax(12rem,1fr)]">
      <div class="grid content-start gap-3">
        <a class={brandLinkClass} href={homeHref}>
          <span class={brandIconWrapClass}>
            <BrandIcon className={brandIconClass} />
          </span>
          <span class={brandLabelClass}>{copy.header.brand}</span>
        </a>
        <p class="m-0 max-w-120 leading-7 text-site-ink-soft">{copy.footer.description}</p>
      </div>
      <div class="grid content-start gap-3">
        <div class="grid gap-[0.85rem]">
          {exploreLinks.map((link) => (
            <a class={ui.footerLink} href={link.href}>{link.label}</a>
          ))}
        </div>
      </div>
      <div class="grid content-start gap-3">
        <div class="grid gap-[0.85rem]">
          <a class={ui.footerLink} href={termsHref}>{copy.footer.terms}</a>
          {exploreLinks.some((link) => link.pageType === 'articles') && rssHref ? <a class={ui.footerLink} href={rssHref}>{copy.footer.rss}</a> : null}
          <a class={ui.footerLink} href={privacyHref}>{copy.footer.privacy}</a>
        </div>
      </div>
    </div>
  </div>
  <div class="border-t-2 border-site-line-strong bg-site-surface text-center">
    <div class={cn(ui.frame, 'py-4')}>
      <p class="m-0 text-sm leading-[1.3] text-site-ink lg:text-[0.96rem]">© {currentYear} {copy.footer.title}. {copy.footer.rights}</p>
    </div>
  </div>
</footer>
