---
import NewspaperIcon from '@lucide/astro/icons/newspaper'
import BrandIcon from '@/brand/BrandIcon.astro'
import DesktopExploreMenu from '@/components/DesktopExploreMenu.astro'
import DesktopLocaleMenu from '@/components/DesktopLocaleMenu.astro'
import MobileNavMenu from '@/components/MobileNavMenu.astro'
import SearchLauncher from '@/components/SearchLauncher.svelte'
import { cn } from '@/lib/cn'
import type { LayoutLocaleLink } from '@/lib/layout-head'
import { type getSiteCopy } from '@/lib/site-copy'
import { ui } from '@/lib/ui'

type SiteCopy = ReturnType<typeof getSiteCopy>

type ExploreLink = {
  href: string
  icon: typeof NewspaperIcon
  isActive: boolean
  label: string
  pageType: string
}

type SearchableSection = {
  href: string
  id: string
  label: string
}

type Props = {
  copy: SiteCopy
  currentLocaleCode: string
  emptyState: string
  exploreLinks?: ExploreLink[]
  hasLocaleSwitcher?: boolean
  hasSearch?: boolean
  homeHref: string
  isDev?: boolean
  localeSwitchLinks?: LayoutLocaleLink[]
  searchableSections?: SearchableSection[]
}

const {
  copy,
  currentLocaleCode,
  emptyState,
  exploreLinks = [],
  hasLocaleSwitcher = false,
  hasSearch = false,
  homeHref,
  isDev = false,
  localeSwitchLinks = [],
  searchableSections = [],
} = Astro.props

const desktopPrimaryLinks = ['articles', 'tracks', 'challenges'].flatMap((pageType) => {
  const link = exploreLinks.find((entry) => entry.pageType === pageType)
  return link ? [link] : []
})
const desktopExploreLinks = exploreLinks.filter(
  (link) => !desktopPrimaryLinks.some((entry) => entry.pageType === link.pageType),
)
const hasDesktopExploreLinks = desktopExploreLinks.length > 0
const brandLinkClass =
  'inline-flex min-h-8 items-center gap-2.5 text-site-ink nav:min-h-10 nav:gap-3 lg:min-h-11 lg:gap-3.5'
const brandIconWrapClass = 'inline-flex size-7 shrink-0 items-center justify-center nav:size-8 lg:size-[2.1rem]'
const brandIconClass = 'size-[1.1rem] nav:size-[1.2rem] lg:size-[1.35rem]'
const brandLabelClass =
  'block font-sans text-[1.05rem] font-semibold leading-[1] tracking-[-0.02em] nav:text-[clamp(1.18rem,2.2vw,1.48rem)] lg:text-[clamp(1.28rem,1.7vw,1.72rem)]'
const mobileNavLinkClass = ui.navMenuLink
const mobileNavActiveClass = 'bg-site-hover text-site-link-hover'
const localeSwitchClass =
  'inline-flex items-center rounded-full border border-site-line bg-site-panel p-1'
const localeOptionActiveClass = 'bg-site-hover text-site-link-hover'
const mobileLocaleOptionClass =
  'inline-flex min-h-9 min-w-12 items-center justify-center rounded-full px-3 py-1.5 text-[0.76rem] font-semibold tracking-[0.08em] text-site-ink transition-colors duration-150 hover:text-site-link-hover focus-visible:text-site-link-hover focus-visible:outline-none'
const desktopDropdownTriggerClass = ui.dropdownTrigger
const desktopDropdownMenuClass =
  cn(ui.dropdownMenu, 'min-w-52 lg:min-w-56')
const desktopExploreLinkClass = ui.navMenuRowLink
const desktopPrimaryLinkClass = ui.navPillLink
const desktopPrimaryActiveClass = 'text-site-link-hover'
const desktopLocaleTriggerClass =
  cn(ui.controlButton, 'min-h-9 cursor-pointer list-none gap-1 px-2.5 py-2 text-[0.78rem] font-semibold tracking-[0.08em] text-site-ink lg:min-h-10 lg:gap-1.5 lg:px-3 lg:text-[0.86rem] focus-visible:outline-none [&::-webkit-details-marker]:hidden')
const desktopTriggerClass =
  cn(ui.controlButton, 'hidden nav:inline-flex nav:h-9 nav:w-54 nav:justify-between nav:gap-3 px-3 py-0 text-left text-[0.9rem] text-site-ink-muted lg:h-10 lg:w-60 lg:gap-3.5 lg:text-[0.98rem]')
const mobileTriggerClass =
  cn(ui.controlButton, 'min-h-10 px-3 py-2 nav:hidden lg:min-h-11')
const mobileNavPanelClass = cn(
  ui.panel,
  'site-dropdown-shadow grid gap-3 overflow-hidden rounded-[1.35rem] p-3',
)
const searchFallbackHref = searchableSections[0]?.href ?? homeHref
const headerBackdropClass =
  'pointer-events-none absolute inset-x-0 top-0 h-[calc(100%+0.5rem)] bg-[linear-gradient(180deg,color-mix(in_srgb,var(--site-bg)_90%,transparent)_0%,color-mix(in_srgb,var(--site-bg)_66%,transparent)_58%,transparent_100%)] backdrop-blur-xl [mask-image:linear-gradient(to_bottom,black_0%,black_78%,transparent_100%)] [-webkit-mask-image:linear-gradient(to_bottom,black_0%,black_78%,transparent_100%)]'
---

<header class="sticky top-0 z-30 mb-5 bg-transparent">
  <div class={cn(ui.frame, 'relative pb-1.5 pt-3 nav:pb-2.5 nav:pt-3')}>
    <div class={headerBackdropClass}></div>
    <div class="relative z-10 flex items-center justify-between gap-3 rounded-[1.4rem] border border-site-line/80 bg-[color-mix(in_srgb,var(--site-panel)_84%,transparent)] px-4 py-2.5 shadow-(--site-shadow-header) backdrop-blur-xl nav:gap-4 nav:px-5 nav:py-3 lg:px-6 lg:py-3.5">
      <a class={brandLinkClass} href={homeHref}>
        <span class={brandIconWrapClass}>
          <BrandIcon className={brandIconClass} />
        </span>
        <span class={brandLabelClass}>{copy.header.brand}</span>
      </a>
      <div class="flex items-center gap-2">
        {desktopPrimaryLinks.length > 0 ? (
          <nav aria-label={copy.header.primaryNav} class="hidden lg:flex lg:items-center lg:gap-1">
            {desktopPrimaryLinks.map((link) => (
              <a
                class={cn(desktopPrimaryLinkClass, link.isActive && desktopPrimaryActiveClass)}
                href={link.href}
              >
                {link.label}
              </a>
            ))}
          </nav>
        ) : null}
        <div class="hidden nav:flex nav:items-center nav:gap-2">
          {hasDesktopExploreLinks ? (
            <DesktopExploreMenu
              activeClass={mobileNavActiveClass}
              itemClass={desktopExploreLinkClass}
              links={desktopExploreLinks}
              menuClass={desktopDropdownMenuClass}
              triggerClass={desktopDropdownTriggerClass}
              triggerLabel={copy.header.explore}
            />
          ) : null}
        </div>
        {hasSearch ? (
          <SearchLauncher
            client:visible
            copy={copy.searchLauncher}
            desktopTriggerClass={desktopTriggerClass}
            dialogClass={ui.searchDialog}
            dialogHintClass={ui.dialogHint}
            emptyState={emptyState}
            fallbackGroupLabel={copy.directory.page}
            isDev={isDev}
            mobileTriggerClass={mobileTriggerClass}
            noJsHref={searchFallbackHref}
            noJsLabel={copy.searchLauncher.noJsFallback}
            searchableSections={searchableSections}
            searchResultLinkClass={ui.searchResultLink}
          />
        ) : null}
        <div class={cn('hidden nav:flex nav:items-center nav:gap-2', !hasLocaleSwitcher && 'nav:hidden')}>
          <DesktopLocaleMenu
            activeClass={mobileNavActiveClass}
            currentLocaleCode={currentLocaleCode}
            itemClass={mobileNavLinkClass}
            localeLinks={localeSwitchLinks}
            menuClass={cn(ui.dropdownMenu, 'min-w-40')}
            triggerClass={desktopLocaleTriggerClass}
            triggerLabel={copy.header.languageSwitcher}
          />
        </div>
        <MobileNavMenu
          closeLabel={copy.header.closeMenu}
          localeLinks={localeSwitchLinks}
          localeOptionActiveClass={localeOptionActiveClass}
          localeSwitchClass={localeSwitchClass}
          localeSwitcherLabel={copy.header.languageSwitcher}
          menuLabel={copy.header.menu}
          mobileLocaleOptionClass={mobileLocaleOptionClass}
          mobileNavActiveClass={mobileNavActiveClass}
          mobileNavLinkClass={mobileNavLinkClass}
          navLinks={exploreLinks}
          panelClass={mobileNavPanelClass}
          primaryNavLabel={copy.header.primaryNav}
          showLocaleSwitcher={hasLocaleSwitcher}
        />
      </div>
    </div>
  </div>
</header>
