---
import type { CollectionEntry } from 'astro:content'
import { render } from 'astro:content'
import ArrowLeft from '@lucide/astro/icons/arrow-left'
import ArrowRight from '@lucide/astro/icons/arrow-right'
import ChevronLeft from '@lucide/astro/icons/chevron-left'
import ChevronRight from '@lucide/astro/icons/chevron-right'
import ArticleComments from '@/components/ArticleComments.svelte'
import ArticleCompletionPanel from '@/components/ArticleCompletionPanel.astro'
import ArticleCompletionRail from '@/components/ArticleCompletionRail.astro'
import ArticleStickyMeta from '@/components/ArticleStickyMeta.astro'
import ArticleSharePanel from '@/components/ArticleSharePanel.astro'
import FilterableDirectory from '@/components/FilterableDirectory.svelte'
import ArticleSection from '@/components/ui/ArticleSection.astro'
import AuthorByline from '@/components/ui/AuthorByline.astro'
import HeaderTagMeta from '@/components/ui/HeaderTagMeta.astro'
import ReferenceExploreSection from '@/components/ui/ReferenceExploreSection.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getArticleCategoryLabel, getArticleLevelLabel, getArticleReadingTimeMinutes, toHashtagLabel } from '@/lib/article-meta'
import { resolveArticleRecommendations, type ArticleRecommendationCandidate } from '@/lib/article-recommendations'
import { articleReadingDomHooks, getDataHookAttributes } from '@/lib/dom-hooks'
import { getArticleEditorialContext } from '@/lib/roadmaps'
import { formatEditorialDate } from '@/lib/format-date'
import { getGiscusConfig } from '@/lib/giscus'
import { getArticleHrefFromEntry, getArticlesIndexHref } from '@/lib/article-links'
import { getLocalePath, resolveLocalizedEntryHrefMap, resolveLocaleMap } from '@/lib/locale-config'
import { createArticleSchema, createBreadcrumbSchema } from '@/lib/seo'
import { resolveEntityOgImageUrl } from '@/lib/og-image'
import { translateSiteLabels } from '@/lib/site-labels'
import { getActiveArticlesByLocale, getArticleCollection } from '@/lib/site-content'
import { sortArticles } from '@/lib/article-tree'
import { getLocalizedArticleTopics } from '@/lib/topic-taxonomy'
import { getSiteCopy, getSiteDateLocale, getSiteLocale } from '@/lib/site-copy'
import { ui } from '@/lib/ui'
import ContentArticleHeader from '@/components/ui/ContentArticleHeader.astro'
import { cn } from '@/lib/cn'

type Props = {
  post: CollectionEntry<'articles'>
}

const { post } = Astro.props
const { Content, headings = [] } = await render(post)
const allArticleEntries = await getArticleCollection()
const localizedPosts = allArticleEntries.filter(
  (entry) => entry.data.articleId === post.data.articleId && entry.data.status === 'active',
)
const alternateLocaleHrefs = resolveLocaleMap((supportedLocale) => {
  const localizedEntry = localizedPosts.find((entry) => entry.data.locale === supportedLocale)
  return localizedEntry ? getArticleHrefFromEntry(localizedEntry) : null
})
const activePosts = sortArticles(await getActiveArticlesByLocale(post.data.locale))
const localeHrefs = resolveLocalizedEntryHrefMap(
  localizedPosts,
  (entry) => getArticleHrefFromEntry(entry),
  (supportedLocale) => getArticlesIndexHref(supportedLocale),
)
const editorialContext = post.data.kind === 'note' ? null : getArticleEditorialContext(post, allArticleEntries)
const currentPostIndex = activePosts.findIndex((entry) => entry.id === post.id)
const previousPost = currentPostIndex > 0 ? activePosts[currentPostIndex - 1] : null
const nextPost = currentPostIndex >= 0 && currentPostIndex < activePosts.length - 1 ? activePosts[currentPostIndex + 1] : null
const copy = getSiteCopy(post.data.locale)
const translatedTags = translateSiteLabels(post.data.tags, post.data.locale)
const linkedTopics = getLocalizedArticleTopics(post)
const locale = getSiteLocale(post.data.locale)
const dateLocale = getSiteDateLocale(post.data.locale)
const giscusConfig = getGiscusConfig(post.data.locale)
const formattedPubDate = formatEditorialDate(post.data.pubDate, dateLocale, { year: 'numeric' })
const formattedUpdatedDate = post.data.updatedDate
  ? formatEditorialDate(post.data.updatedDate, dateLocale)
  : null
const displayHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3)
const readingTimeMinutes = getArticleReadingTimeMinutes(post)
const levelLabel = getArticleLevelLabel(post.data.level, post.data.locale)
const categoryLabel = getArticleCategoryLabel(post)
const articleEntriesById = new Map(activePosts.map((entry) => [entry.data.articleId, entry]))
const postIndexByArticleId = new Map(activePosts.map((entry, index) => [entry.data.articleId, index]))
const topicIds = new Set(post.data.topicIds)
const topicRelatedPosts = activePosts
  .filter((entry) => entry.data.articleId !== post.data.articleId)
  .map((entry) => ({
    entry,
    score: entry.data.topicIds.filter((topicId) => topicIds.has(topicId)).length,
  }))
  .filter((entry) => entry.score > 0)
  .sort((a, b) => {
    if (b.score !== a.score) return b.score - a.score
    return (postIndexByArticleId.get(a.entry.data.articleId) ?? 0) - (postIndexByArticleId.get(b.entry.data.articleId) ?? 0)
  })
  .map(({ entry }) => entry)
const recommendationCandidates: ArticleRecommendationCandidate[] = []
const roadmapArticleNodes = editorialContext?.roadmap.articleNodes ?? []
const currentRoadmapIndex = roadmapArticleNodes.findIndex((node) => node.articleId === post.data.articleId)

if (currentRoadmapIndex >= 0) {
  roadmapArticleNodes.slice(currentRoadmapIndex + 1).forEach((node, index) => {
    recommendationCandidates.push({
      articleId: node.articleId,
      href: node.href,
      title: node.post.data.title,
      trackOrder: index + 1,
    })
  })
}

post.data.relationships.forEach((articleId, index) => {
  const relatedEntry = articleEntriesById.get(articleId)

  if (!relatedEntry) {
    return
  }

  recommendationCandidates.push({
    articleId: relatedEntry.data.articleId,
    href: getArticleHrefFromEntry(relatedEntry),
    relationshipOrder: index + 1,
    title: relatedEntry.data.title,
  })
})

topicRelatedPosts.forEach((entry) => {
  const topicOverlap = entry.data.topicIds.filter((topicId) => topicIds.has(topicId)).length

  recommendationCandidates.push({
    articleId: entry.data.articleId,
    href: getArticleHrefFromEntry(entry),
    title: entry.data.title,
    topicOverlap,
  })
})

const { nextStep, relatedItems } = resolveArticleRecommendations(recommendationCandidates, new Set<string>())
const completionTrack = editorialContext
  ? {
      href: editorialContext.roadmap.href,
      stepIndex: editorialContext.stepIndex,
      title: editorialContext.roadmap.title,
      totalSteps: editorialContext.totalSteps,
    }
  : null
const displayTags = [
  ...new Set(
    [...new Set([...linkedTopics.map((topic) => topic.label), ...translatedTags])]
      .map((label) => toHashtagLabel(label, post.data.locale))
      .filter((label): label is string => Boolean(label)),
  ),
]
const articleUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString()
const socialImage = resolveEntityOgImageUrl(
  Astro.site ?? Astro.url,
  'articles',
  locale,
  post.data.articleId,
)
const hasTakeaways = post.data.takeaways.length > 0
const hasPracticeChecklist = post.data.practiceChecklist.length > 0
const postReadSectionClass = 'xl:max-w-[45rem]'
const exploreArticleLinks = [
  {
    href: getArticlesIndexHref(locale),
    label: copy.layout.articles,
  },
  ...linkedTopics.map((topic) => ({
    href: topic.href,
    label: topic.label,
  })),
].filter((item, index, items) => items.findIndex((candidate) => candidate.label === item.label) === index)
const bottomRelatedArticles = relatedItems.map((item) => ({
  href: item.href,
  tags: [],
  title: item.title,
}))
const articleStructuredData = [
  createArticleSchema({
    dateModified: post.data.updatedDate?.toISOString() ?? null,
    datePublished: post.data.pubDate.toISOString(),
    description: post.data.description,
    keywords: [...translatedTags, ...linkedTopics.map((topic) => topic.label)],
    locale,
    title: post.data.title,
    url: articleUrl,
  }),
  createBreadcrumbSchema({
    items: [
      {
        name: copy.layout.home,
        url: new URL(getLocalePath(locale), Astro.site ?? Astro.url).toString(),
      },
      {
        name: copy.layout.articles,
        url: new URL(getArticlesIndexHref(locale), Astro.site ?? Astro.url).toString(),
      },
      {
        name: post.data.title,
        url: articleUrl,
      },
    ],
  }),
]
---

<BaseLayout
  alternateLocaleHrefs={alternateLocaleHrefs}
  contentWidth="wide"
  description={post.data.description}
  localeHrefs={localeHrefs}
  socialImage={socialImage}
  structuredData={articleStructuredData}
  title={post.data.title}
>
  <article class="w-full pb-11">
    <ContentArticleHeader
      className="article-header-wide-shell"
      createdMeta={formattedPubDate}
      createdMetaClassName={ui.articleHeaderTagTone}
      description={post.data.description}
      title={post.data.title}
    >
      <AuthorByline />
      {formattedUpdatedDate || (readingTimeMinutes && levelLabel && categoryLabel) ? (
        <p class={`mt-3 ${ui.articleHeaderTagTone}`}>
          {formattedUpdatedDate ? (
            <>
              {copy.article.updatedPrefix} {formattedUpdatedDate}
            </>
          ) : null}
          {formattedUpdatedDate && readingTimeMinutes && levelLabel && categoryLabel ? (
            <span aria-hidden="true" class="px-2">•</span>
          ) : null}
          {readingTimeMinutes && levelLabel && categoryLabel ? (
            <>
              {readingTimeMinutes} min
              <span aria-hidden="true" class="px-2">•</span>
              {levelLabel}
              <span aria-hidden="true" class="px-2">•</span>
              {categoryLabel}
            </>
          ) : null}
        </p>
      ) : null}
      <HeaderTagMeta items={displayTags.map((tag) => ({ label: tag }))} />

      {editorialContext ? (
        <div class="mt-5 grid gap-4 border-t border-article-rule pt-4">
          <div class="grid gap-1">
            <p class={ui.eyebrow}>{copy.startHere.roadmapEyebrow}</p>
            <h2 class={ui.headingCompact}>{editorialContext.roadmap.title}</h2>
            <p class={ui.bodyCopy}>
              {copy.startHere.stepLabel} {editorialContext.stepIndex} / {editorialContext.totalSteps}
            </p>
          </div>
          <div class="flex flex-wrap gap-3">
            <a class={ui.actionLink} href={editorialContext.roadmap.href}>
              {copy.startHere.backToRoadmap}
            </a>
            {editorialContext.previousArticle ? (
              <a class={ui.actionLink} href={editorialContext.previousArticle.href}>
                {copy.startHere.previousArticle}
              </a>
            ) : null}
            {editorialContext.nextArticle ? (
              <a class={ui.actionLink} href={editorialContext.nextArticle.href}>
                {copy.startHere.nextArticle}
              </a>
            ) : null}
          </div>
        </div>
      ) : null}
    </ContentArticleHeader>

    <ArticleStickyMeta
      className="article-reading-shell mx-auto my-5 w-full xl:hidden"
      completionId={post.data.articleId}
      headings={displayHeadings}
      locale={locale}
      nextStep={nextStep}
      recommendationCandidates={recommendationCandidates}
      relatedItems={relatedItems}
      showCompletionInPlace={false}
      track={completionTrack}
    />

    <div class={ui.articleRailLayout}>
      <div class={ui.articleRailLayoutMain}>
        <div class="article-prose" {...getDataHookAttributes(articleReadingDomHooks.content)}>
          <Content />
        </div>

        {hasTakeaways || hasPracticeChecklist ? (
          <section class={cn(ui.articleSection, 'grid gap-4')}>
            {hasTakeaways ? (
              <section class={cn(ui.panel, 'grid gap-4 p-5 lg:p-6')}>
                <div class="grid gap-2">
                  <p class={ui.eyebrow}>{copy.article.quickSummary}</p>
                  <h2 class={ui.headingCompact}>{copy.article.quickSummaryTitle}</h2>
                </div>
                <ul class="grid list-disc gap-3 pl-6 text-[0.98rem] leading-[1.8] text-site-ink-soft marker:text-site-link-hover lg:text-[1.02rem]">
                  {post.data.takeaways.map((item) => (
                    <li class="pl-1">{item}</li>
                  ))}
                </ul>
              </section>
            ) : null}

            {hasPracticeChecklist ? (
              <section class={cn(ui.panel, 'grid gap-4 p-5 lg:p-6')}>
                <div class="grid gap-2">
                  <p class={ui.eyebrow}>{copy.article.practiceChecklist}</p>
                  <h2 class={ui.headingCompact}>{copy.article.practiceChecklistTitle}</h2>
                </div>
                <ul class="grid list-disc gap-3 pl-6 text-[0.98rem] leading-[1.8] text-site-ink-soft marker:text-site-link-hover lg:text-[1.02rem]">
                  {post.data.practiceChecklist.map((item) => (
                    <li class="pl-1">{item}</li>
                  ))}
                </ul>
              </section>
            ) : null}
          </section>
        ) : null}

        <div aria-hidden="true" class="h-px" {...getDataHookAttributes(articleReadingDomHooks.end)}></div>
      </div>

      <div class={ui.articleRailLayoutGuide}>
        <ArticleStickyMeta
          completionId={post.data.articleId}
          headings={displayHeadings}
          locale={locale}
          nextStep={nextStep}
          recommendationCandidates={recommendationCandidates}
          relatedItems={relatedItems}
          showCompletionInPlace={false}
          track={completionTrack}
        />

        <ArticleCompletionRail
          className={ui.articleRailLayoutCompletion}
          completionId={post.data.articleId}
          locale={locale}
          nextStep={nextStep}
          recommendationCandidates={recommendationCandidates}
          relatedItems={relatedItems}
          track={completionTrack}
        />
      </div>
    </div>

    <ArticleCompletionPanel
      className="mt-6"
      completionId={post.data.articleId}
      locale={locale}
      nextStep={nextStep}
      recommendationCandidates={recommendationCandidates}
      relatedItems={relatedItems}
      track={completionTrack}
    />

    {previousPost || nextPost ? (
      <section class="article-detail-shell mx-auto mt-8 grid w-full gap-4 border-t border-article-rule pt-8 md:grid-cols-2 md:items-stretch">
        {nextPost ? (
          <a
            class={cn(ui.navCardLink, 'justify-between md:order-3')}
            href={getArticleHrefFromEntry(nextPost)}
          >
            <span class="grid gap-1 content-start text-left md:ml-auto md:justify-items-end md:text-right">
              <span class={cn(ui.eyebrowSentence, 'inline-flex items-center gap-1.5 leading-none md:justify-self-end')}>
                <span class="leading-none">{copy.startHere.nextArticle}</span>
                <ArrowRight aria-hidden="true" class="size-3.5 shrink-0 md:hidden" />
              </span>
              <span class={ui.linkCardTitle}>{nextPost.data.title}</span>
            </span>
            <ChevronRight aria-hidden="true" class="hidden size-6 shrink-0 text-article-body md:block" />
          </a>
        ) : <div class="md:order-3" />}
        {previousPost ? (
          <a
            class={cn(ui.navCardLink, 'text-left md:order-1')}
            href={getArticleHrefFromEntry(previousPost)}
          >
            <ChevronLeft aria-hidden="true" class="hidden size-6 shrink-0 text-article-body md:block" />
            <span class="grid gap-1 content-start">
              <span class={cn(ui.eyebrowSentence, 'inline-flex items-center gap-1.5 leading-none')}>
                <ArrowLeft aria-hidden="true" class="size-3.5 shrink-0 md:hidden" />
                <span class="leading-none">{copy.startHere.previousArticle}</span>
              </span>
              <span class={ui.linkCardTitle}>{previousPost.data.title}</span>
            </span>
          </a>
        ) : <div class="md:order-1" />}
      </section>
    ) : null}

    <ArticleSharePanel
      description={post.data.description}
      locale={locale}
      title={post.data.title}
      useDetailShell={true}
      url={articleUrl}
    />

    <ReferenceExploreSection
      badgeLinks={exploreArticleLinks}
      title={copy.startHere.supportHeading}
    />

    {bottomRelatedArticles.length > 0 ? (
      <ArticleSection
        bodyClass="mt-4"
        sectionClass={ui.articleUtilitySection}
        title={copy.directory.relatedArticles}
      >
        <FilterableDirectory items={bottomRelatedArticles} layout="cards" />
      </ArticleSection>
    ) : null}

    {giscusConfig ? (
      <ArticleComments
        className={postReadSectionClass}
        config={giscusConfig}
        openLabel={copy.article.openComments}
        title={copy.article.comments}
        client:idle
      />
    ) : null}
  </article>
</BaseLayout>
