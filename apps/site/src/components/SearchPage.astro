---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getSearchHref } from '@/lib/search-links'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'
import CompactSection from '@/components/ui/CompactSection.astro'
import InfoPanel from '@/components/ui/InfoPanel.astro'
import PageHeader from '@/components/ui/PageHeader.astro'

type Props = {
  locale: SiteLocale
}

const { locale } = Astro.props
const copy = getSiteCopy(locale)
const isDev = import.meta.env.DEV
const englishHref = getSearchHref('en')
const portugueseHref = getSearchHref('pt-br')
const pagefindConfig = {
  autofocus: true,
  element: '#search',
  excerptLength: 18,
  resetStyles: false,
  showImages: false,
  showSubResults: true,
  translations:
    locale === 'pt-br'
      ? {
          placeholder: 'Buscar no SeniorPath',
          zero_results: 'Nenhum resultado para [SEARCH_TERM]',
        }
      : {
          placeholder: 'Search SeniorPath',
          zero_results: 'No results for [SEARCH_TERM]',
        },
}
---

<BaseLayout
  description={copy.search.copy}
  englishHref={englishHref}
  portugueseHref={portugueseHref}
  title={copy.search.title}
>
  {!isDev ? (
    <Fragment slot="head">
      <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
      <script is:inline src="/pagefind/pagefind-ui.js"></script>
    </Fragment>
  ) : null}

  <PageHeader description={copy.search.copy} title={copy.search.title} />

  <CompactSection>
    <div class="mt-4">
      {isDev ? (
        <InfoPanel body={copy.search.devNotice} className="p-4 text-site-ink-soft" />
      ) : (
        <div class="search-pagefind" id="search"></div>
      )}
    </div>
  </CompactSection>
</BaseLayout>

{
  !isDev ? (
    <script define:vars={{ pagefindConfig }} is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        if (typeof window.PagefindUI !== 'function') {
          return
        }

        new window.PagefindUI(pagefindConfig)
      })
    </script>
  ) : null
}
