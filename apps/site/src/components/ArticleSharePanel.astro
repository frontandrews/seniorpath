---
import ClipboardCopyIcon from '@lucide/astro/icons/clipboard-copy'
import MessageCircleIcon from '@lucide/astro/icons/message-circle'
import Share2Icon from '@lucide/astro/icons/share-2'

import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'
import { cn } from '@/lib/cn'
import { ui } from '@/lib/ui'

type Props = {
  description: string
  locale: SiteLocale
  title: string
  url: string
}

const { description, locale, title, url } = Astro.props
const copy = getSiteCopy(locale)
const shareText = `${title}\n\n${description}\n\n${url}`
const whatsappHref = `https://wa.me/?text=${encodeURIComponent(shareText)}`
const twitterHref = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`
const linkedinHref = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`
const labels =
  locale === 'pt-br'
    ? {
        linkedin: 'Compartilhar no LinkedIn',
        twitter: 'Compartilhar no X',
        whatsapp: 'Compartilhar no WhatsApp',
      }
    : {
        linkedin: 'Share on LinkedIn',
        twitter: 'Share on X',
        whatsapp: 'Share on WhatsApp',
      }
const iconButtonClass =
  'inline-flex size-11 items-center justify-center rounded-full border border-site-line bg-site-card text-site-ink transition-colors duration-150 hover:border-site-line-strong hover:bg-site-hover hover:text-site-link-hover focus-visible:border-site-line-strong focus-visible:bg-site-hover focus-visible:text-site-link-hover focus-visible:outline-none min-[64rem]:size-12'
---

<section
  class={cn(ui.articleSection, 'grid gap-3 px-0 py-0')}
  data-article-share
  data-copy-link-error={copy.article.copyLinkError}
  data-copy-link-success={copy.article.copyLinkSuccess}
  data-share-description={description}
  data-share-fallback={copy.article.shareFallback}
  data-share-title={title}
  data-share-url={url}
>
  <div class="flex flex-wrap items-center justify-between gap-3">
    <p class="text-[0.8rem] font-medium uppercase tracking-[0.22em] text-site-ink-soft min-[64rem]:text-[0.88rem]">
      {copy.article.shareTitle}
    </p>

    <div class="flex flex-wrap gap-2">
      <button
        aria-label={copy.article.share}
        class={iconButtonClass}
        data-share-native
        title={copy.article.share}
        type="button"
      >
        <Share2Icon aria-hidden="true" class="size-4" />
        <span class="sr-only">{copy.article.share}</span>
      </button>
      <a
        aria-label={labels.twitter}
        class={iconButtonClass}
        href={twitterHref}
        rel="noreferrer"
        target="_blank"
        title={labels.twitter}
      >
        <span aria-hidden="true" class="text-[0.88rem] font-semibold tracking-[0.02em] min-[64rem]:text-[0.96rem]">X</span>
        <span class="sr-only">{labels.twitter}</span>
      </a>
      <a
        aria-label={labels.linkedin}
        class={iconButtonClass}
        href={linkedinHref}
        rel="noreferrer"
        target="_blank"
        title={labels.linkedin}
      >
        <span aria-hidden="true" class="text-[0.9rem] font-semibold lowercase tracking-[-0.02em] min-[64rem]:text-[0.98rem]">in</span>
        <span class="sr-only">{labels.linkedin}</span>
      </a>
      <a
        aria-label={labels.whatsapp}
        class={iconButtonClass}
        href={whatsappHref}
        rel="noreferrer"
        target="_blank"
        title={labels.whatsapp}
      >
        <MessageCircleIcon aria-hidden="true" class="size-4" />
        <span class="sr-only">{labels.whatsapp}</span>
      </a>
      <button
        aria-label={copy.article.copyLink}
        class={iconButtonClass}
        data-share-copy
        title={copy.article.copyLink}
        type="button"
      >
        <ClipboardCopyIcon aria-hidden="true" class="size-4" />
        <span class="sr-only">{copy.article.copyLink}</span>
      </button>
    </div>
  </div>

  <p
    aria-live="polite"
    class="hidden text-sm leading-6 text-site-ink-soft min-[64rem]:text-[0.96rem]"
    data-share-feedback
  />
</section>

<script>
  const shareRoots = document.querySelectorAll('[data-article-share]')

  for (const root of shareRoots) {
    if (!(root instanceof HTMLElement)) continue

    const nativeButton = root.querySelector('[data-share-native]')
    const copyButton = root.querySelector('[data-share-copy]')
    const feedback = root.querySelector('[data-share-feedback]')

    if (
      !(nativeButton instanceof HTMLButtonElement) ||
      !(copyButton instanceof HTMLButtonElement) ||
      !(feedback instanceof HTMLElement)
    ) {
      continue
    }

    const shareTitle = root.dataset.shareTitle ?? document.title
    const shareDescription = root.dataset.shareDescription ?? ''
    const shareUrl = root.dataset.shareUrl ?? window.location.href
    const shareFallback = root.dataset.shareFallback ?? 'Share is unavailable.'
    const copyLinkSuccess = root.dataset.copyLinkSuccess ?? 'Link copied.'
    const copyLinkError = root.dataset.copyLinkError ?? 'Unable to copy the link.'

    const setFeedback = (message: string) => {
      feedback.textContent = message
      feedback.classList.remove('hidden')
    }

    const copyLink = async () => {
      if (typeof navigator.clipboard?.writeText !== 'function') {
        setFeedback(copyLinkError)
        return false
      }

      await navigator.clipboard.writeText(shareUrl)
      setFeedback(copyLinkSuccess)
      return true
    }

    nativeButton.addEventListener('click', async () => {
      if (typeof navigator.share !== 'function') {
        setFeedback(shareFallback)
        return
      }

      try {
        await navigator.share({
          text: shareDescription,
          title: shareTitle,
          url: shareUrl,
        })
      } catch (error) {
        if (error instanceof DOMException && error.name === 'AbortError') {
          return
        }

        setFeedback(shareFallback)
      }
    })

    copyButton.addEventListener('click', () => {
      void copyLink()
    })
  }
</script>
