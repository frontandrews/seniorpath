---
import type { CollectionEntry } from 'astro:content'
import { getCollection, render } from 'astro:content'

import FilterableDirectory from '@/components/FilterableDirectory.svelte'
import { getConceptHrefFromEntry, getConceptsHref } from '@/lib/concepts-links'
import {
  getConceptDomainRouteSegment,
  getConceptGroupRouteSegment,
  getLocalizedConceptDomainLabel,
  getLocalizedConceptGroupLabel,
} from '@/lib/concept-taxonomy'
import { formatEditorialDate } from '@/lib/format-date'
import { getGuideHrefFromEntry } from '@/lib/guide-links'
import type { SiteLocale } from '@/lib/site-copy'
import { ui } from '@/lib/ui'
import ArticleSection from '@/components/ui/ArticleSection.astro'
import ReferenceEntryPage from '@/components/ui/ReferenceEntryPage.astro'
import { cn } from '@/lib/cn'

type Props = {
  concept: CollectionEntry<'concepts'>
}

const { concept } = Astro.props
const { Content } = await render(concept)
const allConcepts = await getCollection('concepts')
const allGuides = await getCollection('guides')
const alternateConcept = allConcepts.find(
  (entry) => entry.data.conceptId === concept.data.conceptId && entry.data.locale !== concept.data.locale,
)
const relatedGuides = allGuides.filter(
  (entry) =>
    entry.data.locale === concept.data.locale &&
    entry.data.status !== 'archived' &&
    concept.data.relatedGuideIds.includes(entry.data.guideId),
)
const locale = concept.data.locale === 'pt-br' ? 'pt-br' : 'en'
const siteLocale: SiteLocale = locale
const domainSegment = getConceptDomainRouteSegment(concept.data.domainId, siteLocale)
const groupSegment = getConceptGroupRouteSegment(concept.data.domainId, concept.data.groupId, siteLocale)
const englishHref =
  concept.data.locale === 'en'
    ? getConceptHrefFromEntry(concept)
    : alternateConcept
      ? getConceptHrefFromEntry(alternateConcept)
      : null
const portugueseHref =
  concept.data.locale === 'pt-br'
    ? getConceptHrefFromEntry(concept)
    : alternateConcept
      ? getConceptHrefFromEntry(alternateConcept)
      : null
const dateLocale = locale === 'pt-br' ? 'pt-BR' : 'en-US'
const formattedPubDate = formatEditorialDate(concept.data.pubDate, dateLocale)
const formattedUpdatedDate = concept.data.updatedDate
  ? formatEditorialDate(concept.data.updatedDate, 'en-US', {
      month: 'short',
    })
  : null
const relatedGuideItems = relatedGuides.map((guide) => ({
  href: getGuideHrefFromEntry(guide),
  tags: [],
  title: guide.data.title,
}))
const articleUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString()
const conceptScopeTags = [
  {
    href: getConceptsHref(locale, domainSegment),
    label: getLocalizedConceptDomainLabel(concept.data.domainId, siteLocale),
  },
  {
    href: getConceptsHref(locale, domainSegment, groupSegment),
    label: getLocalizedConceptGroupLabel(concept.data.domainId, concept.data.groupId, siteLocale),
  },
]
---

<ReferenceEntryPage
  createdMeta={formattedPubDate}
  description={concept.data.description}
  englishHref={englishHref}
  locale={locale}
  portugueseHref={portugueseHref}
  title={concept.data.title}
  updatedMeta={formattedUpdatedDate}
  url={articleUrl}
>
  <Content />
  <Fragment slot="afterContent">
    {relatedGuides.length > 0 ? (
      <ArticleSection
        bodyClass="mt-4"
        title={locale === 'pt-br' ? 'Guias relacionados' : 'Related guides'}
      >
          <FilterableDirectory
            items={relatedGuideItems}
            kind="title-cards"
          />
      </ArticleSection>
    ) : null}

    {conceptScopeTags.length > 0 || concept.data.tags.length > 0 ? (
      <div class={ui.articleTagList}>
        {conceptScopeTags.map((tag) => (
          <a class={cn(ui.badge, ui.badgeLink)} href={tag.href}>{tag.label}</a>
        ))}
        {concept.data.tags.map((tag) => (
          <span class={ui.badge}>{tag}</span>
        ))}
      </div>
    ) : null}
  </Fragment>
</ReferenceEntryPage>
