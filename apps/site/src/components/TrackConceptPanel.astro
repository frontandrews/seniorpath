---
import FilterableDirectory from '@/components/FilterableDirectory.svelte'
import { cn } from '@/lib/cn'
import { getDataHookAttributes, trackPageDomHooks } from '@/lib/dom-hooks'
import type { ResolvedRoadmapConceptNode } from '@/lib/roadmaps'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'
import { ui } from '@/lib/ui'

type TrackArticleItem = {
  completionId?: string
  href: string
  tags: Array<{
    id: string
    label: string
  }>
  title: string
}

type Props = {
  articleItems?: TrackArticleItem[]
  className?: string
  locale: SiteLocale
  node: ResolvedRoadmapConceptNode
}

const { articleItems = [], className = '', locale, node } = Astro.props
const copy = getSiteCopy(locale)
---

<section
  class={cn('border-t border-site-line px-[0.45rem] py-[0.8rem] first:border-t-0 lg:px-[0.55rem] lg:py-[0.95rem]', className)}
  {...getDataHookAttributes(trackPageDomHooks.concept, node.id)}
>
  <div class={cn(ui.panel, ui.spotlightPanel)}>
    <div class="grid gap-2">
      <p class={ui.eyebrow}>{copy.startHere.conceptLabel}</p>
      <h2
        class={ui.headingCompact}
        {...getDataHookAttributes(trackPageDomHooks.conceptTitle, node.title)}
      >
        {node.title}
      </h2>
      <p class={ui.cardDescription}>{node.summary}</p>
      <p class={ui.bodyCopy}>{node.panelBody}</p>
    </div>

    {articleItems.length > 0 ? (
      <div class="grid gap-3 border-t border-site-line pt-4">
        <FilterableDirectory items={articleItems} layout="cards" />
      </div>
    ) : null}
  </div>
</section>
