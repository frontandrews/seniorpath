---
import type { CollectionEntry } from 'astro:content'

import ArticleCard from '@/components/ArticleCard.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import PageHeader from '@/components/ui/PageHeader.astro'
import SectionBlock from '@/components/ui/SectionBlock.astro'
import { getLocalizedTopicLabel, getLocalizedTopicSummary, getTopicBreadcrumb } from '@/lib/topic-taxonomy'
import { getTopicHref } from '@/lib/topic-links'
import type { SiteLocale } from '@/lib/site-copy'
import { ui } from '@/lib/ui'

type Props = {
  locale: SiteLocale
  posts: CollectionEntry<'guides'>[]
  topicId: string
}

const { locale, posts, topicId } = Astro.props
const title = getLocalizedTopicLabel(topicId, locale)
const description = getLocalizedTopicSummary(topicId, locale)
const breadcrumbItems = getTopicBreadcrumb(topicId, locale)
const selectionLabel = locale === 'pt-br' ? 'Escolha um guia' : 'Select a guide'
---

<BaseLayout
  description={description}
  englishHref={getTopicHref(topicId, 'en')}
  portugueseHref={getTopicHref(topicId, 'pt-br')}
  title={title}
>
  <PageHeader breadcrumbs={breadcrumbItems} description={description} title={title} />

  <SectionBlock bodyClass={ui.cardsGrid} eyebrow={selectionLabel}>
      {posts.map((post) => (
        <ArticleCard post={post} />
      ))}
  </SectionBlock>
</BaseLayout>
