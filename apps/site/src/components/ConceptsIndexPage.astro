---
import type { CollectionEntry } from 'astro:content'
import BrainIcon from '@lucide/astro/icons/brain'

import DirectoryList from '@/components/ui/DirectoryList.astro'
import DirectoryPagination from '@/components/ui/DirectoryPagination.astro'
import DirectoryIndexShell from '@/components/ui/DirectoryIndexShell.astro'
import RouteFilterNav from '@/components/ui/RouteFilterNav.astro'
import { getConceptCompletionId } from '@/lib/completion-ids'
import {
  getConceptHrefFromEntry,
  getConceptsHref,
  getConceptsPageHref,
  getConceptsTagHref,
  getConceptsTagPageHref,
} from '@/lib/concepts-links'
import { CARD_DIRECTORY_PAGE_SIZE, paginateItems } from '@/lib/directory'
import { getLocalePath, resolveLocaleHrefMap } from '@/lib/locale-config'
import { getRouteFilterEntries, getRouteFilterEntryById } from '@/lib/route-filters'
import { getPageTypeDescription, getPageTypeLabel } from '@/lib/section-manifest'
import type { RecentUpdateItem } from '@/lib/recent-updates'
import {
  CONCEPT_DOMAINS,
  getAvailableConceptGroups,
  getConceptDomainRouteSegment,
  getConceptGroupRouteSegment,
  getLocalizedConceptDomainLabel,
  getLocalizedConceptGroupLabel,
} from '@/lib/concept-taxonomy'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'

type Props = {
  concepts: CollectionEntry<'concepts'>[]
  isHome?: boolean
  locale: SiteLocale
  page?: number
  recentUpdates?: RecentUpdateItem[]
  selectedFilterId?: string | null
}

const {
  concepts,
  isHome = false,
  locale,
  page = 1,
  recentUpdates = [],
  selectedFilterId = null,
} = Astro.props
const copy = getSiteCopy(locale)
const localeHrefs = resolveLocaleHrefMap((supportedLocale) =>
  isHome ? getLocalePath(supportedLocale) : getConceptsHref(supportedLocale),
)
const description = getPageTypeDescription('concepts', locale)
const availableDomains = CONCEPT_DOMAINS.filter((domain) =>
  concepts.some((concept) => concept.data.domainId === domain.id),
)
const availableFilters = availableDomains.flatMap((domain) => {
  const domainSegment = getConceptDomainRouteSegment(domain.id, locale)
  const groupFilters = getAvailableConceptGroups(concepts, domain.id, locale).map((group) => ({
    id: `${domainSegment}/${getConceptGroupRouteSegment(domain.id, group.id, locale)}`,
    label: getLocalizedConceptGroupLabel(domain.id, group.id, locale),
  }))

  return [
    {
      id: domainSegment,
      label: getLocalizedConceptDomainLabel(domain.id, locale),
    },
    ...groupFilters,
  ]
})
const items = concepts.map((concept) => {
  const domainSegment = getConceptDomainRouteSegment(concept.data.domainId, locale)
  const groupSegment = getConceptGroupRouteSegment(concept.data.domainId, concept.data.groupId, locale)

  return {
    completedCtaLabel: copy.directory.readAgain,
    completionId: getConceptCompletionId(concept.data.conceptId),
    href: getConceptHrefFromEntry(concept),
    tags: [
      {
        id: domainSegment,
        label: getLocalizedConceptDomainLabel(concept.data.domainId, locale),
      },
      {
        id: `${domainSegment}/${groupSegment}`,
        label: getLocalizedConceptGroupLabel(concept.data.domainId, concept.data.groupId, locale),
      },
    ],
    title: concept.data.title,
  }
})
const filterEntries = getRouteFilterEntries(availableFilters, locale)
const selectedFilter = selectedFilterId
  ? getRouteFilterEntryById(availableFilters, locale, selectedFilterId)
  : null
const filteredItems = selectedFilter
  ? items.filter((item) => item.tags.some((tag) => tag.id === selectedFilter.id))
  : items
const paginatedItems = paginateItems(filteredItems, page, CARD_DIRECTORY_PAGE_SIZE)
const title = page > 1
  ? `${selectedFilter ? `${getPageTypeLabel('concepts', locale)} · ${selectedFilter.label}` : getPageTypeLabel('concepts', locale)} · ${copy.directory.page} ${paginatedItems.currentPage}`
  : selectedFilter ? `${getPageTypeLabel('concepts', locale)} · ${selectedFilter.label}` : getPageTypeLabel('concepts', locale)
const isPaginatedArchivePage = paginatedItems.currentPage > 1
---

<DirectoryIndexShell
  description={description}
  icon={BrainIcon}
  iconLabel={title}
  localeHrefs={localeHrefs}
  noindex={isPaginatedArchivePage}
  pagefind={!isPaginatedArchivePage}
  recentUpdates={isHome ? recentUpdates : []}
  recentUpdatesLocale={isHome ? locale : undefined}
  title={title}
>
  <RouteFilterNav
    activeFilterId={selectedFilter?.id}
    allHref={getConceptsHref(locale)}
    allLabel={copy.directory.allItems}
    entries={filterEntries}
    filterLabel={copy.directory.filterByConcept}
    getHref={(tagSlug) => getConceptsTagHref(locale, tagSlug)}
  />

  <DirectoryList items={paginatedItems.items} layout="cards" />

  <DirectoryPagination
    currentPage={paginatedItems.currentPage}
    getHref={(targetPage) =>
      selectedFilter
        ? getConceptsTagPageHref(locale, selectedFilter.slug, targetPage)
        : getConceptsPageHref(locale, targetPage)}
    nextLabel={copy.directory.nextPage}
    pageCount={paginatedItems.pageCount}
    pageLabel={copy.directory.page}
    previousLabel={copy.directory.previousPage}
  />
</DirectoryIndexShell>
