---
import type { TopicDefinition } from '@seniorpath/content'

import FilterableDirectory from '@/components/FilterableDirectory.svelte'
import DirectoryIndexShell from '@/components/ui/DirectoryIndexShell.astro'
import { formatEditorialDate } from '@/lib/format-date'
import { getGuideHrefFromEntry } from '@/lib/guide-links'
import { getTopicGroupHref } from '@/lib/topic-links'
import {
  getLocalizedTopicGroupLabel,
  getLocalizedTopicGroupSummary,
  getLocalizedTopicLabel,
  getLocalizedGuideTopicsInGroup,
  getTopicGroupBreadcrumb,
} from '@/lib/topic-taxonomy'
import type { CollectionEntry } from 'astro:content'
import { siteStorageKeys } from '@/lib/storage-keys'
import type { SiteLocale } from '@/lib/site-copy'

type Props = {
  groupId: string
  locale: SiteLocale
  posts: CollectionEntry<'guides'>[]
  topics: TopicDefinition[]
}

const { groupId, locale, posts, topics } = Astro.props
const title = getLocalizedTopicGroupLabel(groupId, locale)
const description = getLocalizedTopicGroupSummary(groupId, locale)
const dateLocale = locale === 'pt-br' ? 'pt-BR' : 'en-US'
const filterItems = topics.map((topic) => ({
  id: topic.routeSegment[locale],
  label: getLocalizedTopicLabel(topic.id, locale),
}))
const items = posts.map((post) => ({
  badgeLabel: post.data.kind === 'article' ? (locale === 'pt-br' ? 'Nota' : 'Journal') : undefined,
  completionId: post.data.kind === 'guide' ? post.data.guideId : undefined,
  contentKind: post.data.kind,
  ctaLabel: locale === 'pt-br' ? 'Ler mais' : 'Learn more',
  description: post.data.description,
  eyebrow: formatEditorialDate(post.data.pubDate, dateLocale),
  href: getGuideHrefFromEntry(post),
  tags: getLocalizedGuideTopicsInGroup(post, groupId, locale).map(({ id, label }) => ({ id, label })),
  title: post.data.title,
}))
---

<DirectoryIndexShell
  breadcrumbs={getTopicGroupBreadcrumb(groupId, locale)}
  description={description}
  englishHref={getTopicGroupHref(groupId, 'en')}
  portugueseHref={getTopicGroupHref(groupId, 'pt-br')}
  title={title}
>
  <FilterableDirectory
    allItemsLabel={locale === 'pt-br' ? 'Tudo' : 'All'}
    articleItemsLabel={locale === 'pt-br' ? 'Artigos' : 'Articles'}
    availableFilters={filterItems}
    completionStorageKey={siteStorageKeys.completedGuides}
    filterLabel={locale === 'pt-br' ? 'Filtrar por subtema' : 'Filter by subtopic'}
    filterQueryKey="sub"
    fewerFiltersLabel={locale === 'pt-br' ? 'Mostrar menos' : 'Show less'}
    guideItemsLabel={locale === 'pt-br' ? 'Guias' : 'Guides'}
    items={items}
    client:load
    kind="guide-rows"
    moreFiltersLabel={locale === 'pt-br' ? 'mais' : 'more'}
  />
</DirectoryIndexShell>
