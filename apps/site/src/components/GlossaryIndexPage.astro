---
import type { CollectionEntry } from 'astro:content'

import BaseLayout from '@/layouts/BaseLayout.astro'
import FilterableDirectory from '@/components/FilterableDirectory.svelte'
import CompactSection from '@/components/ui/CompactSection.astro'
import PageHeader from '@/components/ui/PageHeader.astro'
import { getGlossaryHrefFromEntry, getGlossaryIndexHref } from '@/lib/glossary-links'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'

type Props = {
  locale: SiteLocale
  terms: CollectionEntry<'glossary'>[]
}

const { locale, terms } = Astro.props
const copy = getSiteCopy(locale)
const selectionLabel = locale === 'pt-br' ? 'Escolha um termo' : 'Select a term'
const items = terms.map((term) => ({
  href: getGlossaryHrefFromEntry(term),
  tags: [],
  title: term.data.title,
}))
---

<BaseLayout
  description={copy.glossaryIndex.copy}
  englishHref={getGlossaryIndexHref('en')}
  portugueseHref={getGlossaryIndexHref('pt-br')}
  title={copy.glossaryIndex.title}
>
  <PageHeader description={copy.glossaryIndex.copy} title={copy.glossaryIndex.title} />

  <CompactSection>
    <FilterableDirectory
      items={items}
      sectionLabel={selectionLabel}
      kind="title-cards"
    />
  </CompactSection>
</BaseLayout>
