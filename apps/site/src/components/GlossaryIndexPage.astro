---
import type { CollectionEntry } from 'astro:content'

import BaseLayout from '../layouts/BaseLayout.astro'
import { getGlossaryHrefFromEntry, getGlossaryIndexHref } from '../lib/glossary-links'
import { getSiteCopy, type SiteLocale } from '../lib/site-copy'

type Props = {
  locale: SiteLocale
  terms: CollectionEntry<'glossary'>[]
}

const { locale, terms } = Astro.props
const copy = getSiteCopy(locale)
const selectionLabel = locale === 'pt-br' ? 'Escolha um termo' : 'Select a term'
---

<BaseLayout
  description={copy.glossaryIndex.copy}
  englishHref={getGlossaryIndexHref('en')}
  portugueseHref={getGlossaryIndexHref('pt-br')}
  title={copy.glossaryIndex.title}
>
  <section class="section section--compact">
    <div class="panel page-toolbar page-toolbar--stacked">
      <p class="section-eyebrow">{copy.glossaryIndex.title}</p>
      <h1 class="section-heading section-heading--compact">{copy.glossaryIndex.title}</h1>
      <p class="page-toolbar__copy">{copy.glossaryIndex.copy}</p>
    </div>
  </section>

  <section class="section section--compact">
    <p class="section-eyebrow">{selectionLabel}</p>
    <div class="panel-grid panel-grid--articles">
      {terms.map((term) => (
        <article class="panel article-card">
          <a class="article-card__link" href={getGlossaryHrefFromEntry(term)}>
            <div class="article-card__body">
              <h3 class="article-card__title">{term.data.title}</h3>
              <p class="article-card__summary">{term.data.description}</p>
            </div>
            <div class="article-card__footer">
              <span class="article-card__cta">
                <span>{selectionLabel}</span>
                <span aria-hidden="true">→</span>
              </span>
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
