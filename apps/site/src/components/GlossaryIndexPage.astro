---
import type { CollectionEntry } from 'astro:content'
import BookTextIcon from '@lucide/astro/icons/book-text'

import FilterableDirectory from '@/components/FilterableDirectory.svelte'
import DirectoryIndexShell from '@/components/ui/DirectoryIndexShell.astro'
import { getGlossaryHrefFromEntry, getGlossaryIndexHref } from '@/lib/glossary-links'
import { translateSiteLabels } from '@/lib/site-labels'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'

type Props = {
  locale: SiteLocale
  terms: CollectionEntry<'glossary'>[]
}

const { locale, terms } = Astro.props
const copy = getSiteCopy(locale)
const sortedTerms = [...terms].sort((left, right) =>
  left.data.title.localeCompare(right.data.title, locale === 'pt-br' ? 'pt-BR' : 'en-US', {
    sensitivity: 'base',
  }),
)
const tagEntries = Array.from(
  new Map(
    sortedTerms
      .flatMap((term) =>
        translateSiteLabels(term.data.tags, locale).map((label, index) => [term.data.tags[index], label] as const),
      )
      .sort((left, right) => left[1].localeCompare(right[1], locale === 'pt-br' ? 'pt-BR' : 'en-US', { sensitivity: 'base' })),
  ).entries(),
).map(([id, label]) => ({ id, label }))
const items = sortedTerms.map((term) => ({
  href: getGlossaryHrefFromEntry(term),
  tags: translateSiteLabels(term.data.tags, locale).map((label, index) => ({
    id: term.data.tags[index],
    label,
  })),
  title: term.data.title,
}))
---

<DirectoryIndexShell
  description={copy.glossaryIndex.copy}
  englishHref={getGlossaryIndexHref('en')}
  icon={BookTextIcon}
  iconLabel={copy.glossaryIndex.title}
  portugueseHref={getGlossaryIndexHref('pt-br')}
  title={copy.glossaryIndex.title}
>
  <FilterableDirectory
    allItemsLabel={locale === 'pt-br' ? 'Tudo' : 'All'}
    availableFilters={tagEntries}
    articleItemsLabel={locale === 'pt-br' ? 'Artigos' : 'Articles'}
    filterLabel={locale === 'pt-br' ? 'Filtrar por tema' : 'Filter by topic'}
    filterQueryKey="tag"
    guideItemsLabel={locale === 'pt-br' ? 'Guias' : 'Guides'}
    items={items}
    client:load
    kind="title-cards"
  />
</DirectoryIndexShell>
