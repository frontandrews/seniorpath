---
import ArticleCard from '@/components/ArticleCard.astro'
import { cn } from '@/lib/cn'
import { getTranslatedSiteLabel } from '@/lib/site-labels'
import type { GuideTreeNode } from '@/lib/guide-tree'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'
import { ui } from '@/lib/ui'
import { guideTreeItemVariants, guideTreeLabelVariants } from '@/lib/ui-variants'

type Props = {
  locale: SiteLocale
  node: GuideTreeNode
}

const { locale, node } = Astro.props
const copy = getSiteCopy(locale)
const translatedLabel = getTranslatedSiteLabel(node.label, locale)
const visibleChildren = node.children.filter((child) => child.guideCount > 0)
const hasPosts = node.posts.length > 0
const isEmptyLeaf = visibleChildren.length === 0 && !hasPosts
const shouldFlattenChildren =
  !hasPosts &&
  visibleChildren.length > 0 &&
  visibleChildren.every((child) => child.posts.length > 0 && child.children.length === 0)
const flattenedPosts = shouldFlattenChildren
  ? visibleChildren.flatMap((child) => child.posts)
  : []
const anchorId = `guide-node-${node.key.toLowerCase().replaceAll(/[^a-z0-9]+/g, '-')}`
const depth = node.depth >= 2 ? 2 : (node.depth as 0 | 1 | 2)
---

<li
  class={guideTreeItemVariants({ depth })}
  data-guide-node={node.key}
  data-guide-node-label={node.label}
  data-guide-post-ids={node.postIds.join(',')}
>
  <div class="grid gap-4">
    <div class="flex flex-wrap items-center gap-2.5" id={anchorId}>
      {node.href ? (
        <a
          class={guideTreeLabelVariants({ depth, interactive: true })}
          href={node.href}
        >
          {translatedLabel}
        </a>
      ) : (
        <p class={guideTreeLabelVariants({ depth })}>
          {translatedLabel}
        </p>
      )}
    </div>

    {hasPosts ? (
      <div class={ui.cardsGrid}>
        {node.posts.map((post) => (
          <ArticleCard post={post} />
        ))}
      </div>
    ) : null}

    {shouldFlattenChildren ? (
      <div class={ui.cardsGrid}>
        {flattenedPosts.map((post) => (
          <ArticleCard post={post} />
        ))}
      </div>
    ) : null}

    {visibleChildren.length > 0 && !shouldFlattenChildren ? (
      <ul class="m-0 grid list-none gap-5 p-0">
        {visibleChildren.map((child) => (
          <Astro.self locale={locale} node={child} />
        ))}
      </ul>
    ) : null}

    {isEmptyLeaf ? (
      <p class={cn('mt-1', ui.cardMetaCaps)}>
        {copy.guideIndex.comingSoon}
      </p>
    ) : null}
  </div>
</li>
