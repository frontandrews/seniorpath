---
import type { CollectionEntry } from 'astro:content'

import { getAppHref } from '../lib/app-links'
import type { GuideTreeNode } from '../lib/guide-tree'

type Props = {
  node: GuideTreeNode
}

const { node } = Astro.props
const hasChildren = node.children.length > 0
const anchorId = `guide-node-${node.key.toLowerCase().replaceAll(/[^a-z0-9]+/g, '-')}`

function getPrimaryDeckHref(post: CollectionEntry<'blog'>) {
  const deckId = post.data.relatedDeckIds[0]
  return deckId ? getAppHref(`/decks/${deckId}`) : null
}
---

<li
  class={`guide-tree__item guide-tree__item--depth-${node.depth}`}
  data-guide-node={node.key}
  data-guide-post-ids={node.postIds.join(',')}
>
  <div class="guide-tree__branch">
    <div class="guide-tree__label-row" id={anchorId}>
      <p class="guide-tree__label">{node.label}</p>
      <span class="badge badge--progress" data-guide-progress={node.key}>Not started</span>
    </div>

    {node.posts.length > 0 ? (
      <div class="guide-tree__posts">
        {node.posts.map((post) => (
          <article class="guide-tree__post" data-guide-post={post.data.guideId}>
            <a class="guide-tree__post-link" href={`/blog/${post.id}`}>
              <h3 class="guide-tree__post-title">{post.data.title}</h3>
            </a>
            <div class="guide-tree__post-actions">
              <a class="button-link button-link--primary" href={`/blog/${post.id}`}>Learn</a>
              {getPrimaryDeckHref(post) ? (
                <a class="button-link" href={getPrimaryDeckHref(post)!}>Practice</a>
              ) : null}
            </div>
          </article>
        ))}
      </div>
    ) : null}

    {hasChildren ? (
      <ul class="guide-tree">
        {node.children.map((child) => (
          <Astro.self node={child} />
        ))}
      </ul>
    ) : null}
  </div>
</li>
