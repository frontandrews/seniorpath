---
import ArticleCard from './ArticleCard.astro'
import { getTranslatedSiteLabel } from '../lib/site-labels'
import type { GuideTreeNode } from '../lib/guide-tree'
import { getSiteCopy, type SiteLocale } from '../lib/site-copy'

type Props = {
  locale: SiteLocale
  node: GuideTreeNode
}

const { locale, node } = Astro.props
const copy = getSiteCopy(locale)
const translatedLabel = getTranslatedSiteLabel(node.label, locale)
const visibleChildren = node.children.filter((child) => child.guideCount > 0)
const hasPosts = node.posts.length > 0
const isEmptyLeaf = visibleChildren.length === 0 && !hasPosts
const anchorId = `guide-node-${node.key.toLowerCase().replaceAll(/[^a-z0-9]+/g, '-')}`
---

<li
  class={`guide-tree__item guide-tree__item--depth-${node.depth}`}
  data-guide-node={node.key}
  data-guide-node-label={node.label}
  data-guide-post-ids={node.postIds.join(',')}
>
  <div class="guide-tree__branch">
    <div class="guide-tree__label-row" id={anchorId}>
      <p class="guide-tree__label">{translatedLabel}</p>
    </div>

    {hasPosts ? (
      <div class="guide-tree__posts panel-grid panel-grid--articles">
        {node.posts.map((post) => (
          <ArticleCard className="guide-tree__post" post={post} />
        ))}
      </div>
    ) : null}

    {visibleChildren.length > 0 ? (
      <ul class={`guide-tree guide-tree--depth-${node.depth + 1}`}>
        {visibleChildren.map((child) => (
          <Astro.self locale={locale} node={child} />
        ))}
      </ul>
    ) : null}

    {isEmptyLeaf ? <p class="guide-tree__placeholder">{copy.guideIndex.comingSoon}</p> : null}
  </div>
</li>
