---
import type { CollectionEntry } from 'astro:content'
import { render } from 'astro:content'
import ArrowLeft from '@lucide/astro/icons/arrow-left'
import ArrowRight from '@lucide/astro/icons/arrow-right'
import ChevronLeft from '@lucide/astro/icons/chevron-left'
import ChevronRight from '@lucide/astro/icons/chevron-right'

import { marked } from 'marked'

import ChallengePlayground from '@/components/ChallengePlayground.svelte'
import ArticleStickyMeta from '@/components/ArticleStickyMeta.astro'
import SolutionReveal from '@/components/SolutionReveal.svelte'
import FilterableDirectory from '@/components/FilterableDirectory.svelte'
import ArticleSection from '@/components/ui/ArticleSection.astro'
import ContentArticleHeader from '@/components/ui/ContentArticleHeader.astro'
import HeaderTagMeta from '@/components/ui/HeaderTagMeta.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getArticleHrefFromEntry } from '@/lib/article-links'
import { getChallengeLanguageLabel, getChallengeLevelLabel, sortChallenges } from '@/lib/challenge-meta'
import { getChallengeHrefFromEntry, getChallengeIndexHref } from '@/lib/challenge-links'
import { cn } from '@/lib/cn'
import { resolveActiveRelatedArticles } from '@/lib/content-integrity'
import { articleReadingDomHooks, getDataHookAttributes } from '@/lib/dom-hooks'
import { formatEditorialDate } from '@/lib/format-date'
import { getLocalePath, resolveLocalizedEntryHrefMap, resolveLocaleMap } from '@/lib/locale-config'
import { resolveEntityOgImageUrl } from '@/lib/og-image'
import { createBreadcrumbSchema, createLearningResourceSchema } from '@/lib/seo'
import { getPageTypeLabel } from '@/lib/section-manifest'
import { getSiteCopy, getSiteDateLocale, getSiteLocale } from '@/lib/site-copy'
import { getActiveChallengesByLocale, getArticleCollection, getChallengeCollection } from '@/lib/site-content'
import { ui } from '@/lib/ui'
import { toHashtagLabel } from '@/lib/article-meta'

type Props = {
  challenge: CollectionEntry<'challenges'>
}

const { challenge } = Astro.props
const { Content } = await render(challenge)
const locale = getSiteLocale(challenge.data.locale)
const copy = getSiteCopy(locale)
const challengeSectionLabel = getPageTypeLabel('challenges', locale)
const allChallenges = await getChallengeCollection()
const localizedChallenges = allChallenges.filter(
  (entry) => entry.data.challengeId === challenge.data.challengeId && entry.data.status === 'active',
)
const alternateLocaleHrefs = resolveLocaleMap((supportedLocale) => {
  const localizedEntry = localizedChallenges.find((entry) => entry.data.locale === supportedLocale)
  return localizedEntry ? getChallengeHrefFromEntry(localizedEntry) : null
})
const activeChallenges = sortChallenges(await getActiveChallengesByLocale(challenge.data.locale))
const localeHrefs = resolveLocalizedEntryHrefMap(
  localizedChallenges,
  (entry) => getChallengeHrefFromEntry(entry),
  (supportedLocale) => getChallengeIndexHref(supportedLocale),
)
const currentChallengeIndex = activeChallenges.findIndex((entry) => entry.id === challenge.id)
const previousChallenge = currentChallengeIndex > 0 ? activeChallenges[currentChallengeIndex - 1] : null
const nextChallenge =
  currentChallengeIndex >= 0 && currentChallengeIndex < activeChallenges.length - 1
    ? activeChallenges[currentChallengeIndex + 1]
    : null
const allArticles = await getArticleCollection()
const relatedArticles = resolveActiveRelatedArticles(allArticles, challenge.data.locale, challenge.data.relatedArticleIds)
const explicitRelatedChallenges = challenge.data.relatedChallengeIds.flatMap((challengeId) => {
  const relatedEntry = activeChallenges.find((entry) => entry.data.challengeId === challengeId)

  return relatedEntry ? [relatedEntry] : []
})
const fallbackRelatedChallenges = activeChallenges.filter(
  (entry) =>
    entry.data.challengeId !== challenge.data.challengeId &&
    (entry.data.type === challenge.data.type || entry.data.level === challenge.data.level),
)
const relatedChallenges = [...explicitRelatedChallenges, ...fallbackRelatedChallenges].filter(
  (entry, index, items) =>
    entry.data.challengeId !== challenge.data.challengeId &&
    items.findIndex((candidate) => candidate.data.challengeId === entry.data.challengeId) === index,
).slice(0, 3)
const levelLabel = getChallengeLevelLabel(challenge.data.level, locale)
const solutionLanguageLabel = getChallengeLanguageLabel(challenge.data.solutionLanguage)
const dateLocale = getSiteDateLocale(locale)
const formattedPubDate = formatEditorialDate(challenge.data.pubDate, dateLocale)
const complexityTimeLabel = copy.challenge.complexityTimeLabel
const complexitySpaceLabel = copy.challenge.complexitySpaceLabel
const problemStatementHtml = challenge.data.problemStatement
  ? await marked.parse(challenge.data.problemStatement)
  : null
const walkthroughHtml = challenge.data.walkthrough
  ? await marked.parse(challenge.data.walkthrough)
  : null
const headerTagItems = challenge.data.tags
  .map((tag) => ({
    label: toHashtagLabel(tag, locale) ?? tag,
  }))
  .filter((item, index, items) => items.findIndex((candidate) => candidate.label === item.label) === index)
const challengeGuideHeadings = [
  problemStatementHtml
    ? {
        depth: 2,
        slug: 'read-challenge',
        text: copy.challenge.readChallenge,
      }
    : null,
  challenge.data.whatToNotice.length > 0
    ? {
        depth: 2,
        slug: 'what-to-notice',
        text: copy.challenge.whatToNotice,
      }
    : null,
  challenge.data.commonMistakes.length > 0
    ? {
        depth: 2,
        slug: 'common-mistakes',
        text: copy.challenge.commonMistakes,
      }
    : null,
].filter((item): item is { depth: 2; slug: string; text: string } => Boolean(item))
const relatedArticleItems = relatedArticles.map((entry) => ({
  href: getArticleHrefFromEntry(entry),
  tags: [],
  title: entry.data.title,
}))
const relatedChallengeItems = relatedChallenges.map((entry) => ({
  href: getChallengeHrefFromEntry(entry),
  tags: [],
  title: entry.data.title,
}))
const challengeUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString()
const socialImage = resolveEntityOgImageUrl(
  Astro.site ?? Astro.url,
  'challenges',
  locale,
  challenge.data.challengeId,
)
const challengeStructuredData = [
  createLearningResourceSchema({
    dateModified: challenge.data.updatedDate?.toISOString() ?? null,
    datePublished: challenge.data.pubDate.toISOString(),
    description: challenge.data.description,
    estimatedMinutes: challenge.data.estimatedMinutes,
    keywords: [...challenge.data.tags, challenge.data.typeLabel, solutionLanguageLabel],
    level: challenge.data.level,
    locale,
    resourceType: challenge.data.typeLabel,
    teaches: challenge.data.whatToNotice,
    title: challenge.data.title,
    url: challengeUrl,
  }),
  createBreadcrumbSchema({
    items: [
      {
        name: copy.layout.home,
        url: new URL(getLocalePath(locale), Astro.site ?? Astro.url).toString(),
      },
      {
        name: challengeSectionLabel,
        url: new URL(getChallengeIndexHref(locale), Astro.site ?? Astro.url).toString(),
      },
      {
        name: challenge.data.title,
        url: challengeUrl,
      },
    ],
  }),
]
---

<BaseLayout
  alternateLocaleHrefs={alternateLocaleHrefs}
  contentWidth="wide"
  description={challenge.data.description}
  localeHrefs={localeHrefs}
  socialImage={socialImage}
  structuredData={challengeStructuredData}
  title={challenge.data.title}
>
  <article class="w-full pb-11">
    <ContentArticleHeader
      className="article-header-wide-shell"
      createdMeta={formattedPubDate}
      createdMetaClassName={ui.articleHeaderTagTone}
      description={challenge.data.description}
      title={challenge.data.title}
    >
      <p class={`mt-3 ${ui.articleHeaderTagTone}`}>
        {challenge.data.typeLabel}
        <span aria-hidden="true" class="px-2">•</span>
        {levelLabel}
        <span aria-hidden="true" class="px-2">•</span>
        {challenge.data.estimatedMinutes} min
        <span aria-hidden="true" class="px-2">•</span>
        {solutionLanguageLabel}
      </p>
      <HeaderTagMeta items={headerTagItems} />
    </ContentArticleHeader>

    <ArticleStickyMeta
      className="article-reading-shell mx-auto my-5 w-full xl:hidden"
      categoryLabel={challenge.data.typeLabel}
      headings={challengeGuideHeadings}
      levelLabel={levelLabel}
      locale={locale}
      readingTimeMinutes={challenge.data.estimatedMinutes}
      showCompletionInPlace={false}
    />

    <div class={ui.articleRailLayout}>
      <div class={ui.articleRailLayoutMain}>
        <div {...getDataHookAttributes(articleReadingDomHooks.content)}>
          {problemStatementHtml ? (
            <section class="article-reading-shell mx-auto mt-6 w-full scroll-mt-28" id="read-challenge">
              <div class="article-prose" set:html={problemStatementHtml} />
            </section>
          ) : null}

          {challenge.data.whatToNotice.length > 0 ? (
            <section class="article-reading-shell mx-auto mt-6 w-full scroll-mt-28" id="what-to-notice">
              <section class={cn(ui.panel, 'grid gap-3 p-5')}>
                <p class={ui.eyebrow}>{copy.challenge.whatToNotice}</p>
                <ul class="grid list-disc gap-2 pl-6 text-[0.98rem] leading-7 text-site-ink-soft marker:text-site-link-hover">
                  {challenge.data.whatToNotice.map((item) => (
                    <li class="pl-1">{item}</li>
                  ))}
                </ul>
              </section>
            </section>
          ) : null}

          {challenge.data.commonMistakes.length > 0 ? (
            <section class="article-reading-shell mx-auto mt-6 w-full scroll-mt-28" id="common-mistakes">
              <section class={cn(ui.panel, 'grid gap-3 p-5')}>
                <p class={ui.eyebrow}>{copy.challenge.commonMistakes}</p>
                <ul class="grid list-disc gap-2 pl-6 text-[0.98rem] leading-7 text-site-ink-soft marker:text-site-link-hover">
                  {challenge.data.commonMistakes.map((item) => (
                    <li class="pl-1">{item}</li>
                  ))}
                </ul>
              </section>
            </section>
          ) : null}

          {walkthroughHtml ? (
            <div class="article-reading-shell mx-auto mt-8 w-full">
              <div class="article-prose" set:html={walkthroughHtml} />
            </div>
          ) : null}

          <div aria-hidden="true" class="h-px" {...getDataHookAttributes(articleReadingDomHooks.end)}></div>
        </div>
      </div>

      <div class={ui.articleRailLayoutGuide}>
        <ArticleStickyMeta
          categoryLabel={challenge.data.typeLabel}
          headings={challengeGuideHeadings}
          levelLabel={levelLabel}
          locale={locale}
          readingTimeMinutes={challenge.data.estimatedMinutes}
          showCompletionInPlace={false}
        />
      </div>
    </div>

    {challenge.data.starterCode ? (
      <ChallengePlayground
        className="article-detail-shell mt-8"
        client:visible
        challengeId={challenge.data.challengeId}
        locale={locale}
        starterCode={challenge.data.starterCode}
        testCases={challenge.data.testCases}
        solutionLanguage={challenge.data.solutionLanguage}
        hints={challenge.data.hints}
        complexity={challenge.data.complexity ?? null}
      />
    ) : null}

    <SolutionReveal
      className="article-detail-shell mt-8"
      client:visible
      challengeId={challenge.data.challengeId}
      copy={copy.solutionReveal}
    >
      {challenge.data.complexity ? (
        <section class={cn(ui.panel, 'mb-8 grid gap-3 p-5')}>
          <p class={ui.eyebrow}>{copy.challenge.complexity}</p>
          <div class="grid gap-2 text-[0.98rem] leading-7 text-site-ink-soft">
            <p class="m-0">
              <strong>{complexityTimeLabel}:</strong> {challenge.data.complexity.time}
            </p>
            <p class="m-0">
              <strong>{complexitySpaceLabel}:</strong> {challenge.data.complexity.space}
            </p>
          </div>
        </section>
      ) : null}
      <div class="article-prose">
        <Content />
      </div>
    </SolutionReveal>

    {previousChallenge || nextChallenge ? (
      <section class="article-detail-shell mx-auto mt-8 grid w-full gap-4 border-t border-article-rule pt-8 md:grid-cols-2 md:items-stretch">
        {nextChallenge ? (
          <a
            class={cn(ui.navCardLink, 'justify-between md:order-3')}
            href={getChallengeHrefFromEntry(nextChallenge)}
          >
            <span class="grid gap-1 content-start text-left md:ml-auto md:justify-items-end md:text-right">
              <span class={cn(ui.eyebrowSentence, 'inline-flex items-center gap-1.5 leading-none md:justify-self-end')}>
                <span class="leading-none">{copy.challenge.nextChallenge}</span>
                <ArrowRight aria-hidden="true" class="size-3.5 shrink-0 md:hidden" />
              </span>
              <span class={ui.linkCardTitle}>{nextChallenge.data.title}</span>
            </span>
            <ChevronRight aria-hidden="true" class="hidden size-6 shrink-0 text-article-body md:block" />
          </a>
        ) : <div class="md:order-3" />}
        {previousChallenge ? (
          <a
            class={cn(ui.navCardLink, 'text-left md:order-1')}
            href={getChallengeHrefFromEntry(previousChallenge)}
          >
            <ChevronLeft aria-hidden="true" class="hidden size-6 shrink-0 text-article-body md:block" />
            <span class="grid gap-1 content-start">
              <span class={cn(ui.eyebrowSentence, 'inline-flex items-center gap-1.5 leading-none')}>
                <ArrowLeft aria-hidden="true" class="size-3.5 shrink-0 md:hidden" />
                <span class="leading-none">{copy.challenge.previousChallenge}</span>
              </span>
              <span class={ui.linkCardTitle}>{previousChallenge.data.title}</span>
            </span>
          </a>
        ) : <div class="md:order-1" />}
      </section>
    ) : null}

    {relatedChallengeItems.length > 0 ? (
      <ArticleSection bodyClass="mt-4" sectionClass={ui.articleUtilitySection} title={copy.challenge.relatedChallenges}>
        <FilterableDirectory items={relatedChallengeItems} layout="cards" />
      </ArticleSection>
    ) : null}

    {relatedArticleItems.length > 0 ? (
      <ArticleSection bodyClass="mt-4" sectionClass={ui.articleUtilitySection} title={copy.challenge.relatedArticles}>
        <FilterableDirectory items={relatedArticleItems} layout="cards" />
      </ArticleSection>
    ) : null}
  </article>
</BaseLayout>
