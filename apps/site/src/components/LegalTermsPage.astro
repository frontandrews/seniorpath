---
import StaticArticlePage from '@/components/ui/StaticArticlePage.astro'
import LegalOperationalReview from '@/components/LegalOperationalReview.astro'
import { getLegalContactLinks } from '@/lib/legal-contact'
import { getLegalPageCopy } from '@/lib/legal-page-copy'
import {
  getLegalGoverningLaw,
  getLegalOperatorLocation,
  getLegalOperatorName,
  getLegalVenue,
  siteConfig,
} from '@/lib/site-config'
import { resolveLocaleHrefMap } from '@/lib/locale-config'
import { getTermsHref } from '@/lib/terms-links'
import { getSiteLocale, type SiteLocale } from '@/lib/site-copy'

type Props = {
  locale?: SiteLocale
}

const { locale: requestedLocale = 'en' } = Astro.props
const locale = getSiteLocale(requestedLocale)
const { legalEmail, supportEmail } = getLegalContactLinks()
const contactEmails = [legalEmail, supportEmail].filter((email) => email !== null)
const operatorName = getLegalOperatorName(locale)
const operatorLocation = getLegalOperatorLocation(locale)
const governingLaw = getLegalGoverningLaw(locale)
const venue = getLegalVenue(locale)
const localeHrefs = resolveLocaleHrefMap((supportedLocale) => getTermsHref(supportedLocale))
const copy = getLegalPageCopy(locale).terms
const copyContext = {
  governingLaw,
  operatorLocation,
  operatorName,
  siteName: siteConfig.site.name,
  venue,
}
---

<StaticArticlePage
  description={copy.description(siteConfig.site.name)}
  kicker="Legal"
  localeHrefs={localeHrefs}
  title={copy.title}
>
  <p>{copy.intro(siteConfig.site.name)}</p>

  <h2>{copy.whoOperates.title}</h2>
  <p>{copy.whoOperates.body(copyContext)}</p>

  <h2>{copy.acceptableUse.title}</h2>
  <p>{copy.acceptableUse.body(copyContext)}</p>
  <ul>
    {copy.acceptableUse.items?.map((item) => <li>{item}</li>)}
  </ul>

  <h2>{copy.accounts.title}</h2>
  <p>{copy.accounts.body(copyContext)}</p>

  <h2>{copy.contentOwnership.title}</h2>
  <p>{copy.contentOwnership.body(copyContext)}</p>

  <h2>{copy.noProfessionalAdvice.title}</h2>
  <p>{copy.noProfessionalAdvice.body(copyContext)}</p>

  <h2>{copy.thirdPartyServices.title}</h2>
  <p>{copy.thirdPartyServices.body(copyContext)}</p>

  <LegalOperationalReview locale={locale} />

  <h2>{copy.availability.title}</h2>
  <p>{copy.availability.body(copyContext)}</p>

  <h2>{copy.disclaimer.title}</h2>
  <p>{copy.disclaimer.body(copyContext)}</p>

  <h2>{copy.governingLawVenue.title}</h2>
  <p>{copy.governingLawVenue.body(copyContext)}</p>

  {contactEmails.length > 0 && copy.contact ? (
    <>
      <h2>{copy.contact.title}</h2>
      <p>
        {copy.contact.intro}{' '}
        {contactEmails.map((email, index) => (
          <>
            {index > 0
              ? (index === contactEmails.length - 1 ? copy.contact.lastSeparator : copy.contact.middleSeparator)
              : null}
            <a href={email.href}>{email.value}</a>
          </>
        ))}
        .
      </p>
    </>
  ) : null}
</StaticArticlePage>
