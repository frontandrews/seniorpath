---
import type { CollectionEntry } from 'astro:content'
import type { LearningPathBranch, LearningPathPillar } from '@/lib/learning-paths'

import BaseLayout from '@/layouts/BaseLayout.astro'
import { getArticleBranchHref, getArticlePillarHref, getArticlesIndexHref } from '@/lib/article-links'
import { getLocalizedBranchLabel, getLocalizedPillarLabel, getPillarBreadcrumb } from '@/lib/article-taxonomy'
import { resolveLocaleHrefMap } from '@/lib/locale-config'
import type { SiteLocale } from '@/lib/site-copy'
import FilterableDirectory from '@/components/FilterableDirectory.svelte'
import CompactSection from '@/components/ui/CompactSection.astro'
import PageHeader from '@/components/ui/PageHeader.astro'

type BranchSection = {
  branch: LearningPathBranch
  posts: CollectionEntry<'articles'>[]
}

type Props = {
  branchSections: BranchSection[]
  locale: SiteLocale
  pillar: LearningPathPillar
}

const PILLAR_PAGE_DESCRIPTION: Record<string, (title: string) => string> = {
  en: (title) => `Articles and branches about ${title} to study with more structure.`,
  'pt-br': (title) => `Artigos e ramificacoes de ${title} para estudar com mais estrutura.`,
}

const { branchSections, locale, pillar } = Astro.props
const title = getLocalizedPillarLabel(pillar, locale)
const localeHrefs = resolveLocaleHrefMap((supportedLocale) =>
  getArticlePillarHref(pillar.id, supportedLocale) ?? getArticlesIndexHref(supportedLocale),
)
const description = (PILLAR_PAGE_DESCRIPTION[locale] ?? PILLAR_PAGE_DESCRIPTION.en)(title)
const breadcrumbItems = getPillarBreadcrumb(pillar, locale)
const items = branchSections.map((section) => ({
  href: getArticleBranchHref(pillar.id, section.branch.id, locale) ?? '#',
  tags: [],
  title: getLocalizedBranchLabel(section.branch, locale),
}))
---

<BaseLayout
  description={description}
  localeHrefs={localeHrefs}
  title={title}
>
  <PageHeader breadcrumbs={breadcrumbItems} description={description} title={title} />

  <div data-pagefind-ignore>
    <CompactSection>
      <FilterableDirectory
        items={items}
        layout="cards"
      />
    </CompactSection>
  </div>
</BaseLayout>
