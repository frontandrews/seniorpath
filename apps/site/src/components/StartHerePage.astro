---
import type { ResolvedEditorialRoadmap } from '@/lib/editorial-roadmaps'

import BaseLayout from '@/layouts/BaseLayout.astro'
import { cn } from '@/lib/cn'
import { formatEditorialDate } from '@/lib/format-date'
import { getGlossaryIndexHref } from '@/lib/glossary-links'
import { getGuideHrefFromEntry, getGuideIndexHref } from '@/lib/guide-links'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'
import { getTracksHref } from '@/lib/tracks-links'
import { getTopicIndexHref } from '@/lib/topic-links'
import { ui } from '@/lib/ui'
import PageHeader from '@/components/ui/PageHeader.astro'
import SectionBlock from '@/components/ui/SectionBlock.astro'
import InlineArrowCta from '@/components/ui/InlineArrowCta.astro'
import LinkCard from '@/components/ui/LinkCard.astro'

type Props = {
  locale: SiteLocale
  roadmap: ResolvedEditorialRoadmap
}

const { locale, roadmap } = Astro.props
const copy = getSiteCopy(locale)
const englishHref = getTracksHref('en', roadmap.slugs.en)
const portugueseHref = getTracksHref('pt-br', roadmap.slugs['pt-br'])
const dateLocale = locale === 'pt-br' ? 'pt-BR' : 'en-US'
const learnMoreLabel = locale === 'pt-br' ? 'Ler mais' : 'Learn more'
const roadmapTags = roadmap.tags ?? []
const supportLinks = [
  {
    href: getGuideIndexHref(locale),
    title: copy.startHere.browseLibrary,
  },
  {
    href: getTopicIndexHref(locale),
    title: copy.startHere.topics,
  },
  {
    href: getGlossaryIndexHref(locale),
    title: copy.startHere.glossary,
  },
]
---

<BaseLayout
  description={roadmap.summary}
  englishHref={englishHref}
  portugueseHref={portugueseHref}
  title={roadmap.title}
>
  <PageHeader description={copy.startHere.copy} title={roadmap.title}>
    <p class={ui.bodyCopy}>{roadmap.intro}</p>
    {roadmapTags.length > 0 ? (
      <div class="mt-2 flex flex-wrap gap-2.5">
        {roadmapTags.map((tag) => (
          <span class={ui.badge}>{tag.label}</span>
        ))}
      </div>
    ) : null}
  </PageHeader>

  <SectionBlock bodyClass={ui.linearList} description={roadmap.summary} title={copy.startHere.linearHeading}>
      {roadmap.nodes.map((node, index) => (
        <article class={cn(ui.linearRow, index === 0 && 'border-t-0')} id={node.kind === 'concept' ? node.id : undefined}>
          {node.kind === 'concept' ? (
            <div class={ui.linearCard}>
              <p class={ui.eyebrowSentence}>
                {copy.startHere.stepLabel} {index + 1} - {copy.startHere.conceptLabel}
              </p>
              <h3 class={cn(ui.linearItemTitle, 'text-site-ink')}>{node.title}</h3>
              <p class={ui.cardDescription}>{node.summary}</p>
              <p class={ui.cardDescription}>{node.panelBody}</p>

              {node.relatedGuides.length > 0 ? (
                <div class="mt-2 flex flex-wrap gap-2.5">
                  {node.relatedGuides.map((guide) => (
                    <a class={cn(ui.badge, ui.badgeLink)} href={getGuideHrefFromEntry(guide)}>
                      {guide.data.title}
                    </a>
                  ))}
                </div>
              ) : null}
            </div>
          ) : (
            <a class={ui.linearCardInteractive} href={node.href}>
              <p class={ui.eyebrowSentence}>
                {formatEditorialDate(node.post.data.pubDate, dateLocale)} - {copy.startHere.stepLabel} {index + 1}
              </p>
              <h3 class={ui.linearItemTitle} data-card-title>{node.post.data.title}</h3>
              <p class={ui.cardDescription}>{node.post.data.description}</p>
              <InlineArrowCta label={learnMoreLabel} />
            </a>
          )}
        </article>
      ))}
  </SectionBlock>

  <SectionBlock bodyClass={ui.titleCardList} description={copy.startHere.supportCopy} title={copy.startHere.supportHeading}>
      {supportLinks.map((link) => (
        <LinkCard href={link.href} title={link.title} titleTag="h3" />
      ))}
  </SectionBlock>
</BaseLayout>
