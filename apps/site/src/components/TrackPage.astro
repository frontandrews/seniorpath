---
import type { ResolvedEditorialRoadmap } from '@/lib/roadmaps'
import RouteIcon from '@lucide/astro/icons/route'

import ArticleSharePanel from '@/components/ArticleSharePanel.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import FilterableDirectory from '@/components/FilterableDirectory.svelte'
import TrackProgressPanel from '@/components/TrackProgressPanel.astro'
import TrackConceptPanel from '@/components/TrackConceptPanel.astro'
import ArticleSection from '@/components/ui/ArticleSection.astro'
import { getLocalePath, resolveLocaleHrefMap, resolveLocaleMap } from '@/lib/locale-config'
import { resolveEntityOgImageUrl } from '@/lib/og-image'
import { resolveEditorialRoadmaps, type EditorialLocale } from '@/lib/roadmaps'
import { createBreadcrumbSchema, createTrackSchema } from '@/lib/seo'
import { getSiteCopy, getSiteLowerCaseLocale, type SiteLocale } from '@/lib/site-copy'
import { getArticleCollection } from '@/lib/site-content'
import { getTracksHref } from '@/lib/tracks-links'
import CompactSection from '@/components/ui/CompactSection.astro'
import PageHeader from '@/components/ui/PageHeader.astro'
import { ui } from '@/lib/ui'

type Props = {
  locale: SiteLocale
  roadmap: ResolvedEditorialRoadmap
}

const { locale, roadmap } = Astro.props
const copy = getSiteCopy(locale)
const roadmapSlugs = roadmap.slugs as Record<string, string | undefined>
const roadmapAvailableLocales = new Set<string>(roadmap.availableLocales)
const alternateLocaleHrefs = resolveLocaleMap((supportedLocale) => {
  if (!roadmapAvailableLocales.has(supportedLocale)) {
    return null
  }

  const localizedSlug = roadmapSlugs[supportedLocale]
  return localizedSlug ? getTracksHref(supportedLocale, localizedSlug) : null
})
const localeHrefs = resolveLocaleHrefMap((supportedLocale) =>
  getTracksHref(supportedLocale, roadmapSlugs[supportedLocale] ?? null)
  ?? getTracksHref(supportedLocale),
)
const tracksHref = getTracksHref(locale) ?? '/'
const lowerCaseLocale = getSiteLowerCaseLocale(locale)
const shareUrl = Astro.url.href
const comingSoonLabel = copy.articlesIndex.comingSoon
const socialImage = resolveEntityOgImageUrl(
  Astro.site ?? Astro.url,
  'tracks',
  locale,
  roadmap.id,
)
const allArticles = await getArticleCollection()
const allRoadmaps = resolveEditorialRoadmaps(locale as EditorialLocale, allArticles)
const trackItems = roadmap.articleNodes
  .filter((node): node is typeof roadmap.articleNodes[number] & { href: string } => Boolean(node.href))
  .map((node, index) => ({
  articleId: node.articleId,
  href: node.href,
  stepLabel: String(index + 1),
  title: node.post.data.title,
}))
const stepLabel = (roadmap.stepCount === 1 ? copy.startHere.stepLabel : copy.startHere.stepsLabel)
  .toLocaleLowerCase(lowerCaseLocale)
const trackMetaItems = [
  copy.articleMeta.levelLabels[roadmap.level],
  `${roadmap.stepCount} ${stepLabel}`,
  `~${roadmap.estimatedReadingMinutes} min`,
]
const trackStructuredData = [
  createTrackSchema({
    description: roadmap.summary,
    items: roadmap.articleNodes.flatMap((node) =>
      node.href
        ? [{
            description: node.post.data.description,
            title: node.post.data.title,
            url: new URL(node.href, Astro.site ?? Astro.url).toString(),
          }]
        : [],
    ),
    level: roadmap.level,
    locale,
    title: roadmap.title,
    totalReadingMinutes: roadmap.estimatedReadingMinutes,
    totalSteps: roadmap.stepCount,
    url: shareUrl,
  }),
  createBreadcrumbSchema({
    items: [
      {
        name: copy.layout.home,
        url: new URL(getLocalePath(locale), Astro.site ?? Astro.url).toString(),
      },
      {
        name: copy.layout.tracks,
        url: new URL(tracksHref, Astro.site ?? Astro.url).toString(),
      },
      {
        name: roadmap.title,
        url: shareUrl,
      },
    ],
  }),
]
const currentRoadmapIndex = allRoadmaps.findIndex((entry) => entry.id === roadmap.id)
const orderedOtherRoadmaps = currentRoadmapIndex >= 0
  ? [...allRoadmaps.slice(currentRoadmapIndex + 1), ...allRoadmaps.slice(0, currentRoadmapIndex)]
  : allRoadmaps.filter((entry) => entry.id !== roadmap.id)
const otherTrackItems = orderedOtherRoadmaps
  .filter((entry) => entry.id !== roadmap.id)
  .slice(0, 3)
  .map((entry) => ({
    href: entry.href,
    tags: [],
    title: entry.title,
  }))
const toTrackDirectoryItem = (node: ResolvedEditorialRoadmap['nodes'][number] & { kind: 'article' }) => ({
  completionId: node.isAvailableInLocale ? node.articleId : undefined,
  href: node.href,
  meta: node.isAvailableInLocale ? undefined : comingSoonLabel,
  tags: [],
  title: node.post.data.title,
})
const fallbackArticleItems = roadmap.nodes
  .filter((node): node is ResolvedEditorialRoadmap['nodes'][number] & { kind: 'article' } => node.kind === 'article')
  .map(toTrackDirectoryItem)
const standaloneArticleItems: typeof fallbackArticleItems = []
const groupedConceptSections: Array<{
  articleItems: typeof fallbackArticleItems
  node: ResolvedEditorialRoadmap['nodes'][number] & { kind: 'concept' }
}> = []

let activeConceptSection: (typeof groupedConceptSections)[number] | null = null

roadmap.nodes.forEach((node) => {
  if (node.kind === 'concept') {
    activeConceptSection = {
      articleItems: [],
      node,
    }
    groupedConceptSections.push(activeConceptSection)
    return
  }

  const articleItem = toTrackDirectoryItem(node)

  if (activeConceptSection) {
    activeConceptSection.articleItems.push(articleItem)
    return
  }

  standaloneArticleItems.push(articleItem)
})
---

<BaseLayout
  alternateLocaleHrefs={alternateLocaleHrefs}
  description={roadmap.summary}
  localeHrefs={localeHrefs}
  socialImage={socialImage}
  structuredData={trackStructuredData}
  title={roadmap.title}
>
  <PageHeader description={roadmap.summary} icon={RouteIcon} iconLabel={copy.layout.tracks} title={roadmap.title}>
    <div class={ui.metaList}>
      {trackMetaItems.map((item) => (
        <span class={ui.badge}>{item}</span>
      ))}
    </div>
  </PageHeader>

  <div data-pagefind-ignore>
    <TrackProgressPanel
      items={trackItems}
      locale={locale}
      totalReadingMinutes={roadmap.estimatedReadingMinutes}
    />

    <CompactSection className="xl:mt-0">
      {groupedConceptSections.length > 0 ? (
        <div class={ui.linearList}>
          {standaloneArticleItems.length > 0 ? (
            <div class="pb-4">
              <FilterableDirectory items={standaloneArticleItems} layout="cards" />
            </div>
          ) : null}

          {groupedConceptSections.map(({ articleItems, node }, index) => (
            <TrackConceptPanel
              articleItems={articleItems}
              className={index === 0 && standaloneArticleItems.length === 0 ? 'border-t-0' : ''}
              locale={locale}
              node={node}
            />
          ))}
        </div>
      ) : (
        <FilterableDirectory items={fallbackArticleItems} layout="cards" />
      )}
    </CompactSection>

    <ArticleSharePanel
      description={roadmap.summary}
      locale={locale}
      title={roadmap.title}
      url={shareUrl}
    />

    {otherTrackItems.length > 0 ? (
      <ArticleSection
        bodyClass="mt-4"
        sectionClass={ui.articleUtilitySection}
        title={copy.startHere.otherTracks}
      >
        <FilterableDirectory items={otherTrackItems} layout="cards" />
      </ArticleSection>
    ) : null}
  </div>
</BaseLayout>
