---
import type { CollectionEntry } from 'astro:content'
import { getCollection, render } from 'astro:content'

import BaseLayout from '@/layouts/BaseLayout.astro'
import { getGuideEditorialContext } from '@/lib/editorial-roadmaps'
import { formatEditorialDate } from '@/lib/format-date'
import { getGiscusConfig } from '@/lib/giscus'
import { getGuideHrefFromEntry, getGuideIndexHref } from '@/lib/guide-links'
import { getGuideBreadcrumb } from '@/lib/guide-taxonomy'
import { translateSiteLabels } from '@/lib/site-labels'
import { sortGuides } from '@/lib/guide-tree'
import { getLocalizedGuideTopics } from '@/lib/topic-taxonomy'
import { getSiteCopy } from '@/lib/site-copy'
import { ui } from '@/lib/ui'
import GiscusComments from '@/components/GiscusComments.astro'
import LinkCard from '@/components/ui/LinkCard.astro'
import ArticleSection from '@/components/ui/ArticleSection.astro'
import ContentArticleHeader from '@/components/ui/ContentArticleHeader.astro'
import { cn } from '@/lib/cn'

type Props = {
  post: CollectionEntry<'guides'>
}

const { post } = Astro.props
const isArticle = post.data.kind === 'article'
const { Content } = await render(post)
const allGuideEntries = await getCollection('guides')
const activePosts = sortGuides(
  allGuideEntries.filter(
    (entry) => entry.data.locale === post.data.locale && entry.data.status !== 'archived',
  ),
)
const englishVersion = allGuideEntries.find(
  (entry) => entry.data.locale === 'en' && entry.data.guideId === post.data.guideId,
)
const portugueseVersion = allGuideEntries.find(
  (entry) => entry.data.locale === 'pt-br' && entry.data.guideId === post.data.guideId,
)
const englishHref =
  post.data.locale === 'en' ? getGuideHrefFromEntry(post) : englishVersion ? getGuideHrefFromEntry(englishVersion) : null
const portugueseHref =
  post.data.locale === 'pt-br'
    ? getGuideHrefFromEntry(post)
    : portugueseVersion
      ? getGuideHrefFromEntry(portugueseVersion)
      : null
const editorialContext = isArticle ? null : getGuideEditorialContext(post, allGuideEntries)
const connectedPosts = activePosts.filter((entry) => {
  if (entry.data.guideId === post.data.guideId) {
    return false
  }

  return post.data.relationships.includes(entry.data.guideId)
})
const relatedPosts = activePosts
  .filter((entry) => {
    if (entry.data.guideId === post.data.guideId) {
      return false
    }

    if (post.data.relationships.includes(entry.data.guideId)) {
      return false
    }

    const sharesTopic = entry.data.topic && entry.data.topic === post.data.topic
    const sharesTag = entry.data.tags.some((tag) => post.data.tags.includes(tag))

    return Boolean(sharesTopic || sharesTag)
  })
  .slice(0, 2)
const siblingPosts = activePosts
  .filter((entry) => {
    if (entry.id === post.id) {
      return false
    }

    return entry.data.pillarId === post.data.pillarId && entry.data.branchId === post.data.branchId
  })
  .slice(0, 3)
const nextReads = [...new Map(
  [...connectedPosts, ...siblingPosts, ...relatedPosts]
    .filter((entry): entry is NonNullable<typeof entry> => Boolean(entry))
    .filter((entry) => entry.data.guideId !== post.data.guideId)
    .map((entry) => [entry.data.guideId, entry]),
).values()].slice(0, 3)
const copy = getSiteCopy(post.data.locale)
const translatedTags = translateSiteLabels(post.data.tags, post.data.locale)
const breadcrumbItems = isArticle
  ? [
      {
        href: getGuideIndexHref(post.data.locale),
        label: copy.learn,
      },
      {
        href: null,
        label: post.data.locale === 'pt-br' ? 'Artigo' : 'Article',
      },
    ]
  : getGuideBreadcrumb(post)
const linkedTopics = getLocalizedGuideTopics(post)
const dateLocale = post.data.locale === 'pt-br' ? 'pt-BR' : 'en-US'
const giscusConfig = getGiscusConfig(post.data.locale === 'pt-br' ? 'pt-br' : 'en')
const formattedPubDate = formatEditorialDate(post.data.pubDate, dateLocale)
const formattedUpdatedDate = post.data.updatedDate
  ? formatEditorialDate(post.data.updatedDate, dateLocale, {
      month: 'short',
    })
  : null
---

<BaseLayout
  description={post.data.description}
  englishHref={englishHref}
  portugueseHref={portugueseHref}
  title={post.data.title}
>
  <article class={ui.articleShell}>
    <ContentArticleHeader
      breadcrumbs={breadcrumbItems}
      description={post.data.description}
      title={post.data.title}
    >
      <div class="mt-4 flex items-center gap-3">
        <img
          alt="Andrews Ribeiro"
          class="size-11 shrink-0 rounded-full border border-article-rule bg-article-surface object-cover"
          height="48"
          loading="lazy"
          src="/andrews.jpg"
          width="48"
        />
        <div class="grid gap-0.5">
          <p class={ui.articleBylineName}>Andrews Ribeiro</p>
          <p class={ui.articleMeta}>{formattedPubDate}</p>
          {formattedUpdatedDate ? (
            <p class={ui.articleMetaSubtle}>
              {copy.article.updatedPrefix} {formattedUpdatedDate}
            </p>
          ) : null}
        </div>
      </div>

      {editorialContext ? (
        <div class="mt-5 grid gap-4 border-t border-article-rule pt-4">
          <div class="grid gap-1">
            <p class={ui.eyebrow}>{copy.startHere.roadmapEyebrow}</p>
            <h2 class={ui.headingCompact}>{editorialContext.roadmap.title}</h2>
            <p class={ui.bodyCopy}>
              {copy.startHere.stepLabel} {editorialContext.stepIndex} / {editorialContext.totalSteps}
            </p>
          </div>
          <div class="flex flex-wrap gap-3">
            <a class={ui.actionLink} href={editorialContext.roadmap.href}>
              {copy.startHere.backToRoadmap}
            </a>
            {editorialContext.previousArticle ? (
              <a class={ui.actionLink} href={editorialContext.previousArticle.href}>
                {copy.startHere.previousArticle}
              </a>
            ) : null}
            {editorialContext.nextArticle ? (
              <a class={ui.actionLink} href={editorialContext.nextArticle.href}>
                {copy.startHere.nextArticle}
              </a>
            ) : null}
          </div>
        </div>
      ) : null}
    </ContentArticleHeader>

    <div class="article-prose">
      <Content />
    </div>

    {linkedTopics.length > 0 || translatedTags.length > 0 ? (
      <div class={ui.articleTagList}>
        {linkedTopics.map((topic) => (
          <a class={cn(ui.badge, ui.badgeLink)} href={topic.href}>{topic.label}</a>
        ))}
        {translatedTags.map((tag) => (
          <span class={ui.badge}>{tag}</span>
        ))}
      </div>
    ) : null}

    {giscusConfig ? (
      <ArticleSection className="mt-[2.2rem]" title={copy.article.comments}>
        <GiscusComments config={giscusConfig} />
      </ArticleSection>
    ) : null}

    {nextReads.length > 0 ? (
      <ArticleSection bodyClass={ui.nextReadsGrid} title={copy.article.nextReads}>
          {nextReads.map((entry) => (
            <LinkCard
              href={getGuideHrefFromEntry(entry)}
              showArrow={false}
              title={entry.data.title}
              titleClass={ui.nextReadTitle}
              titleTag="h3"
              variant="compact"
            />
          ))}
      </ArticleSection>
    ) : null}
  </article>
</BaseLayout>
