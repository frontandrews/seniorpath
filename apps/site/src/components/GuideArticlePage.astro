---
import type { CollectionEntry } from 'astro:content'
import { getCollection, render } from 'astro:content'
import ChevronLeft from '@lucide/astro/icons/chevron-left'
import ChevronRight from '@lucide/astro/icons/chevron-right'

import ArticleComments from '@/components/ArticleComments.svelte'
import ArticleStickyMeta from '@/components/ArticleStickyMeta.astro'
import ArticleSharePanel from '@/components/ArticleSharePanel.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getGuideCategoryLabel, getGuideLevelLabel, getGuideReadingTimeMinutes, toHashtagLabel } from '@/lib/article-meta'
import { getGuideEditorialContext } from '@/lib/editorial-roadmaps'
import { formatEditorialDate } from '@/lib/format-date'
import { getGiscusConfig } from '@/lib/giscus'
import { getGuideHrefFromEntry } from '@/lib/guide-links'
import { translateSiteLabels } from '@/lib/site-labels'
import { sortGuides } from '@/lib/guide-tree'
import { getLocalizedGuideTopics } from '@/lib/topic-taxonomy'
import { getSiteCopy, getSiteLocale } from '@/lib/site-copy'
import { ui } from '@/lib/ui'
import ContentArticleHeader from '@/components/ui/ContentArticleHeader.astro'
import { cn } from '@/lib/cn'

type Props = {
  post: CollectionEntry<'guides'>
}

const { post } = Astro.props
const { Content, headings = [] } = await render(post)
const allGuideEntries = await getCollection('guides')
const activePosts = sortGuides(
  allGuideEntries.filter(
    (entry) => entry.data.locale === post.data.locale && entry.data.status !== 'archived',
  ),
)
const englishVersion = allGuideEntries.find(
  (entry) => entry.data.locale === 'en' && entry.data.guideId === post.data.guideId,
)
const portugueseVersion = allGuideEntries.find(
  (entry) => entry.data.locale === 'pt-br' && entry.data.guideId === post.data.guideId,
)
const englishHref =
  post.data.locale === 'en' ? getGuideHrefFromEntry(post) : englishVersion ? getGuideHrefFromEntry(englishVersion) : null
const portugueseHref =
  post.data.locale === 'pt-br'
    ? getGuideHrefFromEntry(post)
    : portugueseVersion
      ? getGuideHrefFromEntry(portugueseVersion)
      : null
const editorialContext = post.data.kind === 'article' ? null : getGuideEditorialContext(post, allGuideEntries)
const currentPostIndex = activePosts.findIndex((entry) => entry.id === post.id)
const previousPost = currentPostIndex > 0 ? activePosts[currentPostIndex - 1] : null
const nextPost = currentPostIndex >= 0 && currentPostIndex < activePosts.length - 1 ? activePosts[currentPostIndex + 1] : null
const copy = getSiteCopy(post.data.locale)
const translatedTags = translateSiteLabels(post.data.tags, post.data.locale)
const linkedTopics = getLocalizedGuideTopics(post)
const locale = getSiteLocale(post.data.locale)
const dateLocale = post.data.locale === 'pt-br' ? 'pt-BR' : 'en-US'
const giscusConfig = getGiscusConfig(post.data.locale === 'pt-br' ? 'pt-br' : 'en')
const formattedPubDate = formatEditorialDate(post.data.pubDate, dateLocale)
const formattedUpdatedDate = post.data.updatedDate
  ? formatEditorialDate(post.data.updatedDate, 'en-US', {
      month: 'short',
    })
  : null
const displayHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3)
const readingTimeMinutes = getGuideReadingTimeMinutes(post)
const levelLabel = getGuideLevelLabel(post.data.level, post.data.locale)
const categoryLabel = getGuideCategoryLabel(post)
const postIndexByGuideId = new Map(activePosts.map((entry, index) => [entry.data.guideId, index]))
const topicIds = new Set(post.data.topicIds)
const topicRelatedPosts = activePosts
  .filter((entry) => entry.data.guideId !== post.data.guideId)
  .map((entry) => ({
    entry,
    score: entry.data.topicIds.filter((topicId) => topicIds.has(topicId)).length,
  }))
  .filter((entry) => entry.score > 0)
  .sort((a, b) => {
    if (b.score !== a.score) return b.score - a.score
    return (postIndexByGuideId.get(a.entry.data.guideId) ?? 0) - (postIndexByGuideId.get(b.entry.data.guideId) ?? 0)
  })
  .map(({ entry }) => entry)
const explicitRelatedPosts = post.data.relationships.flatMap((guideId) => {
  const relatedEntry = activePosts.find((entry) => entry.data.guideId === guideId)
  return relatedEntry ? [relatedEntry] : []
})
const mergedRelatedPosts = [...topicRelatedPosts, ...explicitRelatedPosts].filter(
  (entry, index, items) => items.findIndex((candidate) => candidate.data.guideId === entry.data.guideId) === index,
)
const fallbackNextStep = mergedRelatedPosts[0] ?? null
const nextStep = editorialContext?.nextArticle
  ? {
      guideId: editorialContext.nextArticle.guideId,
      href: editorialContext.nextArticle.href,
      title: editorialContext.nextArticle.post.data.title,
    }
  : fallbackNextStep
    ? {
        guideId: fallbackNextStep.data.guideId,
        href: getGuideHrefFromEntry(fallbackNextStep),
        title: fallbackNextStep.data.title,
      }
    : null
const relatedItems = mergedRelatedPosts
  .filter((entry) => entry.data.guideId !== nextStep?.guideId)
  .slice(0, 3)
  .map((entry) => ({
    href: getGuideHrefFromEntry(entry),
    title: entry.data.title,
  }))
const completionTrack = editorialContext
  ? {
      href: editorialContext.roadmap.href,
      stepIndex: editorialContext.stepIndex,
      title: editorialContext.roadmap.title,
      totalSteps: editorialContext.totalSteps,
    }
  : null
const displayTags = [...new Set([...linkedTopics.map((topic) => topic.label), ...translatedTags])]
  .map((label) => toHashtagLabel(label, post.data.locale))
  .filter((label): label is string => Boolean(label))
const articleUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString()
---

<BaseLayout
  contentWidth="wide"
  description={post.data.description}
  englishHref={englishHref}
  portugueseHref={portugueseHref}
  title={post.data.title}
>
  <article class="w-full pb-11">
    <ContentArticleHeader
      createdMeta={formattedPubDate}
      description={post.data.description}
      title={post.data.title}
    >
      <div class="mt-4 flex items-center gap-3">
        <img
          alt="Andrews Ribeiro"
          class="size-11 shrink-0 rounded-full border border-article-rule bg-article-surface object-cover"
          height="48"
          loading="lazy"
          src="/andrews.jpg"
          width="48"
        />
        <div class="grid gap-0.5">
          <p class={ui.articleBylineName}>Andrews Ribeiro</p>
          <p class={ui.articleMetaSubtle}>Founder & Engineer</p>
        </div>
      </div>
      {displayTags.length > 0 ? (
        <div class="mt-3 flex flex-wrap gap-x-3 gap-y-1 text-[0.82rem] leading-6 text-site-ink-muted min-[64rem]:text-[0.9rem]">
          {displayTags.map((tag) => (
            <span>{tag}</span>
          ))}
        </div>
      ) : null}

      {editorialContext ? (
        <div class="mt-5 grid gap-4 border-t border-article-rule pt-4">
          <div class="grid gap-1">
            <p class={ui.eyebrow}>{copy.startHere.roadmapEyebrow}</p>
            <h2 class={ui.headingCompact}>{editorialContext.roadmap.title}</h2>
            <p class={ui.bodyCopy}>
              {copy.startHere.stepLabel} {editorialContext.stepIndex} / {editorialContext.totalSteps}
            </p>
          </div>
          <div class="flex flex-wrap gap-3">
            <a class={ui.actionLink} href={editorialContext.roadmap.href}>
              {copy.startHere.backToRoadmap}
            </a>
            {editorialContext.previousArticle ? (
              <a class={ui.actionLink} href={editorialContext.previousArticle.href}>
                {copy.startHere.previousArticle}
              </a>
            ) : null}
            {editorialContext.nextArticle ? (
              <a class={ui.actionLink} href={editorialContext.nextArticle.href}>
                {copy.startHere.nextArticle}
              </a>
            ) : null}
          </div>
        </div>
      ) : null}
    </ContentArticleHeader>

    <div class="w-full xl:grid xl:grid-cols-[minmax(0,1fr)_55rem_minmax(0,1fr)]">
      <div class="min-w-0 xl:col-start-2 xl:self-start">
        <div class="article-prose" data-article-reading-content>
          <Content />
        </div>

        <ArticleSharePanel
          description={post.data.description}
          locale={locale}
          title={post.data.title}
          url={articleUrl}
        />

        {previousPost || nextPost ? (
          <section class={cn(ui.articleSection, 'grid gap-4 md:grid-cols-2 md:items-stretch')}>
            {nextPost ? (
              <a class="flex h-full items-center justify-between gap-3 rounded-[var(--radius-sm)] px-3 py-2 text-inherit transition-colors duration-150 hover:bg-site-hover hover:text-site-link-hover focus-visible:bg-site-hover focus-visible:text-site-link-hover focus-visible:outline-none md:order-3" href={getGuideHrefFromEntry(nextPost)}>
                <span class="ml-auto grid gap-1 content-start justify-items-end text-right">
                  <span class={ui.eyebrowSentence}>{copy.startHere.nextArticle}</span>
                  <span class={ui.linkCardTitle}>{nextPost.data.title}</span>
                </span>
                <ChevronRight aria-hidden="true" class="size-6 shrink-0 text-article-body" />
              </a>
            ) : <div class="md:order-3" />}
            {previousPost ? (
              <a class="flex h-full items-center gap-3 rounded-[var(--radius-sm)] px-3 py-2 text-left text-inherit transition-colors duration-150 hover:bg-site-hover hover:text-site-link-hover focus-visible:bg-site-hover focus-visible:text-site-link-hover focus-visible:outline-none md:order-1" href={getGuideHrefFromEntry(previousPost)}>
                <ChevronLeft aria-hidden="true" class="size-6 shrink-0 text-article-body" />
                <span class="grid gap-1 content-start">
                  <span class={ui.eyebrowSentence}>{copy.startHere.previousArticle}</span>
                  <span class={ui.linkCardTitle}>{previousPost.data.title}</span>
                </span>
              </a>
            ) : <div class="md:order-1" />}
          </section>
        ) : null}

        {giscusConfig ? (
          <ArticleComments
            config={giscusConfig}
            openLabel={post.data.locale === 'pt-br' ? 'Ver comentarios' : 'View comments'}
            title={copy.article.comments}
            client:idle
          />
        ) : null}
      </div>

      <div class="hidden xl:col-start-3 xl:block xl:h-fit xl:w-72 xl:justify-self-end xl:translate-x-38 xl:sticky xl:top-28">
        <ArticleStickyMeta
          categoryLabel={categoryLabel}
          headings={displayHeadings}
          levelLabel={levelLabel}
          locale={locale}
          nextStep={nextStep ? { href: nextStep.href, title: nextStep.title } : null}
          readingTimeMinutes={readingTimeMinutes}
          relatedItems={relatedItems}
          shareTitle={post.data.title}
          shareUrl={articleUrl}
          track={completionTrack}
          updatedMeta={formattedUpdatedDate}
        />
      </div>
    </div>
  </article>
</BaseLayout>
