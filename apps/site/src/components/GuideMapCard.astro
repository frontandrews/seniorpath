---
import type { GuideMapItem } from '@/lib/guide-map'
import { ui } from '@/lib/ui'
import LinkCard from '@/components/ui/LinkCard.astro'

type Props = {
  item: GuideMapItem
}

const { item } = Astro.props
---

<article class="grid h-full gap-3">
  <p class={ui.eyebrow}>{item.path.join(' / ')}</p>

  <LinkCard
    href={`/${item.routePath}`}
    showArrow={false}
    title={item.title}
    titleClass="m-0 text-base font-semibold leading-[1.12] min-[64rem]:text-[1.1rem]"
    titleTag="h3"
    variant="ghost"
  />

  {item.connections.length > 0 ? (
    <div class="mt-auto grid gap-2 border-t border-site-line pt-2">
      <div class="grid gap-2">
        {item.connections.map((connection) => (
          <LinkCard href={`/${connection.routePath}`} showArrow={false} title={connection.title} titleTag="span" variant="compact" />
        ))}
      </div>
    </div>
  ) : null}
</article>
