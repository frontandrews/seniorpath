---
import { getAppHref } from '../lib/app-links'
import type { GuideMapItem } from '../lib/guide-map'

type Props = {
  item: GuideMapItem
}

const { item } = Astro.props
const primaryDeckId = item.relatedDeckIds[0] ?? null
---

<article class="panel guide-map-card">
  <p class="section-eyebrow">{item.path.join(' / ')}</p>

  <h3>{item.title}</h3>

  <div class="meta-list">
    <a class="button-link button-link--primary" href={`/blog/${item.slug}`}>Learn</a>
    {primaryDeckId ? (
      <a class="button-link" href={getAppHref(`/decks/${primaryDeckId}`)}>Practice</a>
    ) : null}
  </div>

  {item.connections.length > 0 ? (
    <div class="guide-map-card__connections">
      <div class="guide-map-card__connection-list">
        {item.connections.map((connection) => (
          <a class="guide-connection" href={`/blog/${connection.slug}`}>
            <span>{connection.title}</span>
          </a>
        ))}
      </div>
    </div>
  ) : null}
</article>
