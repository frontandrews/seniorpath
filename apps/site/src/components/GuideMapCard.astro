---
import { getAppHref } from '../lib/app-links'
import type { GuideMapItem } from '../lib/guide-map'
import { getSiteCopy } from '../lib/site-copy'

type Props = {
  item: GuideMapItem
}

const { item } = Astro.props
const primaryDeckId = item.relatedDeckIds[0] ?? null
const copy = getSiteCopy(item.routePath.startsWith('pt-br/') ? 'pt-br' : 'en')
---

<article class="panel guide-map-card">
  <p class="section-eyebrow">{item.path.join(' / ')}</p>

  <h3>{item.title}</h3>

  <div class="meta-list">
    <a class="button-link button-link--primary" href={`/${item.routePath}`}>{copy.learn}</a>
    {primaryDeckId ? (
      <a class="button-link" href={getAppHref(`/decks/${primaryDeckId}`)}>{copy.article.practice}</a>
    ) : null}
  </div>

  {item.connections.length > 0 ? (
    <div class="guide-map-card__connections">
      <div class="guide-map-card__connection-list">
        {item.connections.map((connection) => (
          <a class="guide-connection" href={`/${connection.routePath}`}>
            <span>{connection.title}</span>
          </a>
        ))}
      </div>
    </div>
  ) : null}
</article>
