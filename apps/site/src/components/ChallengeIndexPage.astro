---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getChallengeIndexHref } from '@/lib/challenge-links'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'
import CompactSection from '@/components/ui/CompactSection.astro'
import InfoPanel from '@/components/ui/InfoPanel.astro'
import PageHeader from '@/components/ui/PageHeader.astro'

type Props = {
  locale: SiteLocale
}

const { locale } = Astro.props
const copy = getSiteCopy(locale)
---

<BaseLayout
  description={copy.challengeIndex.copy}
  englishHref={getChallengeIndexHref('en')}
  portugueseHref={getChallengeIndexHref('pt-br')}
  title={copy.challengeIndex.title}
>
  <PageHeader description={copy.challengeIndex.copy} title={copy.challengeIndex.title} />

  <CompactSection>
    <InfoPanel
      body={locale === 'pt-br'
        ? 'A estrutura ja esta reservada para walkthroughs e problemas resolvidos. Ainda nao ha desafios publicados aqui.'
        : 'The structure is reserved for walkthroughs and worked problems. No challenges are published here yet.'}
    />
  </CompactSection>
</BaseLayout>
