---
import '@/styles/global.css'

import { ClientRouter } from 'astro:transitions'
import BookTextIcon from '@lucide/astro/icons/book-text'
import BrainIcon from '@lucide/astro/icons/brain'
import NewspaperIcon from '@lucide/astro/icons/newspaper'
import PuzzleIcon from '@lucide/astro/icons/puzzle'
import RouteIcon from '@lucide/astro/icons/route'
import TagsIcon from '@lucide/astro/icons/tags'
import LayoutClientScripts from '@/components/layout/LayoutClientScripts.astro'
import LayoutHead from '@/components/layout/LayoutHead.astro'
import LocalePreferenceScript from '@/components/layout/LocalePreferenceScript.astro'
import NewsletterSection from '@/components/layout/NewsletterSection.astro'
import SiteFooter from '@/components/layout/SiteFooter.astro'
import SiteHeader from '@/components/layout/SiteHeader.astro'
import { resolveLayoutHeadContext } from '@/lib/layout-head'
import {
  getDefaultLocale,
  getLocaleHtmlLang,
  getLocalePath,
  getLocaleShortLabel,
  getPathLocale,
} from '@/lib/locale-config'
import { getPrivacyHref } from '@/lib/privacy-links'
import {
  getHomeDefaultSection,
  getNewsletterActionUrl,
  getObservabilityScriptConfig,
  getSiteRobotsMetaContent,
  getSitePageTitle,
  isFeatureEnabled,
  shouldAdvertiseSiteFeed,
} from '@/lib/site-config'
import {
  getEnabledSections,
  getSectionHref,
  getSectionLabel,
} from '@/lib/section-manifest'
import { getSearchLauncherEmptyState, getSiteCopy } from '@/lib/site-copy'
import { getTermsHref } from '@/lib/terms-links'
import { ui } from '@/lib/ui'
import type { SiteLocale } from '@/lib/site-copy'

type Props = {
  alternateLocaleHrefs?: Record<string, string | null>
  contentWidth?: 'default' | 'wide'
  description: string
  localeHrefs?: Record<string, string | null>
  noindex?: boolean
  pagefind?: boolean
  socialImage?: string
  structuredData?: Record<string, unknown> | Record<string, unknown>[]
  title: string
}

type ExploreLink = {
  href: string
  icon: typeof NewspaperIcon
  id: string
  isActive: boolean
  label: string
  pageType: string
}

const {
  alternateLocaleHrefs = {},
  contentWidth = 'default',
  description,
  localeHrefs = {},
  noindex = false,
  pagefind = true,
  socialImage,
  structuredData = [],
  title,
} = Astro.props

const pageTitle = getSitePageTitle(title)
const pathname = Astro.url.pathname
const pageUrl = Astro.site ?? Astro.url
const canonicalUrl = new URL(`${Astro.url.pathname}${Astro.url.search}`, pageUrl).toString()
const currentLocale = getPathLocale(pathname) as SiteLocale
const copy = getSiteCopy(currentLocale)
const homeHref = getLocalePath(currentLocale)
const shouldAutoRedirectLocale = pathname === getLocalePath(getDefaultLocale())
const privacyHref = getPrivacyHref(currentLocale)
const termsHref = getTermsHref(currentLocale)
const observabilityScriptConfig = getObservabilityScriptConfig()
const currentYear = new Date().getFullYear()
const currentLocaleCode = getLocaleShortLabel(currentLocale)
const defaultHomeSection = getHomeDefaultSection()
const hasSearch = isFeatureEnabled('search')
const hasLocaleSwitcher = isFeatureEnabled('localeSwitcher')
const newsletterFormAction = getNewsletterActionUrl()
const hasNewsletter = newsletterFormAction !== null
const sectionIconByPageType = {
  articles: NewspaperIcon,
  challenges: PuzzleIcon,
  concepts: BrainIcon,
  glossary: BookTextIcon,
  topics: TagsIcon,
  tracks: RouteIcon,
} as const
const exploreLinks: ExploreLink[] = getEnabledSections().flatMap((section) => {
  const href = getSectionHref(section.id, currentLocale)

  if (!href) {
    return []
  }

  const icon =
    sectionIconByPageType[section.pageType as keyof typeof sectionIconByPageType] ?? NewspaperIcon
  const isHomeSection = defaultHomeSection === section.id && pathname === homeHref

  return [
    {
      href,
      icon,
      id: section.id,
      isActive: isHomeSection || pathname === href || pathname.startsWith(`${href}/`),
      label: getSectionLabel(section.id, currentLocale),
      pageType: section.pageType,
    },
  ]
})
const pageShellClass =
  contentWidth === 'wide'
    ? ui.pageShellWide
    : ui.pageShell
const mainClass = `${pageShellClass} site-transition-content`
const searchableSections = getEnabledSections()
  .map((section) => ({
    href: getSectionHref(section.id, currentLocale),
    id: section.id,
    label: getSectionLabel(section.id, currentLocale),
  }))
  .filter(
    (
      section,
    ): section is {
      href: string
      id: string
      label: string
    } => Boolean(section.href),
  )
const searchableList = searchableSections.map((section) => section.label.toLowerCase()).join(', ')
const emptyState = getSearchLauncherEmptyState(currentLocale, searchableList)
const {
  defaultAlternateHref,
  localeSwitchLinks,
  rssHref,
  seoAlternateLinks,
  structuredDataItems,
} = resolveLayoutHeadContext({
  alternateLocaleHrefs,
  canonicalUrl,
  currentLocale,
  description,
  homeHref,
  localeHrefs,
  pathname,
  siteUrl: pageUrl,
  structuredData,
})
const rssHrefForShell = shouldAdvertiseSiteFeed() ? rssHref : null
const robotsContent = getSiteRobotsMetaContent(noindex)
---

<!doctype html>
<html class="dark" data-js="false" lang={getLocaleHtmlLang(currentLocale)}>
  <head>
    <ClientRouter fallback="animate" />
    <LayoutHead
      canonicalUrl={canonicalUrl}
      defaultAlternateHref={defaultAlternateHref}
      description={description}
      noindex={noindex}
      observabilityScriptConfig={observabilityScriptConfig}
      pageTitle={pageTitle}
      robotsContent={robotsContent}
      rssHref={rssHrefForShell}
      seoAlternateLinks={seoAlternateLinks}
      socialImage={socialImage}
      structuredDataItems={structuredDataItems}
    />
    <LocalePreferenceScript
      currentLocale={currentLocale}
      enableRedirect={shouldAutoRedirectLocale}
      homeHref={homeHref}
      localeSwitchLinks={localeSwitchLinks}
    />
    <slot name="head" />
  </head>
  <body>
    <a
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:rounded-xs focus:border focus:border-site-line-strong focus:bg-site-panel focus:px-4 focus:py-3 focus:text-sm focus:font-semibold focus:text-site-link-hover focus:outline-none"
      data-astro-reload
      href="#main-content"
    >
      {copy.header.skipToContent}
    </a>
    <SiteHeader
      copy={copy}
      currentLocaleCode={currentLocaleCode}
      emptyState={emptyState}
      exploreLinks={exploreLinks}
      hasLocaleSwitcher={hasLocaleSwitcher}
      hasSearch={hasSearch}
      homeHref={homeHref}
      isDev={import.meta.env.DEV}
      localeSwitchLinks={localeSwitchLinks}
      searchableSections={searchableSections}
    />
    <main class={mainClass} data-pagefind-body={pagefind ? true : undefined} id="main-content" tabindex="-1">
      <slot />
    </main>
    {hasNewsletter ? (
      <NewsletterSection
        copy={copy}
        newsletterFormAction={newsletterFormAction!}
        privacyHref={privacyHref}
        termsHref={termsHref}
      />
    ) : null}
    <SiteFooter
      copy={copy}
      currentYear={currentYear}
      exploreLinks={exploreLinks}
      homeHref={homeHref}
      privacyHref={privacyHref}
      rssHref={rssHrefForShell}
      termsHref={termsHref}
    />
    <LayoutClientScripts />
  </body>
</html>
