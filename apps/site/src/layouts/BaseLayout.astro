---
import '../styles/global.css'
import { Icon } from 'astro-icon/components'

import { getGuideIndexHref, getGuideLocaleFromPathname } from '../lib/guide-links'
import { getSiteCopy } from '../lib/site-copy'

type Props = {
  description: string
  localeSuggestionHref?: string | null
  title: string
}

const {
  description,
  localeSuggestionHref = null,
  title,
} = Astro.props

const pageTitle = `${title} | SeniorPath`
const pathname = Astro.url.pathname
const guideLocale = getGuideLocaleFromPathname(pathname)
const copy = getSiteCopy(guideLocale)
const englishGuideIndexHref = getGuideIndexHref('en')
const portugueseGuideIndexHref = getGuideIndexHref('pt-br')
const homeHref = guideLocale === 'pt-br' ? '/pt-br' : '/'
const currentYear = new Date().getFullYear()
---

<!doctype html>
<html lang={guideLocale === 'pt-br' ? 'pt-BR' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin href="https://fonts.gstatic.com" rel="preconnect" />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Space+Grotesk:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
    <meta content={description} name="description" />
    <meta content={pageTitle} property="og:title" />
    <meta content={description} property="og:description" />
    <meta content="website" property="og:type" />
    <meta content="summary_large_image" name="twitter:card" />
    <meta content={pageTitle} name="twitter:title" />
    <meta content={description} name="twitter:description" />
    <script is:inline>
      try {
        const storedTheme = window.localStorage.getItem('seniorpath.site.theme.v1')
        document.documentElement.classList.toggle('dark', storedTheme !== 'light')
      } catch {}
    </script>
  </head>
  <body>
    {guideLocale === 'en' && localeSuggestionHref ? (
      <div class="site-locale-prompt" data-locale-prompt hidden>
        <div class="site-frame site-locale-prompt__inner">
          <p class="site-locale-prompt__text">{copy.localePrompt.message}</p>
          <div class="site-locale-prompt__actions">
            <a class="site-locale-prompt__action" data-locale-prompt-link href={localeSuggestionHref}>
              {copy.localePrompt.action}
            </a>
            <button class="site-locale-prompt__dismiss" data-locale-prompt-dismiss type="button">
              {copy.localePrompt.dismiss}
            </button>
          </div>
        </div>
      </div>
    ) : null}
    <header class="site-header">
      <div class="site-frame site-header__inner">
          <a class="site-brand" href={homeHref}>
            <span class="site-brand__mark">
              <Icon aria-hidden="true" class="site-brand__icon" name="lucide:waypoints" />
            </span>
            <span class="site-brand__label">{copy.header.brand}</span>
          </a>
          <div class="site-header__actions">
            <div aria-label="Language switcher" class="site-lang-switcher">
              <a
                class={guideLocale === 'en' ? 'site-nav__link site-nav__link--active' : 'site-nav__link'}
                href={englishGuideIndexHref}
                hreflang="en"
                lang="en"
              >
                EN
              </a>
              <a
                class={guideLocale === 'pt-br' ? 'site-nav__link site-nav__link--active' : 'site-nav__link'}
                href={portugueseGuideIndexHref}
                hreflang="pt-BR"
                lang="pt-BR"
              >
                PT
              </a>
            </div>
            <button aria-label={copy.layout.themeToggle} class="site-theme-toggle" data-theme-toggle type="button">
              <Icon aria-hidden="true" class="site-theme-toggle__icon site-theme-toggle__icon--sun" name="lucide:sun" />
              <Icon aria-hidden="true" class="site-theme-toggle__icon site-theme-toggle__icon--moon" name="lucide:moon" />
            </button>
          </div>
      </div>
    </header>
    <div class="site-shell">
      <slot />
    </div>
    <footer class="site-footer">
      <div class="site-frame site-footer__main">
          <div class="site-footer__intro">
            <a class="site-brand" href={homeHref}>
              <span class="site-brand__mark">
                <Icon aria-hidden="true" class="site-brand__icon" name="lucide:waypoints" />
              </span>
              <span class="site-brand__label">{copy.header.brand}</span>
            </a>
            <p class="site-footer__copy">{copy.footer.description}</p>
          </div>
          <div class="site-footer__group">
            <div class="site-footer__stack">
              <a class="site-footer__link" href={homeHref}>{copy.footer.home}</a>
            </div>
          </div>
          <div class="site-footer__group">
            <div class="site-footer__stack">
              <a class="site-footer__link" href="/terms">{copy.footer.terms}</a>
              <a class="site-footer__link" href="/privacy">{copy.footer.privacy}</a>
            </div>
          </div>
      </div>
      <div class="site-footer__bottom">
        <div class="site-frame">
          <p class="site-footer__meta">© {currentYear} {copy.footer.title}. {copy.footer.rights}</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<script is:inline>
  const themeButton = document.querySelector('[data-theme-toggle]')
  const localePrompt = document.querySelector('[data-locale-prompt]')
  const localePromptDismiss = document.querySelector('[data-locale-prompt-dismiss]')
  const localePromptLink = document.querySelector('[data-locale-prompt-link]')

  themeButton?.addEventListener('click', () => {
    const nextIsDark = !document.documentElement.classList.contains('dark')
    document.documentElement.classList.toggle('dark', nextIsDark)
    try {
      window.localStorage.setItem('seniorpath.site.theme.v1', nextIsDark ? 'dark' : 'light')
    } catch {}
  })

  if (localePrompt) {
    try {
      const localePreference = window.localStorage.getItem('seniorpath.site.locale-suggestion.v1')
      const prefersPortuguese =
        navigator.language?.toLowerCase().startsWith('pt') ||
        navigator.languages?.some((value) => value.toLowerCase().startsWith('pt'))

      if (!localePreference && prefersPortuguese) {
        localePrompt.hidden = false
      }
    } catch {}
  }

  localePromptDismiss?.addEventListener('click', () => {
    const prompt = document.querySelector('[data-locale-prompt]')
    if (!(prompt instanceof HTMLElement)) {
      return
    }

    prompt.hidden = true

    try {
      window.localStorage.setItem('seniorpath.site.locale-suggestion.v1', 'dismissed')
    } catch {}
  })

  localePromptLink?.addEventListener('click', () => {
    try {
      window.localStorage.setItem('seniorpath.site.locale-suggestion.v1', 'accepted')
    } catch {}
  })
</script>
