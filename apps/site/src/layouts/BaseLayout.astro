---
import '@/styles/global.css'

import BookTextIcon from '@lucide/astro/icons/book-text'
import BrainIcon from '@lucide/astro/icons/brain'
import ChevronDownIcon from '@lucide/astro/icons/chevron-down'
import MenuIcon from '@lucide/astro/icons/menu'
import NewspaperIcon from '@lucide/astro/icons/newspaper'
import RouteIcon from '@lucide/astro/icons/route'
import TagsIcon from '@lucide/astro/icons/tags'
import XIcon from '@lucide/astro/icons/x'
import { getArticlesIndexHref } from '@/lib/articles-links'
import BrandIcon from '@/components/ui/icons/BrandIcon.astro'
import SearchLauncher from '@/components/SearchLauncher.astro'
import { cn } from '@/lib/cn'
import { getConceptsHref } from '@/lib/concepts-links'
import { getGuideIndexHref, getGuideLocaleFromPathname } from '@/lib/guide-links'
import { getGlossaryIndexHref } from '@/lib/glossary-links'
import { getSiteCopy } from '@/lib/site-copy'
import { getTermsHref } from '@/lib/terms-links'
import { getTracksHref } from '@/lib/tracks-links'
import { getTopicIndexHref } from '@/lib/topic-links'
import { ui } from '@/lib/ui'
import type { SiteLocale } from '@/lib/site-copy'

type Props = {
  contentWidth?: 'default' | 'wide'
  description: string
  englishHref?: string | null
  portugueseHref?: string | null
  title: string
}

const {
  contentWidth = 'default',
  description,
  englishHref = null,
  portugueseHref = null,
  title,
} = Astro.props

const pageTitle = `${title} | SeniorPath`
const pathname = Astro.url.pathname
const guideLocale = getGuideLocaleFromPathname(pathname) as SiteLocale
const copy = getSiteCopy(guideLocale)
const englishGuideIndexHref = englishHref ?? getGuideIndexHref('en')
const portugueseGuideIndexHref = portugueseHref ?? getGuideIndexHref('pt-br')
const homeHref = guideLocale === 'pt-br' ? '/pt-br' : '/'
const tracksHref = getTracksHref(guideLocale)
const conceptsHref = getConceptsHref(guideLocale)
const learnHref = getGuideIndexHref(guideLocale)
const topicsHref = getTopicIndexHref(guideLocale)
const glossaryHref = getGlossaryIndexHref(guideLocale)
const termsHref = getTermsHref(guideLocale)
const rssHref = guideLocale === 'pt-br' ? '/pt-br/feed.xml' : '/feed.xml'
const currentYear = new Date().getFullYear()
const alternateLocale = guideLocale === 'pt-br' ? 'en' : 'pt-br'
const localeRedirectHref = guideLocale === 'pt-br' ? englishGuideIndexHref : portugueseGuideIndexHref
const currentLocaleCode = guideLocale === 'pt-br' ? 'PT' : 'EN'
const articlesHref = getArticlesIndexHref(guideLocale)
const isTracksPage = pathname === tracksHref || pathname.startsWith(`${tracksHref}/`)
const isConceptsPage = pathname === conceptsHref || pathname.startsWith(`${conceptsHref}/`)
const isTopicsPage = pathname === topicsHref || pathname.startsWith(`${topicsHref}/`)
const isGlossaryPage = pathname === glossaryHref || pathname.startsWith(`${glossaryHref}/`)
const isArticlesPage = pathname === homeHref || pathname === articlesHref
const brandLinkClass =
  'inline-flex min-h-10 items-center gap-3 text-site-ink min-[64rem]:min-h-11 min-[64rem]:gap-3.5 max-[56rem]:min-h-8 max-[56rem]:gap-2'
const brandIconWrapClass = 'inline-flex size-8 items-center justify-center min-[64rem]:size-9 max-[56rem]:size-[1.6rem]'
const brandIconClass = 'size-7 min-[64rem]:size-[1.85rem] max-[56rem]:size-[1.3rem]'
const brandLabelClass =
  'font-head text-[clamp(1.45rem,3vw,2rem)] leading-none tracking-[-0.04em] min-[64rem]:text-[clamp(1.6rem,2.4vw,2.2rem)] max-[56rem]:text-[1.2rem]'
const mobileNavLinkClass =
  'block rounded-[var(--radius-sm)] px-3 py-3 text-[0.98rem] font-medium text-site-ink transition-colors duration-150 hover:bg-site-hover hover:text-site-link-hover focus-visible:bg-site-hover focus-visible:text-site-link-hover focus-visible:outline-none min-[64rem]:px-3.5 min-[64rem]:py-3.5 min-[64rem]:text-[1.02rem]'
const mobileNavActiveClass = 'bg-site-hover text-site-link-hover'
const localeSwitchClass =
  'inline-flex items-center rounded-full border border-site-line bg-site-panel p-1'
const localeOptionActiveClass = 'bg-site-hover text-site-link-hover'
const mobileLocaleOptionClass =
  'inline-flex min-h-9 min-w-12 items-center justify-center rounded-full px-3 py-1.5 text-[0.76rem] font-semibold tracking-[0.08em] text-site-ink transition-colors duration-150 hover:text-site-link-hover focus-visible:text-site-link-hover focus-visible:outline-none'
const desktopDropdownTriggerClass =
  'inline-flex min-h-9 cursor-pointer list-none items-center justify-center gap-1.5 rounded-full px-1 py-2 text-[0.92rem] font-medium text-site-ink transition-colors duration-150 hover:text-site-link-hover focus-visible:text-site-link-hover focus-visible:outline-none min-[64rem]:min-h-10 min-[64rem]:px-2 min-[64rem]:text-[1rem] [&::-webkit-details-marker]:hidden'
const desktopDropdownMenuClass =
  'absolute right-0 top-[calc(100%+0.6rem)] z-30 grid min-w-[13rem] gap-1 rounded-[var(--radius)] border border-site-line bg-site-panel p-2 shadow-[0_18px_60px_rgba(5,10,20,0.2)] min-[64rem]:min-w-[14rem]'
const desktopExploreLinkClass =
  'flex items-center gap-2.5 rounded-[var(--radius-sm)] px-3 py-3 text-[0.95rem] font-medium text-site-ink transition-colors duration-150 hover:bg-site-hover hover:text-site-link-hover focus-visible:bg-site-hover focus-visible:text-site-link-hover focus-visible:outline-none min-[64rem]:gap-3 min-[64rem]:px-3.5 min-[64rem]:py-3.5 min-[64rem]:text-[1.04rem]'
const desktopLocaleTriggerClass =
  'inline-flex min-h-9 cursor-pointer list-none items-center justify-center gap-1 rounded-[var(--radius-sm)] border border-site-line bg-site-panel px-2.5 py-2 text-[0.78rem] font-semibold tracking-[0.08em] text-site-ink transition-colors duration-150 hover:bg-site-hover hover:text-site-link-hover focus-visible:bg-site-hover focus-visible:text-site-link-hover focus-visible:outline-none min-[64rem]:min-h-10 min-[64rem]:gap-1.5 min-[64rem]:px-3 min-[64rem]:text-[0.86rem] [&::-webkit-details-marker]:hidden'
const pageShellClass =
  contentWidth === 'wide'
    ? 'mx-auto min-h-screen max-w-[72rem] px-4 pb-16 md:px-6 min-[64rem]:max-w-[80rem]'
    : ui.pageShell
---

<!doctype html>
<html class="dark" lang={guideLocale === 'pt-br' ? 'pt-BR' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin href="https://fonts.gstatic.com" rel="preconnect" />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Space+Grotesk:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
    <meta content={description} name="description" />
    <meta content={pageTitle} property="og:title" />
    <meta content={description} property="og:description" />
    <meta content="website" property="og:type" />
    <meta content="summary_large_image" name="twitter:card" />
    <meta content={pageTitle} name="twitter:title" />
    <meta content={description} name="twitter:description" />
    <link href={rssHref} rel="alternate" title={`${pageTitle} RSS`} type="application/rss+xml" />
    <slot name="head" />
  </head>
  <body data-locale-alternate={alternateLocale} data-locale-redirect-href={localeRedirectHref}>
    <header class="sticky top-0 z-20 mb-4 border-b border-site-line bg-site-bg">
      <div class={cn(ui.blogFrame, 'py-[0.85rem] min-[64rem]:py-[1rem] max-[56rem]:py-[0.55rem]')}>
        <div class="flex items-center justify-between gap-4 max-[56rem]:gap-3">
          <a class={brandLinkClass} href={homeHref}>
            <span class={brandIconWrapClass}>
              <BrandIcon className={brandIconClass} />
            </span>
            <span class={brandLabelClass}>{copy.header.brand}</span>
          </a>
          <div class="flex items-center gap-2">
            <div class="hidden min-[56rem]:flex min-[56rem]:items-center min-[56rem]:gap-2">
              <details class="relative">
                <summary class={desktopDropdownTriggerClass}>
                  <span>{copy.header.explore}</span>
                  <ChevronDownIcon class="size-4" />
                </summary>
                <div class={desktopDropdownMenuClass}>
                  <a class={cn(desktopExploreLinkClass, isGlossaryPage && mobileNavActiveClass)} href={glossaryHref}>
                    <BookTextIcon class="size-4 shrink-0 text-site-ink-muted" />
                    {copy.layout.glossary}
                  </a>
                  <a class={cn(desktopExploreLinkClass, isArticlesPage && mobileNavActiveClass)} href={articlesHref}>
                    <NewspaperIcon class="size-4 shrink-0 text-site-ink-muted" />
                    {copy.layout.articles}
                  </a>
                  <a class={cn(desktopExploreLinkClass, isConceptsPage && mobileNavActiveClass)} href={conceptsHref}>
                    <BrainIcon class="size-4 shrink-0 text-site-ink-muted" />
                    {copy.layout.concepts}
                  </a>
                  <a class={cn(desktopExploreLinkClass, isTopicsPage && mobileNavActiveClass)} href={topicsHref}>
                    <TagsIcon class="size-4 shrink-0 text-site-ink-muted" />
                    {copy.layout.topics}
                  </a>
                  <a class={cn(desktopExploreLinkClass, isTracksPage && mobileNavActiveClass)} href={tracksHref}>
                    <RouteIcon class="size-4 shrink-0 text-site-ink-muted" />
                    {copy.layout.tracks}
                  </a>
                </div>
              </details>
            </div>
            <SearchLauncher locale={guideLocale} />
            <div class="hidden min-[56rem]:flex min-[56rem]:items-center min-[56rem]:gap-2">
              <details class="relative">
                <summary class={desktopLocaleTriggerClass}>
                  <span>{currentLocaleCode}</span>
                  <ChevronDownIcon class="size-4" />
                </summary>
                <div aria-label={copy.header.languageSwitcher} class="absolute right-0 top-[calc(100%+0.6rem)] z-30 grid min-w-[10rem] gap-1 rounded-[var(--radius)] border border-site-line bg-site-panel p-2 shadow-[0_18px_60px_rgba(5,10,20,0.2)]">
                  <a
                    class={cn(mobileNavLinkClass, guideLocale === 'en' && mobileNavActiveClass)}
                    href={englishGuideIndexHref}
                    hreflang="en"
                    lang="en"
                    data-locale-choice="en"
                  >
                    English
                  </a>
                  <a
                    class={cn(mobileNavLinkClass, guideLocale === 'pt-br' && mobileNavActiveClass)}
                    href={portugueseGuideIndexHref}
                    hreflang="pt-BR"
                    lang="pt-BR"
                    data-locale-choice="pt-br"
                  >
                    Portugues
                  </a>
                </div>
              </details>
            </div>
            <button
              aria-controls="mobile-site-nav"
              aria-expanded="false"
              class="inline-flex min-h-10 items-center justify-center rounded-[var(--radius-sm)] border border-site-line bg-site-panel px-3 py-2 text-sm font-semibold tracking-[0.04em] text-site-ink transition-colors duration-150 hover:bg-site-hover hover:text-site-link-hover focus-visible:bg-site-hover focus-visible:text-site-link-hover focus-visible:outline-none min-[56rem]:hidden"
              data-label-close={copy.header.closeMenu}
              data-label-open={copy.header.menu}
              data-mobile-nav-toggle
              type="button"
            >
              <MenuIcon class="size-4" data-mobile-nav-open-icon />
              <XIcon class="hidden size-4" data-mobile-nav-close-icon />
              <span class="sr-only" data-mobile-nav-toggle-label>{copy.header.menu}</span>
            </button>
          </div>
        </div>
        <div class="hidden w-full pt-3 min-[56rem]:hidden" data-mobile-nav-panel id="mobile-site-nav">
          <div class="grid gap-3 rounded-[var(--radius)] border border-site-line bg-site-panel p-3 shadow-[0_18px_60px_rgba(5,10,20,0.2)]">
            <nav aria-label={copy.header.primaryNav} class="grid gap-1">
              <a class={cn(mobileNavLinkClass, isArticlesPage && mobileNavActiveClass)} href={articlesHref}>
                {copy.layout.articles}
              </a>
              <a class={cn(mobileNavLinkClass, isGlossaryPage && mobileNavActiveClass)} href={glossaryHref}>
                {copy.layout.glossary}
              </a>
              <a class={cn(mobileNavLinkClass, isConceptsPage && mobileNavActiveClass)} href={conceptsHref}>
                {copy.layout.concepts}
              </a>
              <a class={cn(mobileNavLinkClass, isTopicsPage && mobileNavActiveClass)} href={topicsHref}>
                {copy.layout.topics}
              </a>
              <a class={cn(mobileNavLinkClass, isTracksPage && mobileNavActiveClass)} href={tracksHref}>
                {copy.layout.tracks}
              </a>
            </nav>
            <div class="grid gap-2 border-t border-site-line pt-3">
              <p class="m-0 text-[0.72rem] font-bold uppercase tracking-[0.18em] text-site-line-strong">
                {copy.header.languageSwitcher}
              </p>
              <div class={cn(localeSwitchClass, 'w-fit')}>
                <a
                  class={cn(mobileLocaleOptionClass, guideLocale === 'en' && localeOptionActiveClass)}
                  href={englishGuideIndexHref}
                  hreflang="en"
                  lang="en"
                  data-locale-choice="en"
                >
                  EN
                </a>
                <a
                  class={cn(mobileLocaleOptionClass, guideLocale === 'pt-br' && localeOptionActiveClass)}
                  href={portugueseGuideIndexHref}
                  hreflang="pt-BR"
                  lang="pt-BR"
                  data-locale-choice="pt-br"
                >
                  PT
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>
    <main class={pageShellClass} data-pagefind-body>
      <slot />
    </main>
    <footer class="mt-12 border-t-2 border-site-line-strong bg-site-surface">
      <div class={cn(ui.blogFrame, 'grid gap-8 py-10 md:grid-cols-[minmax(0,1.5fr)_minmax(12rem,1fr)_minmax(12rem,1fr)]')}>
          <div class="grid content-start gap-3">
            <a class={brandLinkClass} href={homeHref}>
              <span class={brandIconWrapClass}>
                <BrandIcon className={brandIconClass} />
              </span>
              <span class={brandLabelClass}>{copy.header.brand}</span>
            </a>
            <p class="m-0 max-w-[30rem] leading-7 text-site-ink-soft">{copy.footer.description}</p>
          </div>
          <div class="grid content-start gap-3">
            <div class="grid gap-[0.85rem]">
              <a class={ui.footerLink} href={topicsHref}>{copy.footer.topics}</a>
              <a class={ui.footerLink} href={glossaryHref}>{copy.footer.glossary}</a>
              <a class={ui.footerLink} href={conceptsHref}>{copy.layout.concepts}</a>
              <a class={ui.footerLink} href={tracksHref}>{copy.footer.tracks}</a>
            </div>
          </div>
          <div class="grid content-start gap-3">
            <div class="grid gap-[0.85rem]">
              <a class={ui.footerLink} href={learnHref}>{copy.footer.learn}</a>
              <a class={ui.footerLink} href={termsHref}>{copy.footer.terms}</a>
              <a class={ui.footerLink} href={rssHref}>{copy.footer.rss}</a>
              <a class={ui.footerLink} href="/privacy">{copy.footer.privacy}</a>
            </div>
          </div>
      </div>
      <div class="border-t-2 border-site-line-strong bg-site-surface text-center">
        <div class={cn(ui.blogFrame, 'py-4')}>
          <p class="m-0 text-sm leading-[1.3] text-site-ink min-[64rem]:text-[0.96rem]">© {currentYear} {copy.footer.title}. {copy.footer.rights}</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<script>
  import { readLocalStorageString, writeLocalStorageString } from '@/lib/local-storage'
  import { siteStorageKeys } from '@/lib/storage-keys'

  const localeChoiceLinks = [...document.querySelectorAll('[data-locale-choice]')]
  const mobileNavToggle = document.querySelector('[data-mobile-nav-toggle]')
  const mobileNavPanel = document.querySelector('[data-mobile-nav-panel]')
  const mobileNavOpenIcon = document.querySelector('[data-mobile-nav-open-icon]')
  const mobileNavCloseIcon = document.querySelector('[data-mobile-nav-close-icon]')
  const mobileNavToggleLabel = document.querySelector('[data-mobile-nav-toggle-label]')
  const mobileNavLinks = [...document.querySelectorAll('#mobile-site-nav a')]

  localeChoiceLinks.forEach((link) => {
    link.addEventListener('click', () => {
      const value = link.getAttribute('data-locale-choice')
      if (!value) {
        return
      }

      writeLocalStorageString(siteStorageKeys.localePreference, value)
    })
  })

  // @ts-expect-error Astro inline scripts do not preserve local type annotations here.
  const setMobileNavOpen = (isOpen) => {
    if (!(mobileNavToggle instanceof HTMLButtonElement) || !(mobileNavPanel instanceof HTMLElement)) {
      return
    }

    mobileNavToggle.setAttribute('aria-expanded', String(isOpen))
    mobileNavPanel.classList.toggle('hidden', !isOpen)
    mobileNavOpenIcon?.classList.toggle('hidden', isOpen)
    mobileNavCloseIcon?.classList.toggle('hidden', !isOpen)

    if (mobileNavToggleLabel instanceof HTMLElement) {
      const nextLabel = isOpen
        ? mobileNavToggle.getAttribute('data-label-close')
        : mobileNavToggle.getAttribute('data-label-open')

      if (nextLabel) {
        mobileNavToggleLabel.textContent = nextLabel
      }
    }
  }

  if (mobileNavToggle instanceof HTMLButtonElement) {
    setMobileNavOpen(false)
    mobileNavToggle.addEventListener('click', () => {
      const isOpen = mobileNavToggle.getAttribute('aria-expanded') === 'true'
      setMobileNavOpen(!isOpen)
    })
  }

  mobileNavLinks.forEach((link) => {
    link.addEventListener('click', () => {
      setMobileNavOpen(false)
    })
  })

  const savedLocalePreference = readLocalStorageString(siteStorageKeys.localePreference)
  const currentLocale = document.documentElement.lang === 'pt-BR' ? 'pt-br' : 'en'
  const alternateHref = document.body.getAttribute('data-locale-redirect-href')
  const alternateLocale = document.body.getAttribute('data-locale-alternate')
  const browserPrefersPortuguese =
    navigator.language?.toLowerCase().startsWith('pt') ||
    navigator.languages?.some((value) => value.toLowerCase().startsWith('pt'))
  const preferredLocale = savedLocalePreference ?? (browserPrefersPortuguese ? 'pt-br' : 'en')

  if (!savedLocalePreference && preferredLocale !== currentLocale && alternateHref && alternateLocale === preferredLocale) {
    window.location.replace(alternateHref)
  }

  const desktopNavMedia = window.matchMedia('(min-width: 896px)')
  desktopNavMedia.addEventListener('change', (event) => {
    if (event.matches) {
      setMobileNavOpen(false)
    }
  })
</script>
