---
import '@/styles/global.css'

import BrandIcon from '@/components/ui/icons/BrandIcon.astro'
import { cn } from '@/lib/cn'
import { getConceptsHref } from '@/lib/concepts-links'
import { getGuideIndexHref, getGuideLocaleFromPathname } from '@/lib/guide-links'
import { getGlossaryIndexHref } from '@/lib/glossary-links'
import { getSearchHref } from '@/lib/search-links'
import { getSiteCopy } from '@/lib/site-copy'
import { getTermsHref } from '@/lib/terms-links'
import { getTracksHref } from '@/lib/tracks-links'
import { getTopicIndexHref } from '@/lib/topic-links'
import { ui } from '@/lib/ui'
import { navLinkVariants } from '@/lib/ui-variants'

type Props = {
  description: string
  englishHref?: string | null
  portugueseHref?: string | null
  title: string
}

const {
  description,
  englishHref = null,
  portugueseHref = null,
  title,
} = Astro.props

const pageTitle = `${title} | SeniorPath`
const pathname = Astro.url.pathname
const guideLocale = getGuideLocaleFromPathname(pathname)
const copy = getSiteCopy(guideLocale)
const englishGuideIndexHref = englishHref ?? getGuideIndexHref('en')
const portugueseGuideIndexHref = portugueseHref ?? getGuideIndexHref('pt-br')
const homeHref = guideLocale === 'pt-br' ? '/pt-br' : '/'
const tracksHref = getTracksHref(guideLocale)
const conceptsHref = getConceptsHref(guideLocale)
const learnHref = getGuideIndexHref(guideLocale)
const topicsHref = getTopicIndexHref(guideLocale)
const glossaryHref = getGlossaryIndexHref(guideLocale)
const searchHref = getSearchHref(guideLocale)
const termsHref = getTermsHref(guideLocale)
const rssHref = guideLocale === 'pt-br' ? '/pt-br/feed.xml' : '/feed.xml'
const currentYear = new Date().getFullYear()
const alternateLocale = guideLocale === 'pt-br' ? 'en' : 'pt-br'
const localeRedirectHref = guideLocale === 'pt-br' ? englishGuideIndexHref : portugueseGuideIndexHref
const isTracksPage = pathname === tracksHref || pathname.startsWith(`${tracksHref}/`)
const isConceptsPage = pathname === conceptsHref || pathname.startsWith(`${conceptsHref}/`)
const isGlossaryPage = pathname === glossaryHref || pathname.startsWith(`${glossaryHref}/`)
const isLearnPage = pathname === learnHref || pathname.startsWith(`${learnHref}/`)
const isSearchPage = pathname === searchHref
const brandLinkClass = 'inline-flex min-h-10 items-center gap-3 text-site-ink max-[56rem]:min-h-8 max-[56rem]:gap-2'
const brandIconWrapClass = 'inline-flex size-8 items-center justify-center max-[56rem]:size-[1.6rem]'
const brandIconClass = 'size-7 max-[56rem]:size-[1.3rem]'
const brandLabelClass = 'font-head text-[clamp(1.45rem,3vw,2rem)] leading-none tracking-[-0.04em] max-[56rem]:text-[1.2rem]'
---

<!doctype html>
<html class="dark" lang={guideLocale === 'pt-br' ? 'pt-BR' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin href="https://fonts.gstatic.com" rel="preconnect" />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Space+Grotesk:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
    <meta content={description} name="description" />
    <meta content={pageTitle} property="og:title" />
    <meta content={description} property="og:description" />
    <meta content="website" property="og:type" />
    <meta content="summary_large_image" name="twitter:card" />
    <meta content={pageTitle} name="twitter:title" />
    <meta content={description} name="twitter:description" />
    <link href={rssHref} rel="alternate" title={`${pageTitle} RSS`} type="application/rss+xml" />
    <slot name="head" />
  </head>
  <body data-locale-alternate={alternateLocale} data-locale-redirect-href={localeRedirectHref}>
    <header class="sticky top-0 z-20 mb-4 border-b border-site-line bg-[color:color-mix(in_srgb,var(--site-bg)_68%,transparent)] backdrop-blur-[14px]">
      <div class={cn(ui.frame, 'flex flex-wrap items-center justify-between gap-4 py-[0.85rem] max-[56rem]:gap-3 max-[56rem]:py-[0.55rem]')}>
          <a class={brandLinkClass} href={homeHref}>
            <span class={brandIconWrapClass}>
              <BrandIcon className={brandIconClass} />
            </span>
            <span class={brandLabelClass}>{copy.header.brand}</span>
          </a>
          <nav
            aria-label="Primary"
            class="flex flex-wrap justify-center gap-1 max-[56rem]:order-3 max-[56rem]:w-full max-[56rem]:justify-start"
          >
            <a class={navLinkVariants({ active: isLearnPage })} href={learnHref}>
              {copy.learn}
            </a>
            <a class={navLinkVariants({ active: isGlossaryPage })} href={glossaryHref}>
              {copy.layout.glossary}
            </a>
            <a class={navLinkVariants({ active: isConceptsPage })} href={conceptsHref}>
              {copy.layout.concepts}
            </a>
            <a class={navLinkVariants({ active: isTracksPage })} href={tracksHref}>
              {copy.layout.tracks}
            </a>
            <a class={navLinkVariants({ active: isSearchPage })} href={searchHref}>
              {copy.layout.search}
            </a>
          </nav>
          <div class="flex items-center gap-2 max-[56rem]:ml-auto max-[56rem]:justify-end">
            <div aria-label="Language switcher" class="inline-flex gap-1 max-[56rem]:gap-[0.2rem]">
              <a
                class={navLinkVariants({ active: guideLocale === 'en' })}
                href={englishGuideIndexHref}
                hreflang="en"
                lang="en"
                data-locale-choice="en"
              >
                EN
              </a>
              <a
                class={navLinkVariants({ active: guideLocale === 'pt-br' })}
                href={portugueseGuideIndexHref}
                hreflang="pt-BR"
                lang="pt-BR"
                data-locale-choice="pt-br"
              >
                PT
              </a>
            </div>
          </div>
      </div>
    </header>
    <main class={ui.pageShell} data-pagefind-body>
      <slot />
    </main>
    <footer class="mt-12 border-t-2 border-site-line-strong bg-site-surface">
      <div class={cn(ui.frame, 'grid gap-8 py-10 md:grid-cols-[minmax(0,1.5fr)_minmax(12rem,1fr)_minmax(12rem,1fr)]')}>
          <div class="grid content-start gap-3">
            <a class={brandLinkClass} href={homeHref}>
              <span class={brandIconWrapClass}>
                <BrandIcon className={brandIconClass} />
              </span>
              <span class={brandLabelClass}>{copy.header.brand}</span>
            </a>
            <p class="m-0 max-w-[30rem] leading-7 text-site-ink-soft">{copy.footer.description}</p>
          </div>
          <div class="grid content-start gap-3">
            <div class="grid gap-[0.85rem]">
              <a class={ui.footerLink} href={tracksHref}>{copy.footer.tracks}</a>
              <a class={ui.footerLink} href={learnHref}>{copy.footer.learn}</a>
              <a class={ui.footerLink} href={conceptsHref}>{copy.layout.concepts}</a>
              <a class={ui.footerLink} href={searchHref}>{copy.footer.search}</a>
            </div>
          </div>
          <div class="grid content-start gap-3">
            <div class="grid gap-[0.85rem]">
              <a class={ui.footerLink} href={topicsHref}>{copy.footer.topics}</a>
              <a class={ui.footerLink} href={glossaryHref}>{copy.footer.glossary}</a>
              <a class={ui.footerLink} href={termsHref}>{copy.footer.terms}</a>
              <a class={ui.footerLink} href={rssHref}>{copy.footer.rss}</a>
              <a class={ui.footerLink} href="/privacy">{copy.footer.privacy}</a>
            </div>
          </div>
      </div>
      <div class="border-t-2 border-site-line-strong bg-site-surface text-center">
        <div class={cn(ui.frame, 'py-4')}>
          <p class="m-0 text-sm leading-[1.3] text-site-ink">© {currentYear} {copy.footer.title}. {copy.footer.rights}</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<script>
  import { readLocalStorageString, writeLocalStorageString } from '@/lib/local-storage'
  import { siteStorageKeys } from '@/lib/storage-keys'

  const localeChoiceLinks = [...document.querySelectorAll('[data-locale-choice]')]

  localeChoiceLinks.forEach((link) => {
    link.addEventListener('click', () => {
      const value = link.getAttribute('data-locale-choice')
      if (!value) {
        return
      }

      writeLocalStorageString(siteStorageKeys.localePreference, value)
    })
  })

  const savedLocalePreference = readLocalStorageString(siteStorageKeys.localePreference)
  const currentLocale = document.documentElement.lang === 'pt-BR' ? 'pt-br' : 'en'
  const alternateHref = document.body.getAttribute('data-locale-redirect-href')
  const alternateLocale = document.body.getAttribute('data-locale-alternate')
  const browserPrefersPortuguese =
    navigator.language?.toLowerCase().startsWith('pt') ||
    navigator.languages?.some((value) => value.toLowerCase().startsWith('pt'))
  const preferredLocale = savedLocalePreference ?? (browserPrefersPortuguese ? 'pt-br' : 'en')

  if (!savedLocalePreference && preferredLocale !== currentLocale && alternateHref && alternateLocale === preferredLocale) {
    window.location.replace(alternateHref)
  }
</script>
