---
import '@/styles/global.css'

import BookTextIcon from '@lucide/astro/icons/book-text'
import BrainIcon from '@lucide/astro/icons/brain'
import MailIcon from '@lucide/astro/icons/mail'
import NewspaperIcon from '@lucide/astro/icons/newspaper'
import PuzzleIcon from '@lucide/astro/icons/puzzle'
import RouteIcon from '@lucide/astro/icons/route'
import TagsIcon from '@lucide/astro/icons/tags'
import BrandIcon from '@/brand/BrandIcon.astro'
import DesktopExploreMenu from '@/components/DesktopExploreMenu.astro'
import DesktopLocaleMenu from '@/components/DesktopLocaleMenu.astro'
import MobileNavMenu from '@/components/MobileNavMenu.astro'
import SearchLauncher from '@/components/SearchLauncher.svelte'
import { cn } from '@/lib/cn'
import { completionDomHooks, getDataHookAttributes, layoutDomHooks } from '@/lib/dom-hooks'
import {
  getDefaultLocale,
  getLocaleFeedHref,
  getLocaleHrefMap,
  getLocaleHtmlLang,
  getLocaleLabel,
  getLocalePath,
  getLocaleShortLabel,
  getPathLocale,
  getSupportedLocaleDefinitions,
} from '@/lib/locale-config'
import { getPrivacyHref } from '@/lib/privacy-links'
import {
  createWebsiteSchema,
  normalizeStructuredData,
  serializeStructuredData,
} from '@/lib/seo'
import {
  getHomeDefaultSection,
  getNewsletterActionUrl,
  getSitePageTitle,
  isFeatureEnabled,
  siteConfig,
  siteEvents,
  siteStorageKeys,
  siteUrls,
} from '@/lib/site-config'
import {
  getEnabledSections,
  getSectionHref,
  getSectionLabel,
} from '@/lib/section-manifest'
import { getSearchLauncherEmptyState, getSiteCopy } from '@/lib/site-copy'
import { getTermsHref } from '@/lib/terms-links'
import { ui } from '@/lib/ui'
import type { SiteLocale } from '@/lib/site-copy'

type Props = {
  alternateLocaleHrefs?: Record<string, string | null>
  contentWidth?: 'default' | 'wide'
  description: string
  localeHrefs?: Record<string, string | null>
  noindex?: boolean
  pagefind?: boolean
  structuredData?: Record<string, unknown> | Record<string, unknown>[]
  title: string
}

const {
  alternateLocaleHrefs = {},
  contentWidth = 'default',
  description,
  localeHrefs = {},
  noindex = false,
  pagefind = true,
  structuredData = [],
  title,
} = Astro.props

const pageTitle = getSitePageTitle(title)
const pathname = Astro.url.pathname
const canonicalUrl = new URL(`${Astro.url.pathname}${Astro.url.search}`, Astro.site ?? Astro.url).toString()
const currentLocale = getPathLocale(pathname) as SiteLocale
const copy = getSiteCopy(currentLocale)
const localeHrefMap = getLocaleHrefMap(localeHrefs)
const seoAlternateSource =
  Object.keys(alternateLocaleHrefs).length > 0 ? alternateLocaleHrefs : localeHrefs
const seoAlternateLinks = getSupportedLocaleDefinitions()
  .flatMap((locale) => {
    const href = seoAlternateSource[locale.code]

    if (!href) {
      return []
    }

    return [{
      absoluteHref: new URL(href, Astro.site ?? Astro.url).toString(),
      code: locale.code,
      htmlLang: locale.htmlLang,
    }]
  })
const defaultAlternateHref = seoAlternateSource[getDefaultLocale()]
  ? new URL(seoAlternateSource[getDefaultLocale()]!, Astro.site ?? Astro.url).toString()
  : null
const localeSwitchLinks = getSupportedLocaleDefinitions().map((locale) => ({
  code: locale.code,
  href: localeHrefMap[locale.code] ?? getLocalePath(locale.code),
  htmlLang: locale.htmlLang,
  isActive: locale.code === currentLocale,
  label: getLocaleLabel(locale.code),
  shortLabel: getLocaleShortLabel(locale.code),
}))
const homeHref = getLocalePath(currentLocale)
const privacyHref = getPrivacyHref(currentLocale)
const termsHref = getTermsHref(currentLocale)
const rssHref = getLocaleFeedHref(currentLocale)
const currentYear = new Date().getFullYear()
const currentLocaleCode = getLocaleShortLabel(currentLocale)
const defaultHomeSection = getHomeDefaultSection()
const hasSearch = isFeatureEnabled('search')
const hasLocaleSwitcher = isFeatureEnabled('localeSwitcher')
type ExploreLink = {
  id: string
  href: string
  icon: typeof NewspaperIcon
  isActive: boolean
  label: string
  pageType: string
}
const newsletterFormAction = getNewsletterActionUrl()
const hasNewsletter = newsletterFormAction !== null
const sectionIconByPageType = {
  articles: NewspaperIcon,
  challenges: PuzzleIcon,
  concepts: BrainIcon,
  glossary: BookTextIcon,
  topics: TagsIcon,
  tracks: RouteIcon,
} as const
const exploreLinks: ExploreLink[] = getEnabledSections().flatMap((section) => {
  const href = getSectionHref(section.id, currentLocale)

  if (!href) {
    return []
  }

  const icon =
    sectionIconByPageType[section.pageType as keyof typeof sectionIconByPageType] ?? NewspaperIcon
  const isHomeSection = defaultHomeSection === section.id && pathname === homeHref

  return [
    {
      id: section.id,
      href,
      icon,
      isActive: isHomeSection || pathname === href || pathname.startsWith(`${href}/`),
      label: getSectionLabel(section.id, currentLocale),
      pageType: section.pageType,
    },
  ]
})
const hasExploreLinks = exploreLinks.length > 0
const brandLinkClass =
  'inline-flex min-h-8 items-center gap-2 text-site-ink nav:min-h-10 nav:gap-3 lg:min-h-11 lg:gap-3.5'
const brandIconWrapClass = 'inline-flex size-[1.6rem] items-center justify-center nav:size-8 lg:size-9'
const brandIconClass = 'size-[1.3rem] nav:size-7 lg:size-[1.85rem]'
const brandLabelClass =
  'font-head text-[1.2rem] leading-none tracking-[-0.04em] nav:text-[clamp(1.45rem,3vw,2rem)] lg:text-[clamp(1.6rem,2.4vw,2.2rem)]'
const mobileNavLinkClass = ui.navMenuLink
const mobileNavActiveClass = 'bg-site-hover text-site-link-hover'
const localeSwitchClass =
  'inline-flex items-center rounded-full border border-site-line bg-site-panel p-1'
const localeOptionActiveClass = 'bg-site-hover text-site-link-hover'
const mobileLocaleOptionClass =
  'inline-flex min-h-9 min-w-12 items-center justify-center rounded-full px-3 py-1.5 text-[0.76rem] font-semibold tracking-[0.08em] text-site-ink transition-colors duration-150 hover:text-site-link-hover focus-visible:text-site-link-hover focus-visible:outline-none'
const desktopDropdownTriggerClass = ui.dropdownTrigger
const desktopDropdownMenuClass =
  cn(ui.dropdownMenu, 'min-w-52 lg:min-w-56')
const desktopExploreLinkClass = ui.navMenuRowLink
const desktopLocaleTriggerClass =
  cn(ui.controlButton, 'min-h-9 cursor-pointer list-none gap-1 px-2.5 py-2 text-[0.78rem] font-semibold tracking-[0.08em] lg:min-h-10 lg:gap-1.5 lg:px-3 lg:text-[0.86rem] [&::-webkit-details-marker]:hidden')
const desktopTriggerClass =
  cn(ui.controlButton, 'hidden nav:inline-flex nav:h-9 nav:w-54 nav:justify-between nav:gap-3 px-3 py-0 text-left text-[0.9rem] text-site-ink-muted lg:h-10 lg:w-60 lg:gap-3.5 lg:text-[0.98rem]')
const mobileTriggerClass =
  cn(ui.controlButton, 'min-h-10 px-3 py-2 lg:min-h-11 nav:hidden')
const pageShellClass =
  contentWidth === 'wide'
    ? ui.pageShellWide
    : ui.pageShell
const mobileNavPanelClass = cn(
  ui.panel,
  'site-dropdown-shadow grid gap-3 overflow-hidden rounded-[1.35rem] p-3',
)
const searchableSections = getEnabledSections()
  .map((section) => ({
    href: getSectionHref(section.id, currentLocale),
    id: section.id,
    label: getSectionLabel(section.id, currentLocale),
  }))
  .filter(
    (
      section,
    ): section is {
      href: string
      id: string
      label: string
    } => Boolean(section.href),
  )
const searchableList = searchableSections.map((section) => section.label.toLowerCase()).join(', ')
const emptyState = getSearchLauncherEmptyState(currentLocale, searchableList)
const structuredDataItems = [
  ...normalizeStructuredData(structuredData),
  ...(pathname === homeHref
    ? [
        createWebsiteSchema({
          description,
          locale: currentLocale,
          url: canonicalUrl,
        }),
      ]
    : []),
]
---

<!doctype html>
<html class="dark" lang={getLocaleHtmlLang(currentLocale)}>
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin href="https://fonts.gstatic.com" rel="preconnect" />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Space+Grotesk:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
    <meta content={description} name="description" />
    {noindex ? <meta content="noindex,follow" name="robots" /> : null}
    <link href={canonicalUrl} rel="canonical" />
    <meta content={siteConfig.site.name} property="og:site_name" />
    <meta content={pageTitle} property="og:title" />
    <meta content={description} property="og:description" />
    <meta content="website" property="og:type" />
    <meta content={canonicalUrl} property="og:url" />
    <meta content={siteUrls.socialImage} property="og:image" />
    <meta content={pageTitle} property="og:image:alt" />
    <meta content="1200" property="og:image:width" />
    <meta content="630" property="og:image:height" />
    <meta content="summary_large_image" name="twitter:card" />
    <meta content={pageTitle} name="twitter:title" />
    <meta content={description} name="twitter:description" />
    <meta content={siteUrls.socialImage} name="twitter:image" />
    <meta content={pageTitle} name="twitter:image:alt" />
    {seoAlternateLinks.map((localeLink) => (
      <link href={localeLink.absoluteHref} hreflang={localeLink.htmlLang} rel="alternate" />
    ))}
    {defaultAlternateHref ? <link href={defaultAlternateHref} hreflang="x-default" rel="alternate" /> : null}
    <link href={rssHref} rel="alternate" title={`${pageTitle} RSS`} type="application/rss+xml" />
    {structuredDataItems.map((item) => (
      <script is:inline type="application/ld+json" set:html={serializeStructuredData(item)} />
    ))}
    <script
      data-current-locale={currentLocale}
      data-locale-options={JSON.stringify(localeSwitchLinks.map((localeLink) => ({
        code: localeLink.code,
        href: localeLink.href,
      })))}
      data-locale-preference-key={siteStorageKeys.localePreference}
      is:inline
    >
      try {
        const currentScript = document.currentScript

        if (!(currentScript instanceof HTMLScriptElement)) {
          throw new Error('Missing locale redirect script context')
        }

        const currentLocale = currentScript.dataset.currentLocale ?? 'en'
        const localePreferenceKey = currentScript.dataset.localePreferenceKey ?? ''
        const localeOptions = JSON.parse(currentScript.dataset.localeOptions ?? '[]')
        const savedLocalePreference = window.localStorage.getItem(localePreferenceKey)

        if (!savedLocalePreference) {
          const resolvePreferredLocale = () => {
            for (const option of localeOptions) {
              const languageNeedle = option.code.split('-')[0]?.toLowerCase()

              if (!languageNeedle) {
                continue
              }

              if (
                navigator.languages?.some((value) => value.toLowerCase().startsWith(languageNeedle))
                || navigator.language?.toLowerCase().startsWith(languageNeedle)
              ) {
                return option.code
              }
            }

            return null
          }

          const preferredLocale = resolvePreferredLocale()
          const preferredOption = localeOptions.find((option) => option.code === preferredLocale) ?? null

          if (
            preferredOption
            && preferredOption.code !== currentLocale
            && typeof preferredOption.href === 'string'
          ) {
            window.location.replace(preferredOption.href)
          }
        }
      } catch {}
    </script>
    <slot name="head" />
  </head>
  <body>
    <header class="sticky top-0 z-20 mb-4 border-b border-site-line bg-site-bg">
      <div class={cn(ui.blogFrame, 'py-[0.55rem] nav:py-[0.85rem] lg:py-4')}>
        <div class="flex items-center justify-between gap-3 nav:gap-4">
          <a class={brandLinkClass} href={homeHref}>
            <span class={brandIconWrapClass}>
              <BrandIcon className={brandIconClass} />
            </span>
            <span class={brandLabelClass}>{copy.header.brand}</span>
          </a>
          <div class="flex items-center gap-2">
            <div class="hidden nav:flex nav:items-center nav:gap-2">
              {hasExploreLinks ? (
                <DesktopExploreMenu
                  activeClass={mobileNavActiveClass}
                  itemClass={desktopExploreLinkClass}
                  links={exploreLinks}
                  menuClass={desktopDropdownMenuClass}
                  triggerClass={desktopDropdownTriggerClass}
                  triggerLabel={copy.header.explore}
                />
              ) : null}
            </div>
            {hasSearch ? (
              <SearchLauncher
                client:idle
                copy={copy.searchLauncher}
                desktopTriggerClass={desktopTriggerClass}
                dialogClass={ui.searchDialog}
                dialogHintClass={ui.dialogHint}
                emptyState={emptyState}
                fallbackGroupLabel={copy.directory.page}
                isDev={import.meta.env.DEV}
                mobileTriggerClass={mobileTriggerClass}
                searchableSections={searchableSections}
                searchResultLinkClass={ui.searchResultLink}
              />
            ) : null}
            <div class={cn('hidden nav:flex nav:items-center nav:gap-2', !hasLocaleSwitcher && 'nav:hidden')}>
              <DesktopLocaleMenu
                activeClass={mobileNavActiveClass}
                currentLocaleCode={currentLocaleCode}
                itemClass={mobileNavLinkClass}
                localeLinks={localeSwitchLinks}
                menuClass={cn(ui.dropdownMenu, 'min-w-40')}
                triggerClass={desktopLocaleTriggerClass}
                triggerLabel={copy.header.languageSwitcher}
              />
            </div>
            <MobileNavMenu
              closeLabel={copy.header.closeMenu}
              localeLinks={localeSwitchLinks}
              localeOptionActiveClass={localeOptionActiveClass}
              localeSwitchClass={localeSwitchClass}
              localeSwitcherLabel={copy.header.languageSwitcher}
              menuLabel={copy.header.menu}
              mobileLocaleOptionClass={mobileLocaleOptionClass}
              mobileNavActiveClass={mobileNavActiveClass}
              mobileNavLinkClass={mobileNavLinkClass}
              navLinks={exploreLinks}
              panelClass={mobileNavPanelClass}
              primaryNavLabel={copy.header.primaryNav}
              showLocaleSwitcher={hasLocaleSwitcher}
            />
          </div>
        </div>
      </div>
    </header>
    <main class={pageShellClass} data-pagefind-body={pagefind ? true : undefined}>
      <slot />
    </main>
    {hasNewsletter ? (
      <section class="mt-4" aria-label={copy.footer.newsletterTitle}>
        <div class={cn(ui.blogFrame, 'py-8 md:py-10')}>
          <div
            class={cn(
              ui.panel,
              ui.spotlightPanel,
              'justify-items-center overflow-hidden px-5 py-5 text-center md:px-6 md:py-6',
            )}
          >
            <div class="grid justify-items-center gap-2">
              <h2 class="m-0 text-[1.08rem] font-semibold leading-[1.3] text-site-ink lg:text-[1.22rem]">
                {copy.footer.newsletterTitle}
              </h2>
              <p class={cn(ui.bodyCopy, 'max-w-152')}>
                {copy.footer.newsletterCopy}
              </p>
            </div>
            <form
              action={newsletterFormAction}
              class="mx-auto w-full max-w-lg"
              method="post"
            >
              <label class="sr-only" for={layoutDomHooks.newsletterEmail.id}>Email</label>
              <div class="flex h-12 w-full overflow-hidden rounded-xs border border-site-line bg-site-bg transition-colors duration-150 focus-within:border-site-link-hover">
                <div class="relative min-w-0 flex-1">
                  <MailIcon class="pointer-events-none absolute left-4 top-1/2 size-4 -translate-y-1/2 text-site-ink-muted" />
                  <input
                    autocomplete="email"
                    class="h-full w-full border-0 bg-transparent pr-4 pl-11 text-[0.98rem] text-site-ink outline-none placeholder:text-site-ink-muted"
                    id={layoutDomHooks.newsletterEmail.id}
                    name="email"
                    placeholder={copy.footer.newsletterInputPlaceholder}
                    required
                    type="email"
                  />
                </div>
                <button
                  class="inline-flex h-full shrink-0 items-center justify-center border-l border-site-line-strong bg-site-hover px-4 text-sm font-semibold tracking-[0.04em] text-site-link-hover transition-colors duration-150 hover:border-site-link-hover hover:bg-site-surface-strong hover:text-site-ink focus-visible:outline-none"
                  type="submit"
                >
                  {copy.footer.newsletterSubmitLabel}
                </button>
              </div>
              <input name="EMAIL" type="hidden" value="" {...getDataHookAttributes(layoutDomHooks.newsletterMirror)} />
              <p class="mt-3 mb-0 text-center text-[0.76rem] leading-5 text-site-ink-muted lg:text-[0.82rem]">
                {copy.footer.newsletterDisclaimerBeforeLinks}
                <a class="underline decoration-site-line-strong underline-offset-2 transition-colors duration-150 hover:text-site-link-hover" href={termsHref}>
                  {copy.footer.terms}
                </a>
                {copy.footer.newsletterDisclaimerBetweenLinks}
                <a class="underline decoration-site-line-strong underline-offset-2 transition-colors duration-150 hover:text-site-link-hover" href={privacyHref}>
                  {copy.footer.privacy}
                </a>
                {copy.footer.newsletterDisclaimerAfterLinks}
              </p>
            </form>
          </div>
        </div>
      </section>
    ) : null}
    <footer class="border-t-2 border-site-line-strong bg-site-surface">
      <div class={cn(ui.blogFrame, 'grid gap-6 py-10')}>
        <div class="grid gap-8 md:grid-cols-[minmax(0,1.5fr)_minmax(12rem,1fr)_minmax(12rem,1fr)]">
          <div class="grid content-start gap-3">
            <a class={brandLinkClass} href={homeHref}>
              <span class={brandIconWrapClass}>
                <BrandIcon className={brandIconClass} />
              </span>
              <span class={brandLabelClass}>{copy.header.brand}</span>
            </a>
            <p class="m-0 max-w-120 leading-7 text-site-ink-soft">{copy.footer.description}</p>
          </div>
          <div class="grid content-start gap-3">
            <div class="grid gap-[0.85rem]">
              {exploreLinks.map((link) => (
                <a class={ui.footerLink} href={link.href}>{link.label}</a>
              ))}
            </div>
          </div>
          <div class="grid content-start gap-3">
            <div class="grid gap-[0.85rem]">
              <a class={ui.footerLink} href={termsHref}>{copy.footer.terms}</a>
              {exploreLinks.some((link) => link.pageType === 'articles') ? <a class={ui.footerLink} href={rssHref}>{copy.footer.rss}</a> : null}
              <a class={ui.footerLink} href={privacyHref}>{copy.footer.privacy}</a>
            </div>
          </div>
        </div>
      </div>
      <div class="border-t-2 border-site-line-strong bg-site-surface text-center">
        <div class={cn(ui.blogFrame, 'py-4')}>
          <p class="m-0 text-sm leading-[1.3] text-site-ink lg:text-[0.96rem]">© {currentYear} {copy.footer.title}. {copy.footer.rights}</p>
        </div>
      </div>
    </footer>
    <script
      data-completed-articles-changed-event={siteEvents.completedArticlesChanged}
      data-completed-articles-key={siteStorageKeys.completedArticles}
      data-mobile-complete-text-attr={completionDomHooks.mobileCompleteText.attr}
      data-mobile-default-text-attr={completionDomHooks.mobileDefaultText.attr}
      data-completion-item-attr={completionDomHooks.item.attr}
      data-newsletter-email-id={layoutDomHooks.newsletterEmail.id}
      data-newsletter-mirror-attr={layoutDomHooks.newsletterMirror.attr}
      is:inline
    >
      const currentScript = document.currentScript
      const completedArticlesChangedEvent =
        currentScript instanceof HTMLScriptElement ? currentScript.dataset.completedArticlesChangedEvent ?? '' : ''
      const completedArticlesKey =
        currentScript instanceof HTMLScriptElement ? currentScript.dataset.completedArticlesKey ?? '' : ''
      const completionItemAttr =
        currentScript instanceof HTMLScriptElement ? currentScript.dataset.completionItemAttr ?? '' : ''
      const mobileCompleteTextAttr =
        currentScript instanceof HTMLScriptElement ? currentScript.dataset.mobileCompleteTextAttr ?? '' : ''
      const mobileDefaultTextAttr =
        currentScript instanceof HTMLScriptElement ? currentScript.dataset.mobileDefaultTextAttr ?? '' : ''
      const newsletterEmailId =
        currentScript instanceof HTMLScriptElement ? currentScript.dataset.newsletterEmailId ?? '' : ''
      const newsletterMirrorAttr =
        currentScript instanceof HTMLScriptElement ? currentScript.dataset.newsletterMirrorAttr ?? '' : ''
      const dismissableDetailsSelector = 'details[data-dismiss-on-outside="true"][open]'

      const readCompletedArticles = () => {
        try {
          const rawValue = window.localStorage.getItem(completedArticlesKey)

          if (!rawValue) {
            return []
          }

          const parsedValue = JSON.parse(rawValue)
          return Array.isArray(parsedValue) ? parsedValue.filter((value) => typeof value === 'string') : []
        } catch {
          return []
        }
      }

      const syncCompletedArticleCards = (completedArticleIds) => {
        const completedSet = new Set(completedArticleIds)
        const selector = `[${completionItemAttr}]`

        document.querySelectorAll(selector).forEach((card) => {
          const articleId = card.getAttribute(completionItemAttr)
          const isComplete = Boolean(articleId && completedSet.has(articleId))
          card.classList.toggle('is-complete', isComplete)

          const mobileDefaultText = mobileDefaultTextAttr ? card.querySelector(`[${mobileDefaultTextAttr}]`) : null
          const mobileCompleteText = mobileCompleteTextAttr ? card.querySelector(`[${mobileCompleteTextAttr}]`) : null

          if (mobileDefaultText instanceof HTMLElement) {
            mobileDefaultText.classList.toggle('hidden', isComplete)
            mobileDefaultText.classList.toggle('inline-flex', !isComplete)
          }

          if (mobileCompleteText instanceof HTMLElement) {
            mobileCompleteText.classList.toggle('hidden', !isComplete)
            mobileCompleteText.classList.toggle('inline-flex', isComplete)
          }
        })
      }

      const syncNewsletterEmail = () => {
        const newsletterEmailInput = document.getElementById(newsletterEmailId)
        const newsletterEmailMirror = document.querySelector(`[${newsletterMirrorAttr}]`)

        if (!(newsletterEmailInput instanceof HTMLInputElement) || !(newsletterEmailMirror instanceof HTMLInputElement)) {
          return
        }

        newsletterEmailMirror.value = newsletterEmailInput.value
      }

      const emitCompletedArticles = () => {
        syncCompletedArticleCards(readCompletedArticles())
      }

      const closeDismissableDetailsOutside = (target) => {
        if (!(target instanceof Node)) {
          return
        }

        document.querySelectorAll(dismissableDetailsSelector).forEach((detailsElement) => {
          if (!(detailsElement instanceof HTMLDetailsElement)) {
            return
          }

          if (!detailsElement.contains(target)) {
            detailsElement.removeAttribute('open')
          }
        })
      }

      const handleNewsletterInput = (event) => {
        if (!(event.target instanceof HTMLInputElement) || event.target.id !== newsletterEmailId) {
          return
        }

        syncNewsletterEmail()
      }

      syncNewsletterEmail()
      emitCompletedArticles()

      document.addEventListener('input', handleNewsletterInput)
      document.addEventListener('pointerdown', (event) => {
        closeDismissableDetailsOutside(event.target)
      })
      window.addEventListener(completedArticlesChangedEvent, emitCompletedArticles)
      window.addEventListener('storage', (event) => {
        if (event.key === completedArticlesKey) {
          emitCompletedArticles()
        }
      })
    </script>
  </body>
</html>
