---
import '../styles/global.css'

import { getAppHref } from '../lib/app-links'

type Props = {
  description: string
  title: string
}

const {
  description,
  title,
} = Astro.props

const pageTitle = `${title} | Prepdeck`
const pathname = Astro.url.pathname

function getNavClass(href: string) {
  const isActive =
    href === '/'
      ? pathname === '/'
      : pathname === href || pathname.startsWith(`${href}/`)

  return isActive ? 'site-nav__link site-nav__link--active' : 'site-nav__link'
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    <title>{pageTitle}</title>
    <meta content={description} name="description" />
    <meta content={pageTitle} property="og:title" />
    <meta content={description} property="og:description" />
    <meta content="website" property="og:type" />
    <meta content="summary_large_image" name="twitter:card" />
    <meta content={pageTitle} name="twitter:title" />
    <meta content={description} name="twitter:description" />
    <script is:inline>
      try {
        const storedTheme = window.localStorage.getItem('prepdeck.site.theme.v1')
        document.documentElement.classList.toggle('dark', storedTheme !== 'light')
      } catch {}
    </script>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="site-header__inner">
          <div class="site-brand">
            <a class="site-brand__eyebrow" href="/">Prepdeck</a>
            <div class="site-brand__summary">
              Short guides, practical checklists, and follow-up practice for technical growth.
            </div>
          </div>
          <nav class="site-nav">
            <a class={getNavClass('/')} href="/">Home</a>
            <a class={getNavClass('/blog')} href="/blog">Guides</a>
            <a class={getNavClass('/map')} href="/map">Map</a>
            <a class="site-nav__link" href={getAppHref('/')}>Practice</a>
            <button class="site-theme-toggle" data-theme-toggle type="button">
              <span data-theme-label>Dark</span>
            </button>
          </nav>
        </div>
      </header>
      <slot />
      <footer class="site-footer">
        Read, practice, repeat.
      </footer>
    </div>
  </body>
</html>

<script is:inline>
  const themeButton = document.querySelector('[data-theme-toggle]')
  const themeLabel = document.querySelector('[data-theme-label]')

  const syncThemeLabel = () => {
    const isDark = document.documentElement.classList.contains('dark')
    if (themeLabel) {
      themeLabel.textContent = isDark ? 'Dark' : 'Light'
    }
  }

  syncThemeLabel()

  themeButton?.addEventListener('click', () => {
    const nextIsDark = !document.documentElement.classList.contains('dark')
    document.documentElement.classList.toggle('dark', nextIsDark)
    try {
      window.localStorage.setItem('prepdeck.site.theme.v1', nextIsDark ? 'dark' : 'light')
    } catch {}
    syncThemeLabel()
  })
</script>
