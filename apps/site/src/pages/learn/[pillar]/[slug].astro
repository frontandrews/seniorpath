---
import { getCollection } from 'astro:content'

import { getGuideCanonicalParams } from '@/lib/guide-taxonomy'

export async function getStaticPaths() {
  const posts = (await getCollection('guides')).filter(
    (post) => post.data.locale === 'en' && post.data.status !== 'archived',
  )

  return posts.flatMap((post) => {
    const params = getGuideCanonicalParams(post)

    if (!params) {
      return []
    }

    return [
      {
        params,
        props: {
          post,
        },
      },
    ]
  })
}
return Astro.redirect(`/articles/${Astro.params.pillar}/${Astro.params.slug}`, 301)
---
