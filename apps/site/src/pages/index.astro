---
import { getCollection } from 'astro:content'

import GuideTreeNode from '../components/GuideTreeNode.astro'
import BaseLayout from '../layouts/BaseLayout.astro'
import { getAppHref } from '../lib/app-links'
import { buildGuideTree } from '../lib/guide-tree'

const posts = await getCollection('blog')
const guideTree = buildGuideTree(posts)
---

<BaseLayout
  description="A tree-style index of guides for programming, AI engineering, communication, and leadership."
  title="Guide map"
>
  <section class="hero">
    <div class="hero__grid">
      <div>
        <div class="hero__badges">
          <span class="badge badge--accent">Guide map</span>
          <span class="badge">{posts.length} guides</span>
          <span class="badge">{guideTree.length} categories</span>
        </div>
        <h1>Browse the map. Open what matters. Practice right after.</h1>
        <p>
          Scan the tree, open the guide you need, then use practice when you want to
          validate the topic instead of just reading it once.
        </p>
        <div class="meta-list">
          <a class="button-link button-link--primary" href={getAppHref('/')}>Open practice</a>
          <a class="button-link" href="/map">Connection map</a>
          <a class="button-link" href="/blog">Flat guide list</a>
        </div>
      </div>

      <div class="panel">
        <p class="section-eyebrow">How to use it</p>
        <ul class="article-prose compact-list">
          <li>Filter one or more categories.</li>
          <li>Open the guide that matches your current gap.</li>
          <li>Use Test when you want to validate the topic inside the app.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <p class="section-eyebrow">Tree navigation</p>
        <h2 class="section-heading">Everything available right now</h2>
        <p class="section-copy">
          One tree for the current learning paths, grouped by primary category and nested
          sub-category.
        </p>
      </div>
    </div>

    <div class="panel tree-controls">
      <div class="tree-controls__header">
        <p class="section-eyebrow">Filter by category</p>
        <div class="meta-list">
          <button class="guide-filter-chip" data-tree-action="expand-all" type="button">
            Expand all
          </button>
          <button class="guide-filter-chip" data-tree-action="collapse-all" type="button">
            Collapse all
          </button>
        </div>
      </div>
      <div class="meta-list">
        {guideTree.map((node) => (
          <button class="guide-filter-chip" data-tree-filter={node.label} type="button">
            {node.label}
          </button>
        ))}
      </div>
    </div>

    <ul class="guide-tree guide-tree--root">
      {guideTree.map((node) => (
        <GuideTreeNode node={node} />
      ))}
    </ul>
  </section>
</BaseLayout>

<script is:inline>
  const treeDetails = [...document.querySelectorAll('[data-guide-tree-details]')]
  const rootNodes = [...document.querySelectorAll('[data-guide-node]')]
  const categoryButtons = [...document.querySelectorAll('[data-tree-filter]')]
  const activeCategories = new Set()
  const completedGuides = (() => {
    try {
      return new Set(JSON.parse(window.localStorage.getItem('prepdeck.site.completed-guides.v1') || '[]'))
    } catch {
      return new Set()
    }
  })()

  const syncGuideProgress = () => {
    rootNodes.forEach((node) => {
      const ids = (node.getAttribute('data-guide-post-ids') || '').split(',').filter(Boolean)
      const completed = ids.filter((id) => completedGuides.has(id)).length
      const progress = node.querySelector('[data-guide-progress]')

      if (progress) {
        progress.textContent = `${completed}/${ids.length}`
        progress.classList.toggle('badge--complete', completed === ids.length && ids.length > 0)
      }
    })

    document.querySelectorAll('[data-guide-post]').forEach((post) => {
      const id = post.getAttribute('data-guide-post')
      post.classList.toggle('guide-tree__post--complete', Boolean(id && completedGuides.has(id)))
    })
  }

  const applyTreeFilter = () => {
    const hasFilter = activeCategories.size > 0

    rootNodes.forEach((node) => {
      const label = node.querySelector(':scope > details > summary .guide-tree__label, :scope > .guide-tree__branch .guide-tree__label')?.textContent?.trim()
      const shouldShow = !hasFilter || (label && activeCategories.has(label))
      node.toggleAttribute('hidden', !shouldShow)
    })
  }

  document.querySelector('[data-tree-action="expand-all"]')?.addEventListener('click', () => {
    treeDetails.forEach((detail) => detail.setAttribute('open', ''))
  })

  document.querySelector('[data-tree-action="collapse-all"]')?.addEventListener('click', () => {
    treeDetails.forEach((detail) => detail.removeAttribute('open'))
  })

  categoryButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const value = button.getAttribute('data-tree-filter')

      if (!value) {
        return
      }

      if (activeCategories.has(value)) {
        activeCategories.delete(value)
      } else {
        activeCategories.add(value)
      }

      button.classList.toggle('guide-filter-chip--active', activeCategories.has(value))
      applyTreeFilter()
    })
  })

  syncGuideProgress()
  applyTreeFilter()
</script>
