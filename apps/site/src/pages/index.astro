---
import { getCollection } from 'astro:content'

import GuideTreeNode from '../components/GuideTreeNode.astro'
import BaseLayout from '../layouts/BaseLayout.astro'
import { buildGuideTree } from '../lib/guide-tree'

const posts = (await getCollection('guides')).filter(
  (post) => post.data.status !== 'archived' && post.data.locale === 'en',
)
const guideTree = buildGuideTree(posts)
const filterTones = ['#dbeafe', '#dbe4ff', '#e2e8f0', '#e0f2fe', '#ede9fe', '#e2f2ea']
---

<BaseLayout
  description="The Path to Senior: a structured learning journey for mid-level developers leveling up through deeper concepts and interview practice."
  title="Path to Senior"
>
  <section class="section section--compact">
    <div class="panel page-toolbar">
      <div class="page-toolbar__intro">
        <h1 class="section-heading section-heading--compact">Path to Senior</h1>
        <p class="page-toolbar__copy">Learn for free. Practice when you want to prove you really got it.</p>
      </div>
    </div>

    <div class="tree-controls tree-controls--compact">
        <p class="section-eyebrow">Filter by category</p>
        <div class="meta-list">
        {guideTree.map((node, index) => (
          <button
            class="guide-filter-chip"
            data-tree-filter={node.label}
            style={`--chip-accent: ${filterTones[index % filterTones.length]};`}
            type="button"
          >
            {node.label}
          </button>
        ))}
      </div>
    </div>

    <ul class="guide-tree guide-tree--root">
      {guideTree.map((node) => (
        <GuideTreeNode node={node} />
      ))}
    </ul>
  </section>
</BaseLayout>

<script is:inline>
  const rootNodes = [...document.querySelectorAll('.guide-tree--root > [data-guide-node]')]
  const categoryButtons = [...document.querySelectorAll('[data-tree-filter]')]
  const activeCategories = new Set()
  const completedGuides = (() => {
    try {
      return new Set(JSON.parse(window.localStorage.getItem('prepdeck.site.completed-guides.v1') || '[]'))
    } catch {
      return new Set()
    }
  })()

  const syncCompletedPosts = () => {
    document.querySelectorAll('[data-guide-post]').forEach((post) => {
      const id = post.getAttribute('data-guide-post')
      post.classList.toggle('guide-tree__post--complete', Boolean(id && completedGuides.has(id)))
    })
  }

  const applyTreeFilter = () => {
    const hasFilter = activeCategories.size > 0

    rootNodes.forEach((node) => {
      const label = node.querySelector(':scope > .guide-tree__branch > .guide-tree__label-row .guide-tree__label')?.textContent?.trim()
      const shouldShow = !hasFilter || (label && activeCategories.has(label))
      node.toggleAttribute('hidden', !shouldShow)
    })
  }

  categoryButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const value = button.getAttribute('data-tree-filter')

      if (!value) {
        return
      }

      if (activeCategories.has(value)) {
        activeCategories.delete(value)
      } else {
        activeCategories.add(value)
      }

      button.classList.toggle('guide-filter-chip--active', activeCategories.has(value))
      applyTreeFilter()
    })
  })

  syncCompletedPosts()
  applyTreeFilter()
</script>
