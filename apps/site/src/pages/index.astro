---
import { getCollection } from 'astro:content'

import GuideTreeNode from '../components/GuideTreeNode.astro'
import BaseLayout from '../layouts/BaseLayout.astro'
import { getAppHref } from '../lib/app-links'
import { buildGuideTree } from '../lib/guide-tree'

const posts = await getCollection('blog')
const guideTree = buildGuideTree(posts)
const rootAreas = guideTree.length

function getNodeHref(key: string) {
  return `#guide-node-${key.toLowerCase().replaceAll(/[^a-z0-9]+/g, '-')}`
}
---

<BaseLayout
  description="A tree-style index of guides for programming, AI engineering, communication, and leadership."
  title="Guide map"
>
  <section class="hero">
    <div class="hero__grid">
      <div>
        <div class="hero__badges">
          <span class="badge badge--accent">Guide map</span>
          <span class="badge">{posts.length} guides</span>
          <span class="badge">{rootAreas} root areas</span>
        </div>
        <h1>Browse the map. Open what matters. Practice right after.</h1>
        <p>
          Prepdeck works better when the content is easy to scan. Start from the tree,
          open one guide, then jump into practice when you want to rehearse the topic.
        </p>
        <div class="meta-list">
          <a class="button-link button-link--primary" href={getAppHref('/')}>Open practice</a>
          <a class="button-link" href="/map">Connection map</a>
          <a class="button-link" href="/blog">Flat guide list</a>
        </div>
      </div>

      <div class="panel">
        <p class="section-eyebrow">How to use it</p>
        <ul class="article-prose compact-list">
          <li>Pick a main area first.</li>
          <li>Drill into the sub-area that matches your current gap.</li>
          <li>Open the guide, then practice the linked deck if one exists.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <p class="section-eyebrow">Tree navigation</p>
        <h2 class="section-heading">Everything available right now</h2>
        <p class="section-copy">
          One home for the current reading paths, grouped by primary category and nested
          sub-category.
        </p>
      </div>
    </div>

    <div class="panel tree-controls">
      <div class="tree-controls__header">
        <p class="section-eyebrow">Jump to area</p>
        <div class="meta-list">
          <button class="guide-filter-chip" data-tree-action="expand-all" type="button">
            Expand all
          </button>
          <button class="guide-filter-chip" data-tree-action="collapse-all" type="button">
            Collapse all
          </button>
        </div>
      </div>
      <div class="meta-list">
        {guideTree.map((node) => (
          <a class="guide-filter-chip" href={getNodeHref(node.key)}>{node.label}</a>
        ))}
      </div>
    </div>

    <ul class="guide-tree guide-tree--root">
      {guideTree.map((node) => (
        <GuideTreeNode node={node} />
      ))}
    </ul>
  </section>
</BaseLayout>

<script is:inline>
  const treeDetails = [...document.querySelectorAll('[data-guide-tree-details]')]

  document.querySelector('[data-tree-action="expand-all"]')?.addEventListener('click', () => {
    treeDetails.forEach((detail) => detail.setAttribute('open', ''))
  })

  document.querySelector('[data-tree-action="collapse-all"]')?.addEventListener('click', () => {
    treeDetails.forEach((detail) => detail.removeAttribute('open'))
  })
</script>
