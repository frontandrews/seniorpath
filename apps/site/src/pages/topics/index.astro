---
import { getCollection } from 'astro:content'

import TopicIndexPage from '@/components/TopicIndexPage.astro'
import { getAvailableTopics, getTopicGuides } from '@/lib/topic-taxonomy'

const posts = await getCollection('guides')
const topics = getAvailableTopics(posts, 'en').map((topic) => ({
  count: getTopicGuides(posts, topic.id, 'en').length,
  topic,
}))
---

<TopicIndexPage locale="en" topics={topics} />
