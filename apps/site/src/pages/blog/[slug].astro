---
import type { CollectionEntry } from 'astro:content'
import { getCollection, render } from 'astro:content'
import { getDeckSummaryById } from '@prepdeck/content/manifest'
import { getTopicLabel } from '@prepdeck/content'

import BaseLayout from '../../layouts/BaseLayout.astro'
import { getAppHref } from '../../lib/app-links'
import { sortGuides } from '../../lib/guide-tree'

export async function getStaticPaths() {
  const posts = await getCollection('blog')

  return posts.map((post) => ({
    params: {
      slug: post.id,
    },
    props: {
      post,
    },
  }))
}

type Props = {
  post: CollectionEntry<'blog'>
}

const { post } = Astro.props
const { Content } = await render(post)
const allPosts = sortGuides(await getCollection('blog'))
const parentPathKey = post.data.path.slice(0, -1).join('>')
const relatedDecks = post.data.relatedDeckIds
  .map((deckId) => getDeckSummaryById(deckId))
  .filter((deck): deck is NonNullable<typeof deck> => Boolean(deck))
const connectedPosts = allPosts.filter((entry) => {
  if (entry.id === post.id) {
    return false
  }

  return post.data.relationships.includes(entry.id)
})
const relatedPosts = allPosts
  .filter((entry) => {
    if (entry.id === post.id) {
      return false
    }

    if (post.data.relationships.includes(entry.id)) {
      return false
    }

    const sharesTopic = entry.data.topic && entry.data.topic === post.data.topic
    const sharesTag = entry.data.tags.some((tag) => post.data.tags.includes(tag))

    return Boolean(sharesTopic || sharesTag)
  })
  .slice(0, 2)
const siblingPosts = allPosts
  .filter((entry) => {
    if (entry.id === post.id) {
      return false
    }

    return entry.data.path.slice(0, -1).join('>') === parentPathKey
  })
  .slice(0, 3)
const currentIndex = allPosts.findIndex((entry) => entry.id === post.id)
const previousPost = currentIndex >= 0 ? allPosts[currentIndex + 1] ?? null : null
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] ?? null : null
const nextReads = [...new Map(
  [nextPost, previousPost, ...connectedPosts, ...siblingPosts, ...relatedPosts]
    .filter((entry): entry is NonNullable<typeof entry> => Boolean(entry))
    .filter((entry) => entry.id !== post.id)
    .map((entry) => [entry.id, entry]),
).values()].slice(0, 3)
const primaryDeck = relatedDecks[0] ?? null
const articleKicker = post.data.topic && post.data.topic !== post.data.category
  ? `${post.data.category} / ${post.data.topic}`
  : post.data.category
const articlePath = post.data.path[0] === post.data.category
  ? post.data.path.slice(1)
  : post.data.path
---

<BaseLayout description={post.data.description} title={post.data.title}>
  <article class="article-shell">
    <header class="article-header">
      <p class="article-kicker">{articleKicker}</p>
      {articlePath.length > 0 ? <p class="article-path">{articlePath.join(' / ')}</p> : null}
      <h1 class="article-title">{post.data.title}</h1>
      <p class="article-excerpt">{post.data.description}</p>
      <div class="article-author-row">
        <div class="article-author-avatar" aria-hidden="true">AR</div>
        <div class="article-author-copy">
          <p class="article-author-name">Andrews Ribeiro</p>
          <p class="article-author-meta">
            {post.data.pubDate.toLocaleDateString('en-US', {
              day: 'numeric',
              month: 'long',
              year: 'numeric',
            })}
            {post.data.updatedDate
              ? ` · Updated ${post.data.updatedDate.toLocaleDateString('en-US', {
                  day: 'numeric',
                  month: 'short',
                  year: 'numeric',
                })}`
              : ''}
          </p>
        </div>
      </div>
      <div class="meta-list article-header-actions">
        {primaryDeck ? (
          <a class="button-link button-link--primary" href={getAppHref(`/decks/${primaryDeck.id}`)}>
            Practice
          </a>
        ) : null}
        <button class="button-link" data-guide-complete-toggle data-guide-id={post.id} type="button">
          Mark as completed
        </button>
      </div>
      {post.data.tags.length > 0 ? (
        <div class="meta-list article-tags">
          {post.data.tags.map((tag) => (
            <span class="badge">{tag}</span>
          ))}
        </div>
      ) : null}
    </header>

    {(post.data.takeaways.length > 0 || post.data.practiceChecklist.length > 0) ? (
      <section class="article-section article-section--summary">
        <div class="panel-grid panel-grid--summary">
          {post.data.takeaways.length > 0 ? (
            <div class="panel article-related-card">
              <div>
                <p class="section-eyebrow">Quick summary</p>
                <h2 class="section-heading section-heading--compact">What to keep in your head</h2>
              </div>
              <ul class="article-prose compact-list">
                {post.data.takeaways.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            </div>
          ) : null}

          {post.data.practiceChecklist.length > 0 ? (
            <div class="panel article-related-card">
              <div>
                <p class="section-eyebrow">Practice checklist</p>
                <h2 class="section-heading section-heading--compact">Use this when you answer</h2>
              </div>
              <ul class="article-prose compact-list">
                {post.data.practiceChecklist.map((step) => (
                  <li>{step}</li>
                ))}
              </ul>
            </div>
          ) : null}
        </div>
      </section>
    ) : null}

    <div class="article-prose">
      <Content />
    </div>

    {relatedDecks.length > 0 ? (
      <section class="article-section">
        <div class="section-header">
          <div>
            <p class="section-eyebrow">Practice in the app</p>
            <h2 class="section-heading section-heading--compact">Turn this idea into reps</h2>
          </div>
        </div>
        <div class="panel-grid">
          {relatedDecks.map((deck) => (
            <div class="panel article-related-card">
              <div class="meta-list">
                <span class="badge badge--accent">{getTopicLabel(deck.topic)}</span>
                <span class="badge">{deck.cardCount} cards</span>
                <span class="badge">{deck.estimatedMinutes} min</span>
              </div>
              <div>
                <h3>{deck.title}</h3>
                <p class="article-excerpt">{deck.description}</p>
              </div>
              <a class="button-link button-link--primary" href={getAppHref(`/decks/${deck.id}`)}>
                Practice
              </a>
            </div>
          ))}
        </div>
      </section>
    ) : null}

    {nextReads.length > 0 ? (
      <section class="article-section">
        <div class="section-header">
          <div>
            <h2 class="section-heading section-heading--compact">Next reads</h2>
          </div>
        </div>
        <div class="panel-grid panel-grid--summary">
          {nextReads.map((entry) => (
            <a class="panel next-read-card" href={`/blog/${entry.id}`}>
              <h3>{entry.data.title}</h3>
              <p class="article-excerpt">{entry.data.summary}</p>
            </a>
          ))}
        </div>
      </section>
    ) : null}
  </article>

  <dialog class="confirm-dialog" data-guide-complete-dialog>
    <div class="confirm-dialog__content">
      <h2 class="section-heading section-heading--compact" data-guide-dialog-title>Mark this guide as completed?</h2>
      <p class="section-copy" data-guide-dialog-copy>
        When you mark this as complete, it will stop showing up in suggestions. You can still practice the topic later. Do you want to continue?
      </p>
      <div class="meta-list confirm-dialog__actions">
        <button class="button-link button-link--primary" data-guide-complete-confirm type="button">
          Yes, continue
        </button>
        <button class="button-link" data-guide-complete-cancel type="button">
          Cancel
        </button>
      </div>
    </div>
  </dialog>
</BaseLayout>

<script is:inline>
  const guideId = document.querySelector('[data-guide-complete-toggle]')?.getAttribute('data-guide-id')
  const completeButton = document.querySelector('[data-guide-complete-toggle]')
  const completeDialog = document.querySelector('[data-guide-complete-dialog]')
  const confirmButton = document.querySelector('[data-guide-complete-confirm]')
  const cancelButton = document.querySelector('[data-guide-complete-cancel]')
  const dialogTitle = document.querySelector('[data-guide-dialog-title]')
  const dialogCopy = document.querySelector('[data-guide-dialog-copy]')

  const readCompletedGuides = () => {
    try {
      return new Set(JSON.parse(window.localStorage.getItem('prepdeck.site.completed-guides.v1') || '[]'))
    } catch {
      return new Set()
    }
  }

  const writeCompletedGuides = (set) => {
    window.localStorage.setItem('prepdeck.site.completed-guides.v1', JSON.stringify([...set]))
  }

  const syncCompleteButton = () => {
    const completed = readCompletedGuides()
    const isComplete = Boolean(guideId && completed.has(guideId))

    if (completeButton) {
      completeButton.textContent = isComplete ? 'Completed' : 'Mark as completed'
      completeButton.classList.toggle('button-link--primary', isComplete)
    }
  }

  const updateGuideCompletion = (nextComplete) => {
    if (!guideId) {
      return
    }

    const completed = readCompletedGuides()

    if (nextComplete) {
      completed.add(guideId)
    } else {
      completed.delete(guideId)
    }

    writeCompletedGuides(completed)
    syncCompleteButton()
  }

  completeButton?.addEventListener('click', () => {
    if (!guideId || !(completeDialog instanceof HTMLDialogElement)) {
      return
    }

    const completed = readCompletedGuides()
    const isComplete = completed.has(guideId)

    if (dialogTitle) {
      dialogTitle.textContent = isComplete ? 'Mark this guide as incomplete?' : 'Mark this guide as completed?'
    }

    if (dialogCopy) {
      dialogCopy.textContent = isComplete
        ? 'When you remove the completed state, this guide can appear in suggestions again. You can still keep reading or practice it later. Do you want to continue?'
        : 'When you mark this as complete, it will stop showing up in suggestions. You can still practice the topic later. Do you want to continue?'
    }

    confirmButton?.setAttribute('data-next-complete', isComplete ? 'false' : 'true')
    completeDialog.showModal()
  })

  confirmButton?.addEventListener('click', () => {
    if (!(completeDialog instanceof HTMLDialogElement)) {
      return
    }

    updateGuideCompletion(confirmButton.getAttribute('data-next-complete') !== 'false')
    completeDialog.close()
  })

  cancelButton?.addEventListener('click', () => {
    if (completeDialog instanceof HTMLDialogElement) {
      completeDialog.close()
    }
  })

  syncCompleteButton()
</script>
