---
import type { CollectionEntry } from 'astro:content'
import { getCollection, render } from 'astro:content'
import { getDeckSummaryById } from '@prepdeck/content/manifest'

import BaseLayout from '../../layouts/BaseLayout.astro'
import ArticleCard from '../../components/ArticleCard.astro'
import { getAppHref } from '../../lib/app-links'

export async function getStaticPaths() {
  const posts = await getCollection('blog')

  return posts.map((post) => ({
    params: {
      slug: post.id,
    },
    props: {
      post,
    },
  }))
}

type Props = {
  post: CollectionEntry<'blog'>
}

const { post } = Astro.props
const { Content } = await render(post)
const relatedDecks = post.data.relatedDeckIds
  .map((deckId) => getDeckSummaryById(deckId))
  .filter((deck): deck is NonNullable<typeof deck> => Boolean(deck))
const relatedPosts = (await getCollection('blog'))
  .filter((entry) => {
    if (entry.id === post.id) {
      return false
    }

    const sharesTopic = entry.data.topic && entry.data.topic === post.data.topic
    const sharesTag = entry.data.tags.some((tag) => post.data.tags.includes(tag))

    return Boolean(sharesTopic || sharesTag)
  })
  .slice(0, 2)
---

<BaseLayout description={post.data.description} title={post.data.title}>
  <article class="article-shell">
    <header class="article-header">
      <div class="meta-list">
        <span class="badge badge--accent">{post.data.topic ?? 'Article'}</span>
        {post.data.tags.map((tag) => (
          <span class="badge">{tag}</span>
        ))}
      </div>
      <h1 class="article-title">{post.data.title}</h1>
      <p class="article-excerpt">{post.data.description}</p>
      <div class="meta-list">
        <span class="badge">
          {post.data.pubDate.toLocaleDateString('en-US', {
            day: 'numeric',
            month: 'long',
            year: 'numeric',
          })}
        </span>
        {post.data.updatedDate ? (
          <span class="badge">
            Updated {post.data.updatedDate.toLocaleDateString('en-US', {
              day: 'numeric',
              month: 'short',
              year: 'numeric',
            })}
          </span>
        ) : null}
      </div>
    </header>

    <div class="article-prose">
      <Content />
    </div>

    {relatedDecks.length > 0 ? (
      <section class="article-section">
        <div class="section-header">
          <div>
            <p class="section-eyebrow">Open in Prepdeck</p>
            <h2 class="section-heading section-heading--compact">Keep practicing inside the app</h2>
          </div>
        </div>
        <div class="panel-grid">
          {relatedDecks.map((deck) => (
            <div class="panel article-related-card">
              <div class="meta-list">
                <span class="badge badge--accent">{deck.topic}</span>
                <span class="badge">{deck.cardCount} cards</span>
                <span class="badge">{deck.estimatedMinutes} min</span>
              </div>
              <div>
                <h3>{deck.title}</h3>
                <p class="article-excerpt">{deck.description}</p>
              </div>
              <a class="button-link button-link--primary" href={getAppHref(`/decks/${deck.id}`)}>
                Open deck
              </a>
            </div>
          ))}
        </div>
      </section>
    ) : null}

    {relatedPosts.length > 0 ? (
      <section class="article-section">
        <div class="section-header">
          <div>
            <p class="section-eyebrow">Keep reading</p>
            <h2 class="section-heading section-heading--compact">More articles around this topic</h2>
          </div>
        </div>
        <div class="panel-grid panel-grid--articles">
          {relatedPosts.map((entry) => (
            <ArticleCard post={entry} />
          ))}
        </div>
      </section>
    ) : null}
  </article>
</BaseLayout>
