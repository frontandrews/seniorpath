---
import type { CollectionEntry } from 'astro:content'
import { getCollection, render } from 'astro:content'
import { getDeckSummaryById } from '@prepdeck/content/manifest'
import { getTopicLabel } from '@prepdeck/content'

import BaseLayout from '../../layouts/BaseLayout.astro'
import ArticleCard from '../../components/ArticleCard.astro'
import { getAppHref } from '../../lib/app-links'
import { sortGuides } from '../../lib/guide-tree'

export async function getStaticPaths() {
  const posts = await getCollection('blog')

  return posts.map((post) => ({
    params: {
      slug: post.id,
    },
    props: {
      post,
    },
  }))
}

type Props = {
  post: CollectionEntry<'blog'>
}

const { post } = Astro.props
const { Content } = await render(post)
const allPosts = sortGuides(await getCollection('blog'))
const parentPathKey = post.data.path.slice(0, -1).join('>')
const relatedDecks = post.data.relatedDeckIds
  .map((deckId) => getDeckSummaryById(deckId))
  .filter((deck): deck is NonNullable<typeof deck> => Boolean(deck))
const connectedPosts = allPosts.filter((entry) => {
  if (entry.id === post.id) {
    return false
  }

  return post.data.relationships.includes(entry.id)
})
const relatedPosts = allPosts
  .filter((entry) => {
    if (entry.id === post.id) {
      return false
    }

    if (post.data.relationships.includes(entry.id)) {
      return false
    }

    const sharesTopic = entry.data.topic && entry.data.topic === post.data.topic
    const sharesTag = entry.data.tags.some((tag) => post.data.tags.includes(tag))

    return Boolean(sharesTopic || sharesTag)
  })
  .slice(0, 2)
const siblingPosts = allPosts
  .filter((entry) => {
    if (entry.id === post.id) {
      return false
    }

    return entry.data.path.slice(0, -1).join('>') === parentPathKey
  })
  .slice(0, 3)
const currentIndex = allPosts.findIndex((entry) => entry.id === post.id)
const previousPost = currentIndex >= 0 ? allPosts[currentIndex + 1] ?? null : null
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] ?? null : null
---

<BaseLayout description={post.data.description} title={post.data.title}>
  <article class="article-shell">
    <header class="article-header">
      <div class="meta-list">
        <span class="badge badge--accent">{post.data.category}</span>
        {post.data.topic ? <span class="badge">{post.data.topic}</span> : null}
        {post.data.tags.map((tag) => (
          <span class="badge">{tag}</span>
        ))}
      </div>
      <div class="meta-list article-breadcrumbs">
        {post.data.path.map((segment) => (
          <span class="badge">{segment}</span>
        ))}
      </div>
      {connectedPosts.length > 0 ? (
        <div class="meta-list article-connections">
          <span class="badge badge--accent">Connected guides</span>
          {connectedPosts.map((entry) => (
            <a class="badge" href={`/blog/${entry.id}`}>{entry.data.title}</a>
          ))}
        </div>
      ) : null}
      <h1 class="article-title">{post.data.title}</h1>
      <p class="article-excerpt">{post.data.description}</p>
      <div class="meta-list">
        <a class="button-link" href="/">Open tree</a>
        <a class="button-link" href="/map">Open map</a>
      </div>
      <div class="meta-list">
        <span class="badge">
          {post.data.pubDate.toLocaleDateString('en-US', {
            day: 'numeric',
            month: 'long',
            year: 'numeric',
          })}
        </span>
        {post.data.updatedDate ? (
          <span class="badge">
            Updated {post.data.updatedDate.toLocaleDateString('en-US', {
              day: 'numeric',
              month: 'short',
              year: 'numeric',
            })}
          </span>
        ) : null}
      </div>
    </header>

    {(post.data.takeaways.length > 0 || post.data.practiceChecklist.length > 0) ? (
      <section class="article-section article-section--summary">
        <div class="panel-grid panel-grid--summary">
          {post.data.takeaways.length > 0 ? (
            <div class="panel article-related-card">
              <div>
                <p class="section-eyebrow">Quick summary</p>
                <h2 class="section-heading section-heading--compact">What to keep in your head</h2>
              </div>
              <ul class="article-prose compact-list">
                {post.data.takeaways.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            </div>
          ) : null}

          {post.data.practiceChecklist.length > 0 ? (
            <div class="panel article-related-card">
              <div>
                <p class="section-eyebrow">Practice checklist</p>
                <h2 class="section-heading section-heading--compact">Use this when you answer</h2>
              </div>
              <ul class="article-prose compact-list">
                {post.data.practiceChecklist.map((step) => (
                  <li>{step}</li>
                ))}
              </ul>
            </div>
          ) : null}
        </div>
      </section>
    ) : null}

    <div class="article-prose">
      <Content />
    </div>

    {connectedPosts.length > 0 ? (
      <section class="article-section">
        <div class="section-header">
          <div>
            <p class="section-eyebrow">Connections</p>
            <h2 class="section-heading section-heading--compact">Guides directly tied to this one</h2>
          </div>
        </div>
        <div class="panel-grid panel-grid--articles">
          {connectedPosts.map((entry) => (
            <ArticleCard post={entry} />
          ))}
        </div>
      </section>
    ) : null}

    {siblingPosts.length > 0 ? (
      <section class="article-section">
        <div class="section-header">
          <div>
            <p class="section-eyebrow">Same branch</p>
            <h2 class="section-heading section-heading--compact">Guides in the same path</h2>
          </div>
        </div>
        <div class="panel-grid panel-grid--articles">
          {siblingPosts.map((entry) => (
            <ArticleCard post={entry} />
          ))}
        </div>
      </section>
    ) : null}

    {relatedDecks.length > 0 ? (
      <section class="article-section">
        <div class="section-header">
          <div>
            <p class="section-eyebrow">Open in Prepdeck</p>
            <h2 class="section-heading section-heading--compact">Keep practicing inside the app</h2>
          </div>
        </div>
        <div class="panel-grid">
          {relatedDecks.map((deck) => (
            <div class="panel article-related-card">
              <div class="meta-list">
                <span class="badge badge--accent">{getTopicLabel(deck.topic)}</span>
                <span class="badge">{deck.cardCount} cards</span>
                <span class="badge">{deck.estimatedMinutes} min</span>
              </div>
              <div>
                <h3>{deck.title}</h3>
                <p class="article-excerpt">{deck.description}</p>
              </div>
              <a class="button-link button-link--primary" href={getAppHref(`/decks/${deck.id}`)}>
                Open deck
              </a>
            </div>
          ))}
        </div>
      </section>
    ) : null}

    {relatedPosts.length > 0 ? (
      <section class="article-section">
        <div class="section-header">
          <div>
            <p class="section-eyebrow">Keep reading</p>
            <h2 class="section-heading section-heading--compact">More guides around this area</h2>
          </div>
        </div>
        <div class="panel-grid panel-grid--articles">
          {relatedPosts.map((entry) => (
            <ArticleCard post={entry} />
          ))}
        </div>
      </section>
    ) : null}

    {(previousPost || nextPost) ? (
      <section class="article-section">
        <div class="section-header">
          <div>
            <p class="section-eyebrow">Keep reading</p>
            <h2 class="section-heading section-heading--compact">Next guide</h2>
          </div>
        </div>
        <div class="panel-grid panel-grid--summary">
          {previousPost ? (
            <a class="panel nav-card" href={`/blog/${previousPost.id}`}>
              <p class="section-eyebrow">Previous</p>
              <h3>{previousPost.data.title}</h3>
              <p class="article-excerpt">{previousPost.data.summary}</p>
            </a>
          ) : null}
          {nextPost ? (
            <a class="panel nav-card" href={`/blog/${nextPost.id}`}>
              <p class="section-eyebrow">Next</p>
              <h3>{nextPost.data.title}</h3>
              <p class="article-excerpt">{nextPost.data.summary}</p>
            </a>
          ) : null}
        </div>
      </section>
    ) : null}
  </article>
</BaseLayout>
