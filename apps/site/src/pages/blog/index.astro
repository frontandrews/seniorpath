---
import { getCollection } from 'astro:content'

import ArticleCard from '../../components/ArticleCard.astro'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { sortGuides } from '../../lib/guide-tree'

const posts = sortGuides(await getCollection('blog'))
const categories = [...new Set(posts.map((post) => post.data.category))]
const topics = [...new Set(posts.map((post) => post.data.topic).filter(Boolean))]
---

<BaseLayout
  description="Browse the Path to Senior: structured learn-first guides for deeper understanding, stronger interviews, and better engineering judgment."
  title="Path to Senior"
>
  <section class="section section--compact">
    <div class="panel page-toolbar">
      <div class="page-toolbar__intro">
        <h1 class="section-heading section-heading--compact">Path to Senior</h1>
        <p class="page-toolbar__copy">Learn the deeper idea first. Practice when you want to validate it.</p>
      </div>
    </div>

    <div class="panel guide-directory-controls">
      <div class="guide-directory-controls__grid">
        <label class="guide-directory-search">
          <input
            class="guide-directory-search__input"
            data-guide-search
            name="search"
            placeholder="React, RAG, standups, scope..."
            type="search"
          />
        </label>

        <div>
          <div class="meta-list" data-guide-filter-group="category">
            <button class="guide-filter-chip guide-filter-chip--active" data-filter-value="all" type="button">
              All
            </button>
            {categories.map((category) => (
              <button class="guide-filter-chip" data-filter-value={category} type="button">
                {category}
              </button>
            ))}
          </div>
        </div>

        <div>
          <div class="meta-list" data-guide-filter-group="topic">
            <button class="guide-filter-chip guide-filter-chip--active" data-filter-value="all" type="button">
              All
            </button>
            {topics.map((topic) => (
              <button class="guide-filter-chip" data-filter-value={topic} type="button">
                {topic}
              </button>
            ))}
          </div>
        </div>

        <div>
          <div class="meta-list" data-guide-filter-group="practice">
            <button class="guide-filter-chip guide-filter-chip--active" data-filter-value="all" type="button">
              All
            </button>
            <button class="guide-filter-chip" data-filter-value="with-practice" type="button">
              Has practice deck
            </button>
            <button class="guide-filter-chip" data-filter-value="reading-only" type="button">
              Reading only
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  {categories.map((category) => (
    <section class="section section--compact" data-guide-section={category}>
      <h2 class="section-heading section-heading--compact">{category}</h2>
      <div class="panel-grid panel-grid--articles">
        {posts
          .filter((post) => post.data.category === category)
          .map((post) => (
            <div
              data-guide-card
              data-guide-category={post.data.category}
              data-guide-has-practice={post.data.relatedDeckIds.length > 0 ? 'true' : 'false'}
              data-guide-search={`${post.data.title} ${post.data.summary} ${post.data.category} ${post.data.topic ?? ''} ${post.data.tags.join(' ')} ${post.data.path.join(' ')}`.toLowerCase()}
              data-guide-topic={post.data.topic ?? ''}
            >
              <ArticleCard post={post} />
            </div>
          ))}
      </div>
    </section>
  ))}

  <section class="section guide-directory-empty" data-guide-empty hidden>
    <div class="panel">
      <h2 class="section-heading section-heading--compact">No guides match the current filters.</h2>
      <p class="section-copy">
        Clear one filter or widen the search to reopen the full directory.
      </p>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const searchInput = document.querySelector('[data-guide-search]')
  const guideCards = [...document.querySelectorAll('[data-guide-card]')]
  const guideSections = [...document.querySelectorAll('[data-guide-section]')]
  const emptyState = document.querySelector('[data-guide-empty]')
  const url = new URL(window.location.href)
  const filters = {
    category: url.searchParams.get('category') || 'all',
    topic: url.searchParams.get('topic') || 'all',
    practice: url.searchParams.get('practice') || 'all',
  }

  if (searchInput instanceof HTMLInputElement) {
    searchInput.value = url.searchParams.get('q') || ''
  }

  const applyFilters = () => {
    let visibleCards = 0
    const query = (searchInput instanceof HTMLInputElement ? searchInput.value : '').trim().toLowerCase()

    guideCards.forEach((card) => {
      const category = card.getAttribute('data-guide-category') ?? ''
      const topic = card.getAttribute('data-guide-topic') ?? ''
      const hasPractice = card.getAttribute('data-guide-has-practice') === 'true'
      const searchText = card.getAttribute('data-guide-search') ?? ''

      const matchesCategory = filters.category === 'all' || category === filters.category
      const matchesTopic = filters.topic === 'all' || topic === filters.topic
      const matchesPractice =
        filters.practice === 'all' ||
        (filters.practice === 'with-practice' && hasPractice) ||
        (filters.practice === 'reading-only' && !hasPractice)
      const matchesQuery = !query || searchText.includes(query)
      const isVisible = matchesCategory && matchesTopic && matchesPractice && matchesQuery

      card.toggleAttribute('hidden', !isVisible)

      if (isVisible) {
        visibleCards += 1
      }
    })

    guideSections.forEach((section) => {
      const visibleChildren = section.querySelectorAll('[data-guide-card]:not([hidden])').length
      section.toggleAttribute('hidden', visibleChildren === 0)
    })

    if (emptyState) {
      emptyState.toggleAttribute('hidden', visibleCards !== 0)
    }

    const nextUrl = new URL(window.location.href)

    if (query) {
      nextUrl.searchParams.set('q', query)
    } else {
      nextUrl.searchParams.delete('q')
    }

    ;(['category', 'topic', 'practice']).forEach((key) => {
      const value = filters[key]

      if (value && value !== 'all') {
        nextUrl.searchParams.set(key, value)
      } else {
        nextUrl.searchParams.delete(key)
      }
    })

    window.history.replaceState({}, '', `${nextUrl.pathname}${nextUrl.search}${nextUrl.hash}`)
  }

  document.querySelectorAll('[data-guide-filter-group]').forEach((group) => {
    const filterGroup = group.getAttribute('data-guide-filter-group')
    const currentValue = filterGroup ? filters[filterGroup] : 'all'

    group.querySelectorAll('.guide-filter-chip').forEach((button) => {
      const isActive = button.getAttribute('data-filter-value') === currentValue
      button.classList.toggle('guide-filter-chip--active', isActive)
    })
  })

  document.querySelectorAll('[data-guide-filter-group]').forEach((group) => {
    group.addEventListener('click', (event) => {
      const target = event.target

      if (!(target instanceof HTMLButtonElement)) {
        return
      }

      const filterGroup = group.getAttribute('data-guide-filter-group')
      const filterValue = target.getAttribute('data-filter-value')

      if (!filterGroup || !filterValue) {
        return
      }

      filters[filterGroup] = filterValue

      group.querySelectorAll('.guide-filter-chip').forEach((button) => {
        button.classList.toggle('guide-filter-chip--active', button === target)
      })

      applyFilters()
    })
  })

  if (searchInput instanceof HTMLInputElement) {
    searchInput.addEventListener('input', applyFilters)
  }

  applyFilters()
</script>
