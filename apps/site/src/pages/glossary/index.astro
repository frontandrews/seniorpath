---
import { getCollection } from 'astro:content'

import GlossaryIndexPage from '@/components/GlossaryIndexPage.astro'

const terms = (await getCollection('glossary')).filter(
  (term) => term.data.locale === 'en' && term.data.status !== 'archived',
)
---

<GlossaryIndexPage locale="en" terms={terms} />
