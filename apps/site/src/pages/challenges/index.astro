---
import { getCollection } from 'astro:content'

import ChallengeIndexPage from '@/components/ChallengeIndexPage.astro'

const challenges = await getCollection('challenges')
const activeChallenges = challenges.filter((challenge) => challenge.data.locale === 'en' && challenge.data.status !== 'archived')
---

<ChallengeIndexPage challenges={activeChallenges} locale="en" />
