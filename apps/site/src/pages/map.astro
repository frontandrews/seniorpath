---
import { getCollection } from 'astro:content'

import GuideMapCard from '../components/GuideMapCard.astro'
import BaseLayout from '../layouts/BaseLayout.astro'
import { buildGuideMap } from '../lib/guide-map'

const posts = await getCollection('blog')
const sections = buildGuideMap(posts)
---

<BaseLayout
  description="A connection map for browsing how Prepdeck guides relate to each other."
  title="Connection map"
>
  <section class="section section--compact">
    <div class="panel page-toolbar">
      <div class="page-toolbar__intro">
        <h1 class="section-heading section-heading--compact">Map</h1>
        <p class="page-toolbar__copy">Explore related guides across categories.</p>
      </div>
    </div>
  </section>

  {sections.map((section) => (
    <section class="section section--compact">
      <div class="section-header">
        <div>
          <h2 class="section-heading section-heading--compact">{section.label}</h2>
        </div>
      </div>

      <div class="panel-grid panel-grid--map">
        {section.items.map((item) => (
          <GuideMapCard item={item} />
        ))}
      </div>
    </section>
  ))}
</BaseLayout>
