---
import { getCollection } from 'astro:content'

import ConceptsIndexPage from '@/components/ConceptsIndexPage.astro'

const concepts = await getCollection('concepts')
const activeConcepts = concepts.filter((concept) => concept.data.locale === 'pt-br' && concept.data.status !== 'archived')
---

<ConceptsIndexPage concepts={activeConcepts} locale="pt-br" />
