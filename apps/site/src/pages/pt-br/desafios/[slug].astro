---
import { getCollection } from 'astro:content'

import ChallengePage from '@/components/ChallengePage.astro'
import { getChallengeSlugFromEntry } from '@/lib/challenge-links'

export async function getStaticPaths() {
  const challenges = await getCollection('challenges')

  return challenges
    .filter((challenge) => challenge.data.locale === 'pt-br' && challenge.data.status !== 'archived')
    .map((challenge) => ({
      params: {
        slug: getChallengeSlugFromEntry(challenge),
      },
      props: { challenge },
    }))
}

const { challenge } = Astro.props
---

<ChallengePage challenge={challenge} />
