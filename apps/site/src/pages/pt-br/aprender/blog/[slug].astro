---
import { getCollection } from 'astro:content'

export async function getStaticPaths() {
  const posts = (await getCollection('guides')).filter(
    (post) => post.data.locale === 'pt-br' && post.data.status !== 'archived' && post.data.kind === 'article',
  )

  return posts.map((post) => ({
    params: {
      slug: post.id.replace(/^\/+|\/+$/g, '').split('/').filter(Boolean).at(-1) ?? post.id,
    },
  }))
}

return Astro.redirect(`/pt-br/artigos/artigo/${Astro.params.slug}`, 301)
---
