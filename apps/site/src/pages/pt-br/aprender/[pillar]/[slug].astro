---
import { getCollection } from 'astro:content'

import GuideArticlePage from '../../../../components/GuideArticlePage.astro'
import { getGuideCanonicalParams } from '../../../../lib/guide-taxonomy'

export async function getStaticPaths() {
  const posts = (await getCollection('guides')).filter(
    (post) => post.data.locale === 'pt-br' && post.data.status !== 'archived',
  )

  return posts.flatMap((post) => {
    const params = getGuideCanonicalParams(post)

    if (!params) {
      return []
    }

    return [
      {
        params,
        props: {
          post,
        },
      },
    ]
  })
}

const { post } = Astro.props
---

<GuideArticlePage post={post} />
