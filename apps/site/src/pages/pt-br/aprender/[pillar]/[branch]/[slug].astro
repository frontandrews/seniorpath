---
import { getCollection } from 'astro:content'
import { getPathBranchRouteSegment, getPathPillarRouteSegment } from '@seniorpath/content'

export async function getStaticPaths() {
  const posts = (await getCollection('guides')).filter(
    (post) => post.data.locale === 'pt-br' && post.data.status !== 'archived',
  )

  return posts.flatMap((post) => {
    if (!post.data.pillarId || !post.data.branchId) {
      return []
    }

    const pillar = getPathPillarRouteSegment(post.data.pillarId, 'pt-br')
    const branch = getPathBranchRouteSegment(post.data.pillarId, post.data.branchId, 'pt-br')

    if (!pillar || !branch) {
      return []
    }

    return [
      {
        params: {
          branch,
          pillar,
          slug: post.id.replace(/^\/+|\/+$/g, '').split('/').filter(Boolean).at(-1) ?? post.id,
        },
        props: {
          post,
        },
      },
    ]
  })
}

return Astro.redirect(`/pt-br/aprender/${Astro.params.pillar}/${Astro.params.slug}`, 301)
---
