---
import type { CollectionEntry } from 'astro:content'
import { getCollection, render } from 'astro:content'

import BaseLayout from '../../../layouts/BaseLayout.astro'
import { getGuideHrefFromEntryId } from '../../../lib/guide-links'
import { translateSiteLabel, translateSiteLabels } from '../../../lib/site-labels'
import { sortGuides } from '../../../lib/guide-tree'
import { getSiteCopy } from '../../../lib/site-copy'

export async function getStaticPaths() {
  const posts = await getCollection('guides')

  return posts
    .filter((post) => post.data.locale === 'pt-br')
    .map((post) => ({
      params: {
        slug: post.id.split('/').slice(1).join('/'),
      },
      props: {
        post,
      },
    }))
}

type Props = {
  post: CollectionEntry<'guides'>
}

const { post } = Astro.props
const { Content } = await render(post)
const allPosts = sortGuides(
  (await getCollection('guides')).filter(
    (entry) => entry.data.locale === post.data.locale && entry.data.status !== 'archived',
  ),
)
const parentPathKey = post.data.path.slice(0, -1).join('>')
const connectedPosts = allPosts.filter((entry) => {
  if (entry.data.guideId === post.data.guideId) {
    return false
  }

  return post.data.relationships.includes(entry.data.guideId)
})
const relatedPosts = allPosts
  .filter((entry) => {
    if (entry.data.guideId === post.data.guideId) {
      return false
    }

    if (post.data.relationships.includes(entry.data.guideId)) {
      return false
    }

    const sharesTopic = entry.data.topic && entry.data.topic === post.data.topic
    const sharesTag = entry.data.tags.some((tag) => post.data.tags.includes(tag))

    return Boolean(sharesTopic || sharesTag)
  })
  .slice(0, 2)
const siblingPosts = allPosts
  .filter((entry) => {
    if (entry.id === post.id) {
      return false
    }

    return entry.data.path.slice(0, -1).join('>') === parentPathKey
  })
  .slice(0, 3)
const currentIndex = allPosts.findIndex((entry) => entry.data.guideId === post.data.guideId)
const previousPost = currentIndex >= 0 ? allPosts[currentIndex + 1] ?? null : null
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] ?? null : null
const nextReads = [...new Map(
  [nextPost, previousPost, ...connectedPosts, ...siblingPosts, ...relatedPosts]
    .filter((entry): entry is NonNullable<typeof entry> => Boolean(entry))
    .filter((entry) => entry.data.guideId !== post.data.guideId)
    .map((entry) => [entry.data.guideId, entry]),
).values()].slice(0, 3)
const copy = getSiteCopy(post.data.locale)
const translatedCategory = translateSiteLabel(post.data.category, post.data.locale)
const translatedTopic = post.data.topic ? translateSiteLabel(post.data.topic, post.data.locale) : null
const articleKicker = translatedTopic && translatedTopic !== translatedCategory
  ? `${translatedCategory} / ${translatedTopic}`
  : translatedCategory
const articlePath = translateSiteLabels(
  post.data.path[0] === post.data.category ? post.data.path.slice(1) : post.data.path,
  post.data.locale,
)
const translatedTags = translateSiteLabels(post.data.tags, post.data.locale)
---

<BaseLayout description={post.data.description} title={post.data.title}>
  <article class="article-shell">
    <header class="article-header">
      <p class="article-kicker">{articleKicker}</p>
      {articlePath.length > 0 ? <p class="article-path">{articlePath.join(' / ')}</p> : null}
      <h1 class="article-title">{post.data.title}</h1>
      <p class="article-excerpt">{post.data.description}</p>
      <div class="article-author-row">
        <div class="article-author-avatar" aria-hidden="true">AR</div>
        <div class="article-author-copy">
          <p class="article-author-name">Andrews Ribeiro</p>
          <p class="article-author-meta">
            {post.data.pubDate.toLocaleDateString('pt-BR', {
              day: 'numeric',
              month: 'long',
              year: 'numeric',
            })}
            {post.data.updatedDate
              ? ` · ${copy.article.updatedPrefix} ${post.data.updatedDate.toLocaleDateString('pt-BR', {
                  day: 'numeric',
                  month: 'short',
                  year: 'numeric',
                })}`
              : ''}
          </p>
        </div>
      </div>
      <div class="meta-list article-header-actions">
        <button class="button-link" data-guide-complete-toggle data-guide-id={post.data.guideId} type="button">
          {copy.article.markCompleted}
        </button>
      </div>
      {post.data.tags.length > 0 ? (
        <div class="meta-list article-tags">
          {translatedTags.map((tag) => (
            <span class="badge">{tag}</span>
          ))}
        </div>
      ) : null}
    </header>

    {(post.data.takeaways.length > 0 || post.data.practiceChecklist.length > 0) ? (
      <section class="article-section article-section--summary">
        <div class="panel-grid panel-grid--summary">
          {post.data.takeaways.length > 0 ? (
            <div class="panel article-related-card">
              <div>
                <p class="section-eyebrow">{copy.article.quickSummary}</p>
                <h2 class="section-heading section-heading--compact">{copy.article.quickSummaryTitle}</h2>
              </div>
              <ul class="article-prose compact-list">
                {post.data.takeaways.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            </div>
          ) : null}

          {post.data.practiceChecklist.length > 0 ? (
            <div class="panel article-related-card">
              <div>
                <p class="section-eyebrow">{copy.article.practiceChecklist}</p>
                <h2 class="section-heading section-heading--compact">{copy.article.practiceChecklistTitle}</h2>
              </div>
              <ul class="article-prose compact-list">
                {post.data.practiceChecklist.map((step) => (
                  <li>{step}</li>
                ))}
              </ul>
            </div>
          ) : null}
        </div>
      </section>
    ) : null}

    <div class="article-prose">
      <Content />
    </div>

    {nextReads.length > 0 ? (
      <section class="article-section">
        <div class="section-header">
          <div>
            <h2 class="section-heading section-heading--compact">{copy.article.nextReads}</h2>
          </div>
        </div>
        <div class="panel-grid panel-grid--summary">
          {nextReads.map((entry) => (
            <a class="panel next-read-card" href={getGuideHrefFromEntryId(entry.id)}>
              <h3>{entry.data.title}</h3>
              <p class="article-excerpt">{entry.data.summary}</p>
            </a>
          ))}
        </div>
      </section>
    ) : null}
  </article>
</BaseLayout>
