---
import { getCollection } from 'astro:content'
import { getTopicGroupRouteSegment, TOPIC_GROUP_DEFINITIONS } from '@seniorpath/content'

import TopicGroupPage from '@/components/TopicGroupPage.astro'
import { getAvailableTopicsInGroup, getTopicGroupGuides } from '@/lib/topic-taxonomy'

export async function getStaticPaths() {
  const posts = await getCollection('guides')

  const groupPaths = TOPIC_GROUP_DEFINITIONS.flatMap((group) => {
    const topics = getAvailableTopicsInGroup(posts, group.id, 'pt-br')
    const topicPosts = getTopicGroupGuides(posts, group.id, 'pt-br')

    if (topics.length === 0 && topicPosts.length === 0) {
      return []
    }

    return [
      {
        params: {
          topic: getTopicGroupRouteSegment(group.id, 'pt-br'),
        },
        props: {
          groupId: group.id,
          posts: topicPosts,
          topics,
        },
      },
    ]
  })

  return groupPaths
}

const { groupId, posts = [], topics = [] } = Astro.props
---

{groupId ? <TopicGroupPage groupId={groupId} locale="pt-br" posts={posts} topics={topics} /> : null}
