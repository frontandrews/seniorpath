---
import { getCollection } from 'astro:content'
import { TOPIC_DEFINITIONS } from '@seniorpath/content'

import TopicPage from '../../../components/TopicPage.astro'
import { getTopicGuides } from '../../../lib/topic-taxonomy'

export async function getStaticPaths() {
  const posts = await getCollection('guides')

  return TOPIC_DEFINITIONS.flatMap((topic) => {
    const topicPosts = getTopicGuides(posts, topic.id, 'pt-br')

    if (topicPosts.length === 0) {
      return []
    }

    return [
      {
        params: {
          topic: topic.routeSegment,
        },
        props: {
          posts: topicPosts,
          topicId: topic.id,
        },
      },
    ]
  })
}

const { posts, topicId } = Astro.props
---

<TopicPage locale="pt-br" posts={posts} topicId={topicId} />
