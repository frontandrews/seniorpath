---
import { getCollection } from 'astro:content'

import TopicIndexPage from '@/components/TopicIndexPage.astro'

const posts = await getCollection('guides')
const activePosts = posts.filter((post) => post.data.locale === 'pt-br' && post.data.status !== 'archived')
---

<TopicIndexPage locale="pt-br" posts={activePosts} />
