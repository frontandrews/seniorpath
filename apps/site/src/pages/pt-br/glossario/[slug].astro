---
import { getCollection } from 'astro:content'

import GlossaryTermPage from '../../../components/GlossaryTermPage.astro'

export async function getStaticPaths() {
  const terms = await getCollection('glossary')

  return terms
    .filter((term) => term.data.locale === 'pt-br')
    .map((term) => ({
      params: {
        slug: term.id.split('/').slice(1).join('/'),
      },
      props: {
        term,
      },
    }))
}

const { term } = Astro.props
---

<GlossaryTermPage term={term} />
