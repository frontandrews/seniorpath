---
import { getCollection } from 'astro:content'

import GuideArticlePage from '@/components/GuideArticlePage.astro'
import { getGuideHrefFromEntry, getGuideLegacyHrefFromEntryId } from '@/lib/guide-links'

export async function getStaticPaths() {
  const posts = await getCollection('guides')

  return posts
    .filter((post) => {
      if (post.data.locale !== 'pt-br') {
        return false
      }

      if (post.data.status === 'archived') {
        return true
      }

      return getGuideLegacyHrefFromEntryId(post.id) !== getGuideHrefFromEntry(post)
    })
    .map((post) => ({
      params: {
        slug: post.id.split('/').slice(1).join('/'),
      },
      props: {
        post,
      },
    }))
}

const { post } = Astro.props
const canonicalHref = getGuideHrefFromEntry(post)
const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/'

if (post.data.status !== 'archived' && canonicalHref !== currentPath) {
  return Astro.redirect(canonicalHref, 301)
}
---

<GuideArticlePage post={post} />
