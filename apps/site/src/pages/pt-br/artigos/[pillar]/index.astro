---
import { getCollection } from 'astro:content'
import { PATH_TO_SENIOR_PILLARS } from '@seniorpath/content'

import GuidePillarPage from '@/components/GuidePillarPage.astro'
import { sortGuides } from '@/lib/guide-tree'

export async function getStaticPaths() {
  const posts = (await getCollection('guides')).filter(
    (post) => post.data.locale === 'pt-br' && post.data.status !== 'archived',
  )

  return PATH_TO_SENIOR_PILLARS.flatMap((pillar) => {
    const pillarPosts = sortGuides(posts.filter((post) => post.data.pillarId === pillar.id))

    if (pillarPosts.length === 0) {
      return []
    }

    return [
      {
        params: {
          pillar: pillar.routeSegment['pt-br'],
        },
        props: {
          branchSections: pillar.branches
            .map((branch) => ({
              branch,
              posts: pillarPosts.filter((post) => post.data.branchId === branch.id),
            }))
            .filter((section) => section.posts.length > 0),
          pillar,
        },
      },
    ]
  })
}

const { branchSections, pillar } = Astro.props
---

<GuidePillarPage branchSections={branchSections} locale="pt-br" pillar={pillar} />
