{
  "name": "@template/site",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "build": "node ./scripts/sync-content.mjs && astro build && node ./scripts/build-search-index.mjs",
    "check": "node ./scripts/sync-content.mjs && astro check",
    "content:sync": "node ./scripts/sync-content.mjs",
    "dev": "node ./scripts/sync-content.mjs && astro dev",
    "preview": "node ./scripts/sync-content.mjs && astro preview",
    "style:guard": "node ./scripts/style-guard.mjs",
    "tailwind:canonical": "node ./scripts/tailwind-canonical.mjs",
    "tailwind:canonical:fix": "node ./scripts/tailwind-canonical.mjs --write"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.12",
    "@astrojs/svelte": "^8.0.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@lucide/astro": "^0.577.0",
    "@template/content": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "marked": "^17.0.5",
    "sucrase": "^3.35.1",
    "svelte": "^5.54.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/sitemap": "^3.7.1",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^6.0.5",
    "pagefind": "^1.4.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
}
