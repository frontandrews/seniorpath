{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://andrews.local/schemas/deck.schema.json",
  "title": "Flashcard Deck",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "topic",
    "description",
    "difficulty",
    "cards"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "difficulty": {
      "type": "string",
      "enum": ["easy", "medium", "hard"]
    },
    "estimatedMinutes": {
      "type": "integer",
      "minimum": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "cards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./flashcard.schema.json"
      }
    }
  }
}
