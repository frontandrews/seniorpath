{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://andrews.local/schemas/flashcard.schema.json",
  "title": "Flashcard",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "difficulty",
    "question",
    "shortAnswer",
    "expectedAnswer",
    "keyPoints",
    "tags"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": ["concept", "tradeoff", "scenario", "behavioral"]
    },
    "difficulty": {
      "type": "string",
      "enum": ["easy", "medium", "hard"]
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "shortAnswer": {
      "type": "string",
      "minLength": 1
    },
    "expectedAnswer": {
      "type": "string",
      "minLength": 1
    },
    "keyPoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "commonTraps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "followUps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    }
  }
}
